      "html": "\n<div class=\"flex w-full bg-[#080812] text-[#f8fafc] font-sans selection:bg-[#8b5cf6]/30\" data-kid=\"0\">\n  <style data-kid=\"1\">\n    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Space+Grotesk:wght@400;500;600;700&display=swap');\n\n    :root {\n      --primary: #8b5cf6;\n      --primary-glow: rgba(139, 92, 246, 0.4);\n      --bg-base: #080812;\n      --bg-surface: #0d0d1f;\n      --border-subtle: rgba(255, 255, 255, 0.06);\n    }\n\n    .font-heading { font-family: 'Space Grotesk', sans-serif; }\n    \n    .glass-card {\n      background: rgba(255, 255, 255, 0.03);\n      backdrop-filter: blur(20px);\n      border: 1px solid rgba(255, 255, 255, 0.06);\n    }\n\n    .neon-glow {\n      box-shadow: 0 0 20px rgba(139, 92, 246, 0.15);\n    }\n\n    .neon-button {\n      background: linear-gradient(135deg, #8b5cf6, #6d28d9);\n      box-shadow: 0 0 20px rgba(139, 92, 246, 0.3);\n      transition: all 0.3s ease;\n    }\n\n    .neon-button:hover {\n      box-shadow: 0 0 35px rgba(139, 92, 246, 0.5);\n      transform: translateY(-1px);\n    }\n\n    .sidebar-link.active {\n      background: linear-gradient(90deg, rgba(139, 92, 246, 0.1) 0%, transparent 100%);\n      color: #8b5cf6;\n      border-left: 3px solid #8b5cf6;\n    }\n\n    .sidebar-link i {\n      transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);\n    }\n\n    .sidebar-link:hover i {\n      filter: drop-shadow(0 0 8px #8b5cf6);\n      transform: scale(1.1);\n    }\n\n    .animate-glow {\n      animation: logoGlow 3s ease-in-out infinite;\n    }\n\n    @keyframes logoGlow {\n      0%, 100% { box-shadow: 0 0 20px rgba(139, 92, 246, 0.3); }\n      50% { box-shadow: 0 0 40px rgba(139, 92, 246, 0.6); }\n    }\n\n    /* Custom Scrollbar */\n    ::-webkit-scrollbar { width: 6px; }\n    ::-webkit-scrollbar-track { background: transparent; }\n    ::-webkit-scrollbar-thumb { background: rgba(255, 255, 255, 0.1); border-radius: 10px; }\n    ::-webkit-scrollbar-thumb:hover { background: rgba(139, 92, 246, 0.3); }\n  </style>\n\n  \n  <aside class=\"w-72 bg-[#0d0d1f]/50 backdrop-blur-3xl border-r border-white/5 flex flex-col min-h-[1500px]\" data-kid=\"2\">\n    <div class=\"p-8\" data-kid=\"3\">\n      <div class=\"flex items-center gap-3 group cursor-pointer\" data-kid=\"4\">\n        <div class=\"w-10 h-10 rounded-xl bg-gradient-to-br from-[#8b5cf6] to-[#3b82f6] flex items-center justify-center animate-glow group-hover:scale-110 transition-transform\" data-kid=\"5\">\n          <i data-lucide=\"zap\" class=\"text-white w-5 h-5\" data-kid=\"6\"></i>\n        </div>\n        <span class=\"text-xl font-bold font-heading tracking-tight bg-gradient-to-r from-white to-white/60 bg-clip-text text-transparent\" data-kid=\"7\">InterviewAI</span>\n      </div>\n    </div>\n\n    <nav class=\"flex-1 px-4 space-y-1\" data-kid=\"8\">\n      <div class=\"px-4 py-2 text-[10px] font-bold text-slate-500 uppercase tracking-widest\" data-kid=\"9\">Management</div>\n      <div class=\"sidebar-link active flex items-center gap-3 px-4 py-3 text-sm font-medium transition-all\" data-kid=\"10\">\n        <i data-lucide=\"history\" class=\"w-4 h-4 opacity-70\" data-kid=\"11\"></i> Interview History\n      </div>\n      <div class=\"sidebar-link flex items-center gap-3 px-4 py-3 text-sm font-medium transition-all text-slate-400\" data-kid=\"12\">\n        <i data-lucide=\"credit-card\" class=\"w-4 h-4 opacity-70\" data-kid=\"13\"></i> Billing & Plans\n      </div>\n      <div class=\"sidebar-link flex items-center gap-3 px-4 py-3 text-sm font-medium transition-all text-slate-400\" data-kid=\"14\">\n        <i data-lucide=\"settings\" class=\"w-4 h-4 opacity-70\" data-kid=\"15\"></i> User Settings\n      </div>\n      <div class=\"sidebar-link flex items-center gap-3 px-4 py-3 text-sm font-medium transition-all text-slate-400\" data-kid=\"16\">\n        <i data-lucide=\"shield-check\" class=\"w-4 h-4 opacity-70\" data-kid=\"17\"></i> Admin Panel\n      </div>\n\n      <div class=\"pt-8 px-4 py-2 text-[10px] font-bold text-slate-500 uppercase tracking-widest\" data-kid=\"18\">Resources</div>\n      <div class=\"sidebar-link flex items-center gap-3 px-4 py-3 text-sm font-medium transition-all text-slate-400\" data-kid=\"19\">\n        <i data-lucide=\"help-circle\" class=\"w-4 h-4\" data-kid=\"20\"></i> Documentation\n      </div>\n      <div class=\"sidebar-link flex items-center gap-3 px-4 py-3 text-sm font-medium transition-all text-slate-400\" data-kid=\"21\">\n        <i data-lucide=\"message-square\" class=\"w-4 h-4\" data-kid=\"22\"></i> Support\n      </div>\n    </nav>\n\n    <div class=\"p-6 border-t border-white/5\" data-kid=\"23\">\n      <div class=\"glass-card p-4 rounded-2xl flex items-center gap-3 hover:bg-white/[0.05] transition-all cursor-pointer group\" data-kid=\"24\">\n        <img src=\"https://i.pravatar.cc/100?u=john\" class=\"w-10 h-10 rounded-full border border-white/10\" alt=\"Avatar\" data-kid=\"25\">\n        <div class=\"flex-1 min-w-0\" data-kid=\"26\">\n          <p class=\"text-xs font-bold truncate\" data-kid=\"27\">John Doe</p>\n          <p class=\"text-[10px] text-slate-500 truncate\" data-kid=\"28\">Pro Member</p>\n        </div>\n        <button class=\"text-slate-500 group-hover:text-white transition-colors\" data-kid=\"29\"><i data-lucide=\"log-out\" class=\"w-4 h-4\" data-kid=\"30\"></i></button>\n      </div>\n    </div>\n  </aside>\n\n  \n  <main class=\"flex-1 min-w-0 bg-[radial-gradient(#ffffff05_1px,transparent_1px)] [background-size:32px_32px]\" data-kid=\"31\">\n    \n    <header class=\"h-20 border-b border-white/5 bg-[#080812]/80 backdrop-blur-md flex items-center justify-between px-10\" data-kid=\"32\">\n      <div class=\"flex items-center gap-4\" data-kid=\"33\">\n        <h2 class=\"text-lg font-bold font-heading\" data-kid=\"34\">Management Hub</h2>\n        <span class=\"px-2 py-0.5 rounded-md bg-white/5 text-[10px] font-bold text-slate-500 uppercase tracking-tighter\" data-kid=\"35\">V 2.4.0</span>\n      </div>\n      <div class=\"flex items-center gap-6\" data-kid=\"36\">\n        <div class=\"flex items-center gap-2 bg-white/5 px-3 py-1.5 rounded-full border border-white/10\" data-kid=\"37\">\n          <div class=\"w-2 h-2 rounded-full bg-green-500 animate-pulse\" data-kid=\"38\"></div>\n          <span class=\"text-[10px] font-bold text-slate-400\" data-kid=\"39\">AI Nodes: Operational</span>\n        </div>\n        <button class=\"relative text-slate-400 hover:text-white transition-colors\" data-kid=\"40\">\n          <i data-lucide=\"bell\" class=\"w-5 h-5\" data-kid=\"41\"></i>\n          <span class=\"absolute -top-1 -right-1 w-2 h-2 bg-red-500 rounded-full border-2 border-[#080812]\" data-kid=\"42\"></span>\n        </button>\n      </div>\n    </header>\n\n    <div class=\"p-10 space-y-24 pb-32\" data-kid=\"43\">\n      \n      \n      <section id=\"history\" class=\"space-y-10\" data-kid=\"44\">\n        <div class=\"flex items-center justify-between\" data-kid=\"45\">\n          <div data-kid=\"46\">\n            <h3 class=\"text-3xl font-black font-heading tracking-tight uppercase\" data-kid=\"47\">Interview History</h3>\n            <p class=\"text-slate-400 mt-1\" data-kid=\"48\">Review your past sessions and track your progress metrics.</p>\n          </div>\n          <div class=\"flex gap-3\" data-kid=\"49\">\n            <div class=\"relative group\" data-kid=\"50\">\n              <i data-lucide=\"search\" class=\"absolute left-3 top-1/2 -translate-y-1/2 text-slate-500 w-4 h-4 group-focus-within:text-[#8b5cf6]\" data-kid=\"51\"></i>\n              <input type=\"text\" placeholder=\"Search sessions...\" class=\"bg-white/5 border border-white/10 rounded-xl pl-10 pr-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-[#8b5cf6]/50 w-72 transition-all\" data-kid=\"52\">\n            </div>\n            <button class=\"bg-white/5 border border-white/10 rounded-xl px-4 py-2 text-sm flex items-center gap-2 hover:bg-white/10 transition-colors\" data-kid=\"53\">\n              <i data-lucide=\"filter\" class=\"w-3.5 h-3.5 text-slate-500\" data-kid=\"54\"></i> All Roles\n            </button>\n          </div>\n        </div>\n\n        <div class=\"relative space-y-8 pl-10\" data-kid=\"55\">\n          \n          <div class=\"absolute left-[13px] top-4 bottom-4 w-px bg-gradient-to-b from-[#8b5cf6]/50 via-white/10 to-transparent\" data-kid=\"56\"></div>\n\n          \n          <div class=\"relative group/item\" data-kid=\"57\">\n            <div class=\"absolute -left-[35px] top-7 w-6 h-6 rounded-full bg-[#080812] border-2 border-[#8b5cf6] shadow-[0_0_15px_rgba(139,92,246,0.5)] z-10 flex items-center justify-center group-hover/item:scale-125 transition-transform\" data-kid=\"58\">\n              <div class=\"w-1.5 h-1.5 bg-white rounded-full animate-pulse\" data-kid=\"59\"></div>\n            </div>\n            <div class=\"glass-card rounded-3xl p-6 flex flex-col md:flex-row items-center gap-8 hover:border-[#8b5cf6]/40 transition-all hover:bg-white/[0.05] group\" data-kid=\"60\">\n              <div class=\"w-16 h-16 rounded-2xl bg-[#8b5cf6]/10 border border-[#8b5cf6]/20 flex items-center justify-center shrink-0 group-hover:scale-105 transition-transform\" data-kid=\"61\">\n                <i data-lucide=\"building-2\" class=\"text-[#8b5cf6] w-8 h-8\" data-kid=\"62\"></i>\n              </div>\n              <div class=\"flex-1 min-w-0\" data-kid=\"63\">\n                <div class=\"flex items-center gap-3 mb-2\" data-kid=\"64\">\n                  <h4 class=\"text-xl font-bold truncate\" data-kid=\"65\">Senior Frontend Engineer</h4>\n                  <span class=\"px-2.5 py-0.5 rounded-full text-[10px] font-bold uppercase tracking-widest bg-[#8b5cf6]/20 text-[#8b5cf6] border border-[#8b5cf6]/30\" data-kid=\"66\">Technical</span>\n                </div>\n                <div class=\"flex flex-wrap items-center gap-5 text-sm text-slate-500\" data-kid=\"67\">\n                  <span class=\"flex items-center gap-2 bg-white/5 px-2 py-1 rounded-lg border border-white/5\" data-kid=\"68\"><i data-lucide=\"calendar\" class=\"w-3.5 h-3.5\" data-kid=\"69\"></i> May 24, 2026</span>\n                  <span class=\"flex items-center gap-2 bg-white/5 px-2 py-1 rounded-lg border border-white/5\" data-kid=\"70\"><i data-lucide=\"clock\" class=\"w-3.5 h-3.5\" data-kid=\"71\"></i> 45m Session</span>\n                  <span class=\"flex items-center gap-2 text-slate-300 font-medium\" data-kid=\"72\"><i data-lucide=\"at-sign\" class=\"w-3.5 h-3.5\" data-kid=\"73\"></i> Google</span>\n                </div>\n              </div>\n              <div class=\"flex items-center gap-10 px-10 border-x border-white/5\" data-kid=\"74\">\n                <div class=\"text-center\" data-kid=\"75\">\n                  <p class=\"text-3xl font-black text-white\" data-kid=\"76\">88</p>\n                  <p class=\"text-[10px] font-bold text-slate-500 uppercase tracking-widest mt-1\" data-kid=\"77\">AATS Score</p>\n                </div>\n              </div>\n              <div class=\"flex gap-2\" data-kid=\"78\">\n                <button class=\"h-10 w-10 flex items-center justify-center rounded-xl bg-white/5 border border-white/10 text-slate-400 hover:text-[#8b5cf6] hover:bg-[#8b5cf6]/10 hover:border-[#8b5cf6]/30 transition-all\" data-kid=\"79\"><i data-lucide=\"play\" class=\"w-4 h-4\" data-kid=\"80\"></i></button>\n                <button class=\"h-10 w-10 flex items-center justify-center rounded-xl bg-white/5 border border-white/10 text-slate-400 hover:text-white hover:bg-white/10 transition-all\" data-kid=\"81\"><i data-lucide=\"file-text\" class=\"w-4 h-4\" data-kid=\"82\"></i></button>\n                <button class=\"h-10 w-10 flex items-center justify-center rounded-xl bg-white/5 border border-white/10 text-slate-400 hover:text-white hover:bg-white/10 transition-all\" data-kid=\"83\"><i data-lucide=\"share-2\" class=\"w-4 h-4\" data-kid=\"84\"></i></button>\n              </div>\n            </div>\n          </div>\n\n          \n          <div class=\"relative\" data-kid=\"85\">\n            <div class=\"absolute -left-[35px] top-7 w-6 h-6 rounded-full bg-[#080812] border-2 border-[#3b82f6] shadow-[0_0_15px_rgba(59,130,246,0.3)] z-10 flex items-center justify-center\" data-kid=\"86\">\n              <div class=\"w-1.5 h-1.5 bg-white rounded-full\" data-kid=\"87\"></div>\n            </div>\n            <div class=\"glass-card rounded-3xl p-6 flex flex-col md:flex-row items-center gap-8 hover:border-[#3b82f6]/40 transition-all hover:bg-white/[0.05] group\" data-kid=\"88\">\n              <div class=\"w-16 h-16 rounded-2xl bg-[#3b82f6]/10 border border-[#3b82f6]/20 flex items-center justify-center shrink-0 group-hover:scale-105 transition-transform\" data-kid=\"89\">\n                <i data-lucide=\"briefcase\" class=\"text-[#3b82f6] w-8 h-8\" data-kid=\"90\"></i>\n              </div>\n              <div class=\"flex-1 min-w-0\" data-kid=\"91\">\n                <div class=\"flex items-center gap-3 mb-2\" data-kid=\"92\">\n                  <h4 class=\"text-xl font-bold truncate\" data-kid=\"93\">Product Manager</h4>\n                  <span class=\"px-2.5 py-0.5 rounded-full text-[10px] font-bold uppercase tracking-widest bg-[#3b82f6]/20 text-[#3b82f6] border border-[#3b82f6]/30\" data-kid=\"94\">Behavioral</span>\n                </div>\n                <div class=\"flex flex-wrap items-center gap-5 text-sm text-slate-500\" data-kid=\"95\">\n                  <span class=\"flex items-center gap-2 bg-white/5 px-2 py-1 rounded-lg border border-white/5\" data-kid=\"96\"><i data-lucide=\"calendar\" class=\"w-3.5 h-3.5\" data-kid=\"97\"></i> May 22, 2026</span>\n                  <span class=\"flex items-center gap-2 bg-white/5 px-2 py-1 rounded-lg border border-white/5\" data-kid=\"98\"><i data-lucide=\"clock\" class=\"w-3.5 h-3.5\" data-kid=\"99\"></i> 60m Session</span>\n                  <span class=\"flex items-center gap-2 text-slate-300 font-medium\" data-kid=\"100\"><i data-lucide=\"at-sign\" class=\"w-3.5 h-3.5\" data-kid=\"101\"></i> Amazon</span>\n                </div>\n              </div>\n              <div class=\"flex items-center gap-10 px-10 border-x border-white/5\" data-kid=\"102\">\n                <div class=\"text-center\" data-kid=\"103\">\n                  <p class=\"text-3xl font-black text-slate-400\" data-kid=\"104\">74</p>\n                  <p class=\"text-[10px] font-bold text-slate-500 uppercase tracking-widest mt-1\" data-kid=\"105\">AATS Score</p>\n                </div>\n              </div>\n              <div class=\"flex gap-2\" data-kid=\"106\">\n                <button class=\"h-10 w-10 flex items-center justify-center rounded-xl bg-white/5 border border-white/10 text-slate-400 hover:text-[#3b82f6] hover:bg-[#3b82f6]/10 hover:border-[#3b82f6]/30 transition-all\" data-kid=\"107\"><i data-lucide=\"play\" class=\"w-4 h-4\" data-kid=\"108\"></i></button>\n                <button class=\"h-10 w-10 flex items-center justify-center rounded-xl bg-white/5 border border-white/10 text-slate-400 hover:text-white hover:bg-white/10 transition-all\" data-kid=\"109\"><i data-lucide=\"file-text\" class=\"w-4 h-4\" data-kid=\"110\"></i></button>\n                <button class=\"h-10 w-10 flex items-center justify-center rounded-xl bg-white/5 border border-white/10 text-slate-400 hover:text-white hover:bg-white/10 transition-all\" data-kid=\"111\"><i data-lucide=\"share-2\" class=\"w-4 h-4\" data-kid=\"112\"></i></button>\n              </div>\n            </div>\n          </div>\n        </div>\n      </section>\n\n      \n      <section id=\"billing\" class=\"space-y-10\" data-kid=\"113\">\n        <div data-kid=\"114\">\n          <h3 class=\"text-3xl font-black font-heading tracking-tight uppercase\" data-kid=\"115\">Billing & Subscriptions</h3>\n          <p class=\"text-slate-400 mt-1\" data-kid=\"116\">Manage your active plans, usage limits and payment history.</p>\n        </div>\n\n        <div class=\"grid grid-cols-1 lg:grid-cols-12 gap-6\" data-kid=\"117\">\n          \n          <div class=\"lg:col-span-8 glass-card rounded-3xl p-8 flex flex-col justify-between overflow-hidden relative\" data-kid=\"118\">\n            <div class=\"absolute top-0 right-0 w-64 h-64 bg-[#8b5cf6]/10 rounded-full blur-[100px] -mr-32 -mt-32\" data-kid=\"119\"></div>\n            <div class=\"flex items-center justify-between mb-10\" data-kid=\"120\">\n              <div class=\"flex items-center gap-4\" data-kid=\"121\">\n                <div class=\"w-12 h-12 rounded-2xl bg-[#8b5cf6]/20 border border-[#8b5cf6]/30 flex items-center justify-center neon-glow\" data-kid=\"122\">\n                  <i data-lucide=\"zap\" class=\"text-[#8b5cf6] w-6 h-6\" data-kid=\"123\"></i>\n                </div>\n                <div data-kid=\"124\">\n                  <h4 class=\"text-lg font-bold\" data-kid=\"125\">Credits & Usage</h4>\n                  <p class=\"text-xs text-slate-500\" data-kid=\"126\">Resetting in 7 days (June 1st)</p>\n                </div>\n              </div>\n              <button class=\"px-5 py-2.5 rounded-xl bg-[#8b5cf6]/10 border border-[#8b5cf6]/30 text-[#8b5cf6] text-sm font-bold hover:bg-[#8b5cf6]/20 transition-all\" data-kid=\"127\">Add Credits</button>\n            </div>\n            \n            <div class=\"space-y-8\" data-kid=\"128\">\n              <div class=\"space-y-3\" data-kid=\"129\">\n                <div class=\"flex justify-between items-end\" data-kid=\"130\">\n                  <span class=\"text-sm font-bold text-slate-300\" data-kid=\"131\">Interview Sessions</span>\n                  <span class=\"text-sm font-black text-white\" data-kid=\"132\">4 <span class=\"text-slate-500 font-medium\" data-kid=\"133\">/ 5</span></span>\n                </div>\n                <div class=\"h-2.5 bg-white/5 rounded-full overflow-hidden border border-white/5 p-0.5\" data-kid=\"134\">\n                  <div class=\"h-full bg-gradient-to-r from-[#8b5cf6] to-[#d946ef] rounded-full shadow-[0_0_10px_rgba(139,92,246,0.5)]\" style=\"width: 80%\" data-kid=\"135\"></div>\n                </div>\n              </div>\n              <div class=\"space-y-3\" data-kid=\"136\">\n                <div class=\"flex justify-between items-end\" data-kid=\"137\">\n                  <span class=\"text-sm font-bold text-slate-300\" data-kid=\"138\">Resume ATS Scans</span>\n                  <span class=\"text-sm font-black text-white\" data-kid=\"139\">12 <span class=\"text-slate-500 font-medium\" data-kid=\"140\">/ 20</span></span>\n                </div>\n                <div class=\"h-2.5 bg-white/5 rounded-full overflow-hidden border border-white/5 p-0.5\" data-kid=\"141\">\n                  <div class=\"h-full bg-gradient-to-r from-[#06b6d4] to-[#3b82f6] rounded-full shadow-[0_0_10px_rgba(6,182,212,0.5)]\" style=\"width: 60%\" data-kid=\"142\"></div>\n                </div>\n              </div>\n            </div>\n          </div>\n\n          \n          <div class=\"lg:col-span-4 bg-gradient-to-br from-[#8b5cf6] to-[#6d28d9] rounded-3xl p-8 text-white relative overflow-hidden group\" data-kid=\"143\">\n            <div class=\"absolute inset-0 bg-white/10 opacity-0 group-hover:opacity-20 transition-opacity pointer-events-none\" data-kid=\"144\"></div>\n            <div class=\"flex flex-col h-full justify-between\" data-kid=\"145\">\n              <div data-kid=\"146\">\n                <div class=\"flex items-center justify-between mb-6\" data-kid=\"147\">\n                  <span class=\"px-3 py-1 rounded-full bg-white/20 text-[10px] font-bold uppercase tracking-widest border border-white/20\" data-kid=\"148\">Current Plan</span>\n                  <i data-lucide=\"crown\" class=\"text-white/50 w-5 h-5\" data-kid=\"149\"></i>\n                </div>\n                <h3 class=\"text-3xl font-black mb-2\" data-kid=\"150\">Pro Individu