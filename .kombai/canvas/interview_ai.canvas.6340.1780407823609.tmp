      "html": "\n<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Space+Grotesk:wght@500;600;700&display=swap');\n\n  :root {\n    --primary: #8b5cf6;\n    --primary-hover: #7c3aed;\n    --secondary: #6366f1;\n    --bg-page: #080812;\n    --bg-surface: #0d0d1f;\n    --text-primary: #f8fafc;\n    --text-secondary: #94a3b8;\n    --accent: #67e8f9;\n  }\n\n  body {\n    background-color: var(--bg-page);\n    color: var(--text-primary);\n    font-family: 'Inter', sans-serif;\n    margin: 0;\n  }\n\n  .font-heading {\n    font-family: 'Space Grotesk', sans-serif;\n  }\n\n  .glass {\n    background: rgba(255, 255, 255, 0.03);\n    backdrop-filter: blur(20px);\n    -webkit-backdrop-filter: blur(20px);\n    border: 1px solid rgba(255, 255, 255, 0.08);\n  }\n\n  .neon-border {\n    border: 1px solid rgba(139, 92, 246, 0.3);\n    box-shadow: 0 0 15px rgba(139, 92, 246, 0.1);\n  }\n\n  .neon-border:focus-within {\n    border-color: var(--primary);\n    box-shadow: 0 0 20px rgba(139, 92, 246, 0.3);\n  }\n\n  @keyframes float {\n    0%, 100% { transform: translateY(0px) rotate(0deg); }\n    50% { transform: translateY(-20px) rotate(5deg); }\n  }\n\n  @keyframes pulse-glow {\n    0%, 100% { opacity: 0.5; transform: scale(1); }\n    50% { opacity: 0.8; transform: scale(1.1); }\n  }\n\n  @keyframes orbit {\n    from { transform: rotate(0deg) translateX(150px) rotate(0deg); }\n    to { transform: rotate(360deg) translateX(150px) rotate(-360deg); }\n  }\n\n  .animate-float { animation: float 6s ease-in-out infinite; }\n  .animate-pulse-glow { animation: pulse-glow 4s ease-in-out infinite; }\n  \n  .neural-line {\n    stroke-dasharray: 1000;\n    stroke-dashoffset: 1000;\n    animation: dash 5s linear infinite;\n  }\n\n  @keyframes dash {\n    to { stroke-dashoffset: 0; }\n  }\n\n  /* Custom scrollbar for small areas if needed */\n  .custom-scrollbar::-webkit-scrollbar {\n    width: 4px;\n  }\n  .custom-scrollbar::-webkit-scrollbar-track {\n    background: transparent;\n  }\n  .custom-scrollbar::-webkit-scrollbar-thumb {\n    background: rgba(255, 255, 255, 0.1);\n    border-radius: 10px;\n  }\n</style>\n\n<div class=\"flex flex-col lg:flex-row min-h-[900px] w-full bg-[var(--bg-page)]\" data-kid=\"1\">\n  \n  \n  <div class=\"relative w-full lg:w-[45%] h-[400px] lg:h-auto overflow-hidden bg-[#05050a] flex flex-col justify-center items-center px-12 border-r border-white/5\" data-kid=\"2\">\n    \n    <div class=\"absolute top-0 left-0 w-full h-full bg-[radial-gradient(circle_at_50%_50%,_#1e1b4b_0%,_transparent_70%)] opacity-40\" data-kid=\"3\"></div>\n    <div class=\"absolute -top-24 -left-24 w-96 h-96 bg-[var(--primary)] opacity-10 blur-[120px] rounded-full\" data-kid=\"4\"></div>\n    <div class=\"absolute -bottom-24 -right-24 w-96 h-96 bg-[var(--secondary)] opacity-10 blur-[120px] rounded-full\" data-kid=\"5\"></div>\n\n    \n    <svg class=\"absolute inset-0 w-full h-full opacity-20 pointer-events-none\" viewBox=\"0 0 800 800\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\" data-kid=\"6\">\n      <path d=\"M100 100L400 400M400 400L700 100M400 400L100 700M400 400L700 700\" stroke=\"var(--primary)\" stroke-width=\"1\" class=\"neural-line\" data-kid=\"7\"></path>\n      <path d=\"M200 100L400 400M400 400L600 100M400 400L200 700M400 400L600 700\" stroke=\"var(--secondary)\" stroke-width=\"0.5\" class=\"neural-line\" style=\"animation-delay: 1s;\" data-kid=\"8\"></path>\n      <circle cx=\"400\" cy=\"400\" r=\"2\" fill=\"var(--primary)\" data-kid=\"9\"></circle>\n      <circle cx=\"100\" cy=\"100\" r=\"2\" fill=\"var(--primary)\" data-kid=\"10\"></circle>\n      <circle cx=\"700\" cy=\"100\" r=\"2\" fill=\"var(--primary)\" data-kid=\"11\"></circle>\n      <circle cx=\"100\" cy=\"700\" r=\"2\" fill=\"var(--primary)\" data-kid=\"12\"></circle>\n      <circle cx=\"700\" cy=\"700\" r=\"2\" fill=\"var(--primary)\" data-kid=\"13\"></circle>\n    </svg>\n\n    \n    <div class=\"relative z-10 flex flex-col items-center\" data-kid=\"14\">\n      <div class=\"relative mb-12\" data-kid=\"15\">\n        <div class=\"absolute inset-0 bg-[var(--primary)] blur-[80px] opacity-40 animate-pulse-glow\" data-kid=\"16\"></div>\n        <div class=\"w-40 h-40 lg:w-56 lg:h-56 rounded-full bg-gradient-to-br from-[#8b5cf6] to-[#4c1d95] flex items-center justify-center p-1 shadow-[0_0_60px_rgba(139,92,246,0.5)]\" data-kid=\"17\">\n          <div class=\"w-full h-full rounded-full bg-[#0d0d1f] flex items-center justify-center overflow-hidden relative\" data-kid=\"18\">\n            \n            <div class=\"w-12 h-12 bg-white rounded-full blur-md animate-pulse\" data-kid=\"19\"></div>\n            \n            <div class=\"absolute inset-0 border-4 border-[var(--primary)]/30 rounded-full animate-[spin_10s_linear_infinite]\" data-kid=\"20\"></div>\n          </div>\n        </div>\n        \n        <div class=\"absolute -top-4 -right-4 w-6 h-6 bg-[var(--accent)] rounded-full blur-[2px] shadow-[0_0_15px_var(--accent)] animate-float\" data-kid=\"21\"></div>\n        <div class=\"absolute -bottom-8 -left-2 w-4 h-4 bg-[var(--primary)] rounded-full blur-[1px] shadow-[0_0_10px_var(--primary)] animate-float\" style=\"animation-delay: 2s;\" data-kid=\"22\"></div>\n      </div>\n\n      <div class=\"text-center max-w-sm\" data-kid=\"23\">\n        <h2 class=\"text-3xl lg:text-4xl font-bold font-heading mb-4 leading-tight\" data-kid=\"24\">Master Your Next <span class=\"text-transparent bg-clip-text bg-gradient-to-r from-[var(--primary)] to-[var(--accent)]\" data-kid=\"25\">Interview</span></h2>\n        <p class=\"text-[var(--text-secondary)] text-lg\" data-kid=\"26\">AI-driven simulation, feedback, and career matching for the world's top tech talent.</p>\n      </div>\n    </div>\n\n    \n    <div class=\"absolute bottom-12 left-12 flex items-center gap-3 opacity-40\" data-kid=\"27\">\n      <div class=\"w-2 h-2 rounded-full bg-[var(--success)] animate-pulse\" data-kid=\"28\"></div>\n      <span class=\"text-[10px] uppercase tracking-[0.2em] font-bold\" data-kid=\"29\">Neural Engine v4.2.0 Active</span>\n    </div>\n  </div>\n\n  \n  <div class=\"w-full lg:w-[55%] flex flex-col items-center justify-center p-8 lg:p-20 relative\" data-kid=\"30\">\n    \n    \n    <div class=\"absolute top-12 left-8 lg:left-20 flex items-center gap-3\" data-kid=\"31\">\n      <div class=\"w-10 h-10 bg-gradient-to-br from-[var(--primary)] to-[var(--secondary)] rounded-xl flex items-center justify-center\" data-kid=\"32\">\n        <svg xmlns=\"http://www.w3.org/2000/svg\" class=\"w-6 h-6 text-white\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\" data-kid=\"33\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2.5\" d=\"M13 10V3L4 14h7v7l9-11h-7z\" data-kid=\"34\"></path></svg>\n      </div>\n      <span class=\"text-2xl font-bold font-heading tracking-tight\" data-kid=\"35\">Interview<span class=\"text-[var(--primary)]\" data-kid=\"36\">AI</span></span>\n    </div>\n\n    <div class=\"w-full max-w-lg\" data-kid=\"37\">\n      <div class=\"mb-10\" data-kid=\"38\">\n        <h1 class=\"text-4xl lg:text-5xl font-bold font-heading text-[var(--text-primary)] mb-3\" data-kid=\"39\">Begin Journey</h1>\n        <p class=\"text-[var(--text-secondary)] text-lg\" data-kid=\"40\">Create your account to start simulating.</p>\n      </div>\n\n      \n      <div class=\"flex items-center justify-between mb-12 px-2\" data-kid=\"41\">\n        <div class=\"flex flex-col items-center gap-3 group\" data-kid=\"42\">\n          <div class=\"w-10 h-10 rounded-full bg-[var(--primary)] flex items-center justify-center ring-4 ring-[var(--primary)]/20 shadow-[0_0_15px_rgba(139,92,246,0.3)] transition-all\" data-kid=\"43\">\n            <svg xmlns=\"http://www.w3.org/2000/svg\" class=\"w-5 h-5 text-white\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\" data-kid=\"44\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z\" data-kid=\"45\"></path></svg>\n          </div>\n          <span class=\"text-[10px] font-bold uppercase tracking-widest text-[var(--primary)]\" data-kid=\"46\">Identity</span>\n        </div>\n        <div class=\"h-[2px] flex-1 mx-4 bg-white/10 relative -top-4\" data-kid=\"47\">\n          <div class=\"absolute inset-0 bg-gradient-to-r from-[var(--primary)] to-white/10 w-1/2\" data-kid=\"48\"></div>\n        </div>\n        <div class=\"flex flex-col items-center gap-3\" data-kid=\"49\">\n          <div class=\"w-10 h-10 rounded-full bg-white/5 border border-white/10 flex items-center justify-center text-[var(--text-secondary)]\" data-kid=\"50\">\n            <svg xmlns=\"http://www.w3.org/2000/svg\" class=\"w-5 h-5\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\" data-kid=\"51\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z\" data-kid=\"52\"></path></svg>\n          </div>\n          <span class=\"text-[10px] font-bold uppercase tracking-widest text-[var(--text-muted)]\" data-kid=\"53\">Focus</span>\n        </div>\n        <div class=\"h-[2px] flex-1 mx-4 bg-white/10 relative -top-4\" data-kid=\"54\"></div>\n        <div class=\"flex flex-col items-center gap-3\" data-kid=\"55\">\n          <div class=\"w-10 h-10 rounded-full bg-white/5 border border-white/10 flex items-center justify-center text-[var(--text-secondary)]\" data-kid=\"56\">\n            <svg xmlns=\"http://www.w3.org/2000/svg\" class=\"w-5 h-5\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\" data-kid=\"57\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M13 7h8m0 0v8m0-8l-8 8-4-4-6 6\" data-kid=\"58\"></path></svg>\n          </div>\n          <span class=\"text-[10px] font-bold uppercase tracking-widest text-[var(--text-muted)]\" data-kid=\"59\">Experience</span>\n        </div>\n      </div>\n\n      \n      <div class=\"glass p-8 lg:p-10 rounded-3xl space-y-8 shadow-2xl relative\" data-kid=\"60\">\n        \n        <div class=\"absolute -top-px left-20 right-20 h-px bg-gradient-to-r from-transparent via-white/20 to-transparent\" data-kid=\"61\"></div>\n        \n        <div class=\"space-y-6\" data-kid=\"62\">\n          <div class=\"space-y-2\" data-kid=\"63\">\n            <label class=\"text-sm font-semibold text-[var(--text-secondary)] px-1\" data-kid=\"64\">Full Name</label>\n            <div class=\"relative group\" data-kid=\"65\">\n              <input type=\"text\" placeholder=\"John Wick\" class=\"w-full px-5 py-4 rounded-2xl bg-white/5 border border-white/10 text-white placeholder-white/20 outline-none transition-all hover:border-white/20 focus:border-[var(--primary)] focus:ring-1 focus:ring-[var(--primary)] shadow-sm\" data-kid=\"66\">\n              <div class=\"absolute right-5 top-1/2 -translate-y-1/2 text-white/20 group-focus-within:text-[var(--primary)] transition-colors\" data-kid=\"67\">\n                <svg xmlns=\"http://www.w3.org/2000/svg\" class=\"w-5 h-5\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\" data-kid=\"68\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z\" data-kid=\"69\"></path></svg>\n              </div>\n            </div>\n          </div>\n\n          <div class=\"space-y-2\" data-kid=\"70\">\n            <label class=\"text-sm font-semibold text-[var(--text-secondary)] px-1\" data-kid=\"71\">Email Address</label>\n            <div class=\"relative group\" data-kid=\"72\">\n              <input type=\"email\" placeholder=\"john@example.com\" class=\"w-full px-5 py-4 rounded-2xl bg-white/5 border border-white/10 text-white placeholder-white/20 outline-no