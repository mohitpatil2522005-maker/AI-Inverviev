 bg-white/5\" data-kid=\"46\"></div>\n            </div>\n            <div class=\"bg-white/5 border border-white/5 p-4 rounded-xl\" data-kid=\"47\">\n              <p class=\"text-[var(--k-color-text-primary)] font-medium leading-relaxed italic opacity-90\" data-kid=\"48\">\n                \"We need to detect and report cyclic dependencies in the graph. How would you modify your DFS approach to efficiently handle this?\"\n              </p>\n            </div>\n          </div>\n\n          <div class=\"mt-auto pt-6 border-t border-white/5\" data-kid=\"49\">\n             <div class=\"flex items-center justify-between text-[10px] uppercase font-bold tracking-widest text-[var(--k-color-text-muted)]\" data-kid=\"50\">\n                <span data-kid=\"51\">AI confidence</span>\n                <span data-kid=\"52\">98.4%</span>\n             </div>\n             <div class=\"w-full h-1 bg-white/5 rounded-full mt-2 overflow-hidden\" data-kid=\"53\">\n                <div class=\"w-[98.4%] h-full bg-[var(--k-color-primary)] glow-border\" data-kid=\"54\"></div>\n             </div>\n          </div>\n        </div>\n      </div>\n    </aside>\n\n    \n    <section class=\"flex-1 flex flex-col glass-panel rounded-[var(--k-radius-xl)] overflow-hidden shadow-2xl relative\" data-kid=\"55\">\n      \n      <div class=\"h-14 shrink-0 border-b border-[var(--k-color-border)] flex items-center justify-between px-6 bg-white/2\" data-kid=\"56\">\n        <div class=\"flex items-center gap-1\" data-kid=\"57\">\n          <div class=\"flex gap-1 h-full\" data-kid=\"58\">\n            <button class=\"px-6 py-4 flex items-center gap-2 border-b-2 border-[var(--k-color-primary)] text-sm font-medium bg-[var(--k-color-primary)]/5\" data-kid=\"59\">\n              <i class=\"fa-brands fa-python text-[var(--k-color-primary)]\" data-kid=\"60\"></i>\n              main.py\n            </button>\n            <button class=\"px-6 py-4 flex items-center gap-2 text-sm font-medium text-[var(--k-c