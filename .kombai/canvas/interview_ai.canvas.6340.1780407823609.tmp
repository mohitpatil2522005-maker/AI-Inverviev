<div class=\"glass-card p-10 flex flex-col gap-8\" data-kid=\"43\">\n        <div class=\"w-16 h-16 rounded-2xl bg-white/5 border border-white/10 flex items-center justify-center text-[var(--k-color-primary)]\" data-kid=\"44\">\n          <i class=\"ti ti-target text-4xl\" data-kid=\"45\"></i>\n        </div>\n        <div class=\"space-y-4\" data-kid=\"46\">\n          <h3 class=\"text-2xl font-bold text-white font-heading\" data-kid=\"47\">AI Matching</h3>\n          <p class=\"text-[var(--k-color-text-secondary)] leading-relaxed\" data-kid=\"48\">Our neural network matches your persona with company cultures and tech stacks perfectly.</p>\n          <div class=\"pt-4 space-y-3\" data-kid=\"49\">\n            <div class=\"flex justify-between text-xs font-bold uppercase tracking-wider text-slate-400\" data-kid=\"50\">\n              <span data-kid=\"51\">Match Precision</span>\n              <span class=\"text-emerald-400\" data-kid=\"52\">98%</span>\n            </div>\n            <div class=\"h-2 w-full bg-white/5 rounded-full overflow-hidden\" data-kid=\"53\">\n              <div class=\"h-full bg-emerald-500 rounded-full progress-glow\" style=\"width: 98%\" data-kid=\"54\"></div>\n            </div>\n          </div>\n        </div>\n      </div>\n\n      \n      <div class=\"glass-card p-10 flex flex-col gap-8\" data-kid=\"55\">\n        <div class=\"w-16 h-16 rounded-2xl bg-white/5 border border-white/10 flex items-center justify-center text-indigo-400\" data-kid=\"56\">\n          <i class=\"ti ti-cpu text-4xl\" data-kid=\"57\"></i>\n        </div>\n        <div class=\"space-y-4\" data-kid=\"58\">\n          <h3 class=\"text-2xl font-bold text-white font-heading\" data-kid=\"59\">Real-time Analysis</h3>\n          <p class=\"text-[var(--k-color-text-secondary)] leading-relaxed\" data-kid=\"60\">Receive instant telemetry on your voice modulation, facial expressions, and keyword usage.</p>\n          <div class=\"pt-4 space-y-3\" data-kid=\"61\">\n          