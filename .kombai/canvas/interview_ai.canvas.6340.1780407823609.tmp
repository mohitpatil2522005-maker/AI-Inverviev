\"hover:bg-white/[0.01] transition-colors group\" data-kid=\"382\">\n                  <td class=\"px-8 py-6\" data-kid=\"383\">\n                    <div class=\"flex items-center gap-3\" data-kid=\"384\">\n                      <div class=\"w-10 h-10 rounded-xl bg-gradient-to-br from-slate-500/20 to-slate-400/20 border border-white/5 flex items-center justify-center font-bold text-slate-400\" data-kid=\"385\">RP</div>\n                      <div data-kid=\"386\">\n                        <p class=\"text-sm font-bold text-white group-hover:text-[#8b5cf6] transition-colors\" data-kid=\"387\">Raj Patel</p>\n                        <p class=\"text-[10px] text-slate-500\" data-kid=\"388\">raj.patel@amazon.com</p>\n                      </div>\n                    </div>\n                  </td>\n                  <td class=\"px-8 py-6\" data-kid=\"389\">\n                    <span class=\"px-2 py-1 rounded-md bg-white/5 text-slate-400 text-[10px] font-bold border border-white/10\" data-kid=\"390\">Free Tier</span>\n                  </td>\n                  <td class=\"px-8 py-6 text-xs text-slate-400\" data-kid=\"391\">2 hours ago</td>\n                  <td class=\"px-8 py-6\" data-kid=\"392\">\n                    <div class=\"flex items-center gap-2\" data-kid=\"393\">\n                      <div class=\"w-1.5 h-1.5 rounded-full bg-slate-600\" data-kid=\"394\"></div>\n                      <span class=\"text-[10px] font-bold text-slate-500 uppercase tracking-tighter\" data-kid=\"395\">Inactive</span>\n                    </div>\n                  </td>\n                  <td class=\"px-8 py-6 text-right\" data-kid=\"396\">\n                    <button class=\"text-slate-500 hover:text-white\" data-kid=\"397\"><i data-lucide=\"more-horizontal\" class=\"w-4 h-4\" data-kid=\"398\"></i></button>\n                  </td>\n                </tr>\n              </tbody>\n            </table>\n          </div>\n        </div>\n      </section>\n\n    </div>\n  </main>\n\n  