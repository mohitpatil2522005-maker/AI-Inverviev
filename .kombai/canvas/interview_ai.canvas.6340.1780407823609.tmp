      "html": "<div class=\"w-full bg-[#080812] text-slate-200 font-sans p-6 overflow-hidden selection:bg-primary/30 selection:text-white\" style=\"min-height: 950px; background-color: #080812;\" data-kid=\"0\">\n  \n  <style data-kid=\"1\">\n    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Space+Grotesk:wght@400;500;600;700&family=Fira+Code:wght@400;500&display=swap');\n\n    :root {\n      --primary: #8b5cf6;\n      --accent: #06b6d4;\n      --secondary: #3b82f6;\n    }\n\n    .font-heading { font-family: 'Space Grotesk', sans-serif; }\n    .font-mono { font-family: 'Fira Code', monospace; }\n\n    @keyframes waveform-anim {\n      0%, 100% { height: 4px; opacity: 0.5; }\n      50% { height: 28px; opacity: 1; }\n    }\n\n    @keyframes rotate-slow {\n      from { transform: rotate(0deg); }\n      to { transform: rotate(360deg); }\n    }\n\n    @keyframes pulse-custom {\n      0%, 100% { transform: scale(1); opacity: 0.3; }\n      50% { transform: scale(1.4); opacity: 0.1; }\n    }\n\n    .glass-panel {\n      background: rgba(17, 17, 40, 0.6);\n      backdrop-filter: blur(20px);\n      border: 1px solid rgba(255, 255, 255, 0.08);\n      box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.37);\n    }\n\n    .scrollbar-hide::-webkit-scrollbar {\n      display: none;\n    }\n    \n    .animate-waveform {\n      animation: waveform-anim 1s ease-in-out infinite;\n    }\n  </style>\n\n  \n  <div class=\"max-w-[1400px] mx-auto grid grid-cols-12 gap-6 h-[880px]\" data-kid=\"2\">\n    \n    \n    <aside class=\"col-span-3 flex flex-col gap-6 h-full\" data-kid=\"3\">\n      \n      <div class=\"flex-1 glass-panel rounded-3xl p-8 flex flex-col items-center justify-between relative overflow-hidden group\" data-kid=\"4\">\n        \n        <div class=\"absolute inset-0 bg-radial-[circle_at_center,_var(--color-primary)_0%,_transparent_70%] opacity-15 pointer-events-none\" data-kid=\"5\"></div>\n        \n        \n        <div class=\"re