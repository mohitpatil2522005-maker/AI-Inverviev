      "html": "<style data-kid=\"0\">\n  @import url(\"https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Space+Grotesk:wght@400;500;600;700&display=swap\");\n\n  :root {\n    --bg-base: #080812;\n    --bg-surface: #0d0d1f;\n    --bg-card: #111128;\n    --bg-card-hover: #16163a;\n    --border-subtle: rgba(255, 255, 255, 0.06);\n    --border-glow: rgba(139, 92, 246, 0.3);\n    --text-base: #f8fafc;\n    --text-muted: #94a3b8;\n    --text-faint: #475569;\n    --primary: #8b5cf6;\n    --primary-glow: rgba(139, 92, 246, 0.4);\n    --secondary: #3b82f6;\n    --accent: #06b6d4;\n    --success: #10b981;\n    --warning: #f59e0b;\n    --danger: #ef4444;\n  }\n\n  .font-heading {\n    font-family: \"Space Grotesk\", sans-serif;\n  }\n\n  .glass-card {\n    background: rgba(255, 255, 255, 0.02);\n    backdrop-filter: blur(24px);\n    -webkit-backdrop-filter: blur(24px);\n    border: 1px solid rgba(255, 255, 255, 0.06);\n    border-radius: 1.25rem;\n  }\n\n  .neon-button {\n    background: linear-gradient(135deg, #8b5cf6, #6d28d9);\n    border: 1px solid rgba(139, 92, 246, 0.5);\n    box-shadow: 0 8px 24px rgba(139, 92, 246, 0.25);\n    color: white;\n    font-weight: 600;\n    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);\n  }\n\n  .neon-button:hover {\n    box-shadow: 0 12px 32px rgba(139, 92, 246, 0.4);\n    transform: translateY(-2px);\n    filter: brightness(1.1);\n  }\n\n  .scrollbar-hidden::-webkit-scrollbar {\n    display: none;\n  }\n\n  .scrollbar-hidden {\n    -ms-overflow-style: none;\n    scrollbar-width: none;\n  }\n\n  @keyframes typing {\n    0%, 100% { opacity: 0.3; transform: scale(0.8); }\n    50% { opacity: 1; transform: scale(1.1); }\n  }\n\n  .typing-dot {\n    animation: typing 1.2s infinite ease-in-out;\n  }\n\n  @keyframes shimmer {\n    0% { transform: translateX(-100%); }\n    100% { transform: translateX(100%); }\n  }\n\n  .animate-shimmer {\n    animation: shimmer 2s infinite;\n  }\n\n  .message-user {\n    background: linear-gradient(135deg, rgba(139, 92, 246, 0.2), rgba(139, 92, 246, 0.05));\n    border: 1px solid rgba(139, 92, 246, 0.3);\n  }\n\n  .message-ai {\n    background: rgba(255, 255, 255, 0.03);\n    border: 1px solid rgba(255, 255, 255, 0.08);\n  }\n</style>\n\n<div class=\"w-full bg-[var(--bg-base)] text-[var(--text-base)] font-sans antialiased\" data-kid=\"1\">\n  <div class=\"w-full min-h-[850px] p-6 flex gap-6 box-border max-w-[1440px] mx-auto\" data-kid=\"2\">\n    \n    \n    <aside class=\"w-72 flex flex-col gap-5 shrink-0\" data-kid=\"3\">\n      <button class=\"neon-button w-full py-4 px-6 rounded-2xl flex items-center justify-center gap-3 cursor-pointer group\" data-kid=\"4\">\n        <i data-lucide=\"plus-circle\" class=\"w-5 h-5 group-hover:rotate-90 transition-transform duration-300\" data-kid=\"5\"></i>\n        <span class=\"font-heading tracking-tight\" data-kid=\"6\">New Session</span>\n      </button>\n\n      <div class=\"glass-card flex-1 flex flex-col overflow-hidden\" data-kid=\"7\">\n        <div class=\"p-5 border-b border-white/5\" data-kid=\"8\">\n          <h3 class=\"text-[10px] font-bold text-slate-500 uppercase tracking-[0.2em] flex items-center gap-2.5\" data-kid=\"9\">\n            <i data-lucide=\"history\" class=\"w-3.5 h-3.5\" data-kid=\"10\"></i> Recent Sessions\n          </h3>\n        </div>\n        <div class=\"flex-1 overflow-y-auto p-2 scrollbar-hidden\" data-kid=\"11\">\n          <div class=\"space-y-1\" data-kid=\"12\">\n            <button class=\"w-full text-left p-3 rounded-xl text-sm text-slate-400 hover:text-white hover:bg-white/8 hover:border-white/10 transition-all truncate border border-transparent flex items-center gap-3 group cursor-pointer\" data-kid=\"13\">\n              <i data-lucide=\"message-square\" class=\"w-4 h-4 text-slate-600 group-hover:text-[var(--primary)] transition-colors\" data-kid=\"14\"></i>\n              Google L4 Prep Strategy\n            </button>\n            <button class=\"w-full text-left p-3 rounded-xl text-sm text-slate-400 hover:text-white hover:bg-white/8 hover:border-white/10 transition-all truncate border border-transparent flex items-center gap-3 group cursor-pointer\" data-kid=\"15\">\n              <i data-lucide=\"message-square\" class=\"w-4 h-4 text-slate-600 group-hover:text-[var(--primary)] transition-colors\" data-kid=\"16\"></i>\n              Resume Review - SWE\n            </button>\n            <button class=\"w-full text-left p-3 rounded-xl text-sm text-slate-400 hover:text-white hover:bg-white/8 hover:border-white/10 transition-all truncate border border-transparent flex items-center gap-3 group cursor-pointer\" data-kid=\"17\">\n              <i data-lucide=\"message-square\" class=\"w-4 h-4 text-slate-600 group-hover:text-[var(--primary)] transition-colors\" data-kid=\"18\"></i>\n              Salary Negotiation Tips\n            </button>\n            <button class=\"w-full text-left p-3 rounded-xl text-sm text-slate-400 hover:text-white hover:bg-white/8 hover:border-white/10 transition-all truncate border border-transparent flex items-center gap-3 group cursor-pointer\" data-kid=\"19\">\n              <i data-lucide=\"message-square\" class=\"w-4 h-4 text-slate-600 group-hover:text-[var(--primary)] transition-colors\" data-kid=\"20\"></i>\n              System Design Basics\n            </button>\n          </div>\n        </div>\n        \n        <div class=\"p-5 bg-white/[0.02] border-t border-white/5\" data-kid=\"21\">\n          <h3 class=\"text-[10px] font-bold text-slate-500 uppercase tracking-[0.2em] flex items-center gap-2.5 mb-4\" data-kid=\"22\">\n            <i data-lucide=\"sparkles\" class=\"w-3.5 h-3.5 text-[var(--primary)]\" data-kid=\"23\"></i> Career Roadmap\n          </h3>\n          <div class=\"p-4 rounded-2xl border border-[var(--primary)]/10 bg-[var(--primary)]/5 relative overflow-hidden group\" data-kid=\"24\">\n            <div class=\"absolute inset-0 bg-gradient-to-br from-[var(--primary)]/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity\" data-kid=\"25\"></div>\n            <div class=\"relative z-10\" data-kid=\"26\">\n              <div class=\"flex justify-between items-end mb-2.5\" data-kid=\"27\">\n                <p class=\"text-[11px] font-semibold text-slate-200\" data-kid=\"28\">Staff Engineer</p>\n                <p class=\"text-[10px] text-[var(--primary)] font-bold\" data-kid=\"29\">65%</p>\n              </div>\n              <div class=\"h-2 w-full bg-white/5 rounded-full overflow-hidden border border-white/5\" data-kid=\"30\">\n                <div class=\"h-full bg-gradient-to-r from-[var(--primary)] to-[var(--accent)] w-[65%] rounded-full relative shadow-[0_0_12px_rgba(139,92,246,0.4)]\" data-kid=\"31\">\n                  <div class=\"absolute inset-0 bg-[linear-gradient(90deg,transparent_0%,rgba(255,255,255,0.3)_50%,transparent_100%)] w-20 animate-shimmer\" data-kid=\"32\"></div>\n                </div>\n              </div>\n            </div>\n          </div>\n        </div>\n      </div>\n    </aside>\n\n    \n    <main class=\"flex-1 flex flex-col glass-card overflow-hidden bg-white/[0.01]\" data-kid=\"33\">\n      \n      <header class=\"px-8 py-5 border-b border-white/10 flex items-center justify-between\" data-kid=\"34\">\n        <div class=\"flex items-center gap-4\" data-kid=\"35\">\n          <div class=\"relative\" data-kid=\"36\">\n            <div class=\"w-11 h-11 rounded-2xl bg-[var(--primary)]/15 border border-[var(--primary)]/30 flex items-center justify-center shadow-inner\" data-kid=\"37\">\n              <i data-lucide=\"bot\" class=\"w-6 h-6 text-[var(--primary)]\" data-kid=\"38\"></i>\n            </div>\n            <div class=\"absolute -bottom-0.5 -right-0.5 w-3.5 h-3.5 bg-green-500 rounded-full border-[3px] border-[#0a0a18] shadow-lg\" data-kid=\"39\"></div>\n          </div>\n          <div data-kid=\"40\">\n            <h2 class=\"font-heading text-lg font-bold tracking-tight\" data-kid=\"41\">Career Coach AI</h2>\n            <p class=\"text-slate-500 text-xs flex items-center gap-1.5 mt-0.5\" data-kid=\"42\">\n              <span class=\"w-1.5 h-1.5 rounded-full bg-green-500 animate-pulse\" data-kid=\"43\"></span>\n              Synchronized & Ready\n            </p>\n          </div>\n        </div>\n        <div class=\"flex items-center gap-3\" data-kid=\"44\">\n          <button class=\"w-10 h-10 rounded-xl flex items-center justify-center text-slate-400 hover:bg-white/5 hover:text-white transition-all border border-transparent hover:border-white/10\" data-kid=\"45\">\n            <i data-lucide=\"search\" class=\"w-5 h-5\" data-kid=\"46\"></i>\n          </button>\n          <button class=\"w-10 h-10 rounded-xl flex items-center justify-center text-slate-400 hover:bg-white/5 hover:text-white transition-all border border-transparent hover:border-white/10\" data-kid=\"47\">\n            <i data-lucide=\"settings-2\" class=\"w-5 h-5\" data-kid=\"48\"></i>\n          </button>\n        </div>\n      </header>\n\n      \n      <div class=\"flex-1 p-8 overflow-y-auto scrollbar-hidden space-y-12\" data-kid=\"49\">\n        \n        <div class=\"grid grid-cols-2 gap-4 max-w-3xl mx-auto\" data-kid=\"50\">\n          <button class=\"group p-5 rounded-2xl bg-white/[0.02] border border-white/5 hover:border-[var(--primary)]/40 hover:bg-white/[0.04] transition-all text-left relative overflow-hidden\" data-kid=\"51\">\n            <div class=\"absolute top-0 right-0 p-3 opacity-0 group-hover:opacity-100 transition-opacity\" data-kid=\"52\">\n              <i data-lucide=\"arrow-up-right\" class=\"w-4 h-4 text-[var(--primary)]\" data-kid=\"53\"></i>\n            </div>\n            <p class=\"text-slate-200 group-hover:text-white text-[13px] leading-relaxed pr-6 transition-colors\" data-kid=\"54\">How can I improve my system design skills for L6 roles?</p>\n          </button>\n          <button class=\"group p-5 rounded-2xl bg-white/[0.02] border border-white/5 hover:border-[var(--primary)]/40 hover:bg-white/[0.04] transition-all text-left relative overflow-hidden\" data-kid=\"55\">\n            <div class=\"absolute top-0 right-0 p-3 opacity-0 group-hover:opacity-100 transition-opacity\" data-kid=\"56\">\n              <i data-lucide=\"arrow-up-right\" class=\"w-4 h-4 text-[var(--primary)]\" data-kid=\"57\"></i>\n            </div>\n            <p class=\"text-slate-200 group-hover:text-white text-[13px] leading-relaxed pr-6 transition-colors\" data-kid=\"58\">What is the current salary range for Staff SWE in London?</p>\n          </button>\n        </div>\n\n        <div class=\"space-y-8\" data-kid=\"59\">\n          \n          <div class=\"flex gap-5 max-w-[85%]\" data-kid=\"60\">\n            <div class=\"w-10 h-10 rounded-xl bg-[var(--primary)]/15 border border-[var(--primary)]/30 flex items-center justify-center shrink-0 self-end mb-6\" data-kid=\"61\">\n              <i data-lucide=\"bot\" class=\"w-5 h-5 text-[var(--primary)]\" data-kid=\"62\"></i>\n            </div>\n            <div class=\"flex flex-col gap-2.5\" data-kid=\"63\">\n              <div class=\"p-6 rounded-3xl rounded-bl-none message-ai text-slate-200 text-sm leading-relaxed shadow-xl\" data-kid=\"64\">\n                Hello John! I've analyzed your current trajectory. Based on your 8 years of experience in backend systems, we should focus on <span class=\"text-[var(--primary)] font-semibold\" data-kid=\"65\">Distributed Systems</span> and <span class=\"text-[var(--primary)] font-semibold\" data-kid=\"66\">Leadership paradigms</span>. How would you like to start today?\n              </div>\n              <span class=\"text-slate-400 text-[10px] font-bold uppercase tracking-widest px-1\" data-kid=\"67\">14:22 PM</span>\n            </div>\n          </div>\n\n          \n          <div class=\"flex gap-5 max-w-[85%] ml-auto flex-row-reverse\" data-kid=\"68\">\n            <div class=\"w-10 h-10 rounded-xl bg-slate-800 border border-white/10 flex items-center justify-center shrink-0 self-end mb-6\" data-kid=\"69\">\n              <i data-lucide=\"user\" class=\"w-5 h-5 text-slate-400\" data-kid=\"70\"></i>\n            </div>\n            <div class=\"flex flex-col gap-2.5 items-end\" data-kid=\"71\">\n              <div class=\"p-6 rounded-3xl rounded-br-none message-user text-white text-sm leading-relaxed shadow-2xl backdrop-blur-md\" data-kid=\"72\">\n                I'd like to dive into the Staff Engineer roadmap. Can you give me a breakdown of the technical expectations for that level at Tier-1 companies?\n              </div>\n              <span class=\"text-slate-400 text-[10px] font-bold uppercase tracking-widest px-1\" data-kid=\"73\">14:24 PM</span>\n            </div>\n          </div>\n\n          \n          <div class=\"flex gap-5\" data-kid=\"74\">\n            <div class=\"w-10 h-10 rounded-xl bg-[var(--primary)]/15 border border-[var(--primary)]/30 flex items-center justify-center shrink-0\" data-kid=\"75\">\n              <i data-lucide=\"bot\" class=\"w-5 h-5 text-[var(--primary)]\" data-kid=\"76\"></i>\n            </div>\n            <div class=\"p-5 rounded-2xl rounded-bl-none bg-white/[0.03] border border-white/10 flex gap-2 items-center px-7\" data-kid=\"77\">\n              <div class=\"w-1.5 h-1.5 rounded-full bg-[var(--primary)] typing-dot\" style=\"animation-delay: 0s;\" data-kid=\"78\"></div>\n              <div class=\"w-1.5 h-1.5 rounded-full bg-[var(--primary)] typing-dot\" style=\"animation-delay: 0.2s;\" data-kid=\"79\"></div>\n              <div class=\"w-1.5 h-1.5 rounded-full bg-[var(--primary)] typing-dot\" style=\"animation-delay: 0.4s;\" data-kid=\"80\"></div>\n            </div>\n          </div>\n        </div>\n      </div>\n\n      \n      <footer class=\"p-8 border-t border-white/10 bg-[#0a0a18]/50 backdrop-blur-xl\" data-kid=\"81\">\n        <div class=\"max-w-3xl mx-auto relative group\" data-kid=\"82\">\n          <div class=\"absolute -inset-1 bg-gradient-to-r from-[var(--primary)]/20 to-blue-500/20 rounded-3xl blur opacity-0 group-focus-within:opacity-100 transition duration-500\" data-kid=\"83\"></div>\n          <div class=\"relative\" data-kid=\"84\">\n            <input type=\"text\" placeholder=\"Ask about roadmaps, salary, or interview prep...\" class=\"w-full h-16 pl-7 pr-20 bg-white/5 border border-white/10 rounded-2xl text-white placeholder-slate-500 focus:outline-none focus:border-[var(--primary)]/50 focus:ring-0 transition-all text-sm font-medium\" data-kid=\"85\">\n            <div class=\"absolute right-3 top-1/2 -translate-y-1/2 flex items-center gap-2\" data-kid=\"86\">\n              <button class=\"w-10 h-10 rounded-xl flex items-center justify-center text-slate-400 hover:text-white transition-colors\" data-kid=\"87\">\n                <i data-lucide=\"paperclip\" class=\"w-5 h-5\" data-kid=\"88\"></i>\n              </button>\n              <button class=\"w-10 h-10 rounded-xl neon-button flex items-center justify-center cursor-pointer\" data-kid=\"89\">\n                <i data-lucide=\"send\" class=\"w-5 h-5\" data-kid=\"90\"></i>\n              </button>\n            </div>\n          </div>\n        </div>\n        <p class=\"text-[10px] text-slate-600 text-center mt-4 font-bold uppercase tracking-[0.2em]\" data-kid=\"91\">\n          AI-Powered Insights • Career Coach v4.2\n        </p>\n      </footer>\n    </main>\n\n    \n    <aside class=\"w-72 flex flex-col gap-6 shrink-0\" data-kid=\"92\">\n      <div class=\"glass-card p-6 border-white/10 bg-white/[0.02]\" data-kid=\"93\">\n        <h3 class=\"text-[10px] font-bold text-white uppercase tracking-[0.2em] flex items-center gap-2.5 mb-8\" data-kid=\"94\">\n          <i data-lucide=\"brain\" class=\"w-4 h-4 text-[var(--primary)]\" data-kid=\"95\"></i> Smart Insights\n        </h3>\n        <div class=\"space-y-7\" data-kid=\"96\">\n          <div class=\"flex items-center gap-4 group cursor-help\" data-kid=\"97\">\n            <div class=\"w-11 h-11 rounded-2xl bg-[var(--primary)]/10 border border-[var(--primary)]/20 flex items-center justify-center group-hover:bg-[var(--primary)]/20 transition-colors\" data-kid=\"98\">\n              <i data-lucide=\"target\" class=\"w-5 h-5 text-[var(--primary)]\" data-kid=\"99\"></i>\n            </div>\n            <div data-kid=\"100\">\n              <p class=\"text-[9px] font-bold text-slate-500 uppercase tracking-wider\" data-kid=\"101\">Goal</p>\n              <p class=\"text-[13px] font-bold text-white group-hover:text-[var(--primary)] transition-colors\" data-kid=\"102\">Staff SWE @ Google</p>\n            </div>\n          </div>\n          <div class=\"flex items-center gap-4 group cursor-help\" data-kid=\"103\">\n            <div class=\"w-11 h-11 rounded-2xl bg-blue-500/10 border border-blue-500/20 flex items-center justify-center group-hover:bg-blue-500/20 transition-colors\" data-kid=\"104\">\n              <i data-lucide=\"zap\" class=\"w-5 h-5 text-blue-500\" data-kid=\"105\"></i>\n            </div>\n            <div data-kid=\"106\">\n              <p class=\"text-[9px] font-bold text-slate-500 uppercase tracking-wider\" data-kid=\"107\">Priority Focus</p>\n              <p class=\"text-[13px] font-bold text-white group-hover:text-blue-500 transition-colors\" data-kid=\"108\">System Design</p>\n            </div>\n          </div>\n          <div class=\"flex items-center gap-4 group cursor-help\" data-kid=\"109\">\n            <div class=\"w-11 h-11 rounded-2xl bg-emerald-500/10 border border-emerald-500/20 flex items-center justify-center group-hover:bg-emerald-500/20 transition-colors\" data-kid=\"110\">\n              <i data-lucide=\"trending-up\" class=\"w-5 h-5 text-emerald-500\" data-kid=\"111\"></i>\n            </div>\n            <div data-kid=\"112\">\n              <p class=\"text-[9px] font-bold text-slate-500 uppercase tracking-wider\" data-kid=\"113\">Market Value</p>\n              <p class=\"text-[13px] font-bold text-white group-hover:text-emerald-500 transition-colors\" data-kid=\"114\">$240k - $290k</p>\n            </div>\n          </div>\n        </div>\n      </div>\n\n      <div class=\"glass-card p-6 flex-1 flex flex-col overflow-hidden bg-white/[0.02]\" data-kid=\"115\">\n        <h3 class=\"text-[10px] font-bold text-white uppercase tracking-[0.2em] flex items-center gap-2.5 mb-8\" data-kid=\"116\">\n          <i data-lucide=\"list-checks\" class=\"w-4 h-4 text-yellow-400\" data-kid=\"117\"></i> Action Items\n        </h3>\n        <div class=\"flex-1 overflow-y-auto space-y-3.5 scrollbar-hidden\" data-kid=\"118\">\n          <div class=\"group flex items-start gap-4 p-4 rounded-2xl bg-white/[0.02] border border-white/5 hover:border-[var(--primary)]/30 hover:bg-white/[0.05] transition-all cursor-pointer\" data-kid=\"119\">\n            <div class=\"mt-0.5 w-5 h-5 rounded-lg border border-white/10 flex items-center justify-center group-hover:border-[var(--primary)]/50 transition-colors shrink-0\" data-kid=\"120\">\n              <div class=\"w-2.5 h-2.5 rounded-sm bg-[var(--primary)] opacity-0 group-hover:opacity-100 transition-all scale-75 group-hover:scale-100\" data-kid=\"121\"></div>\n            </div>\n            <p class=\"text-[12px] text-slate-200 group-hover:text-white leading-tight transition-colors\" data-kid=\"122\">Complete \"System Design Interview\" Course</p>\n          </div>\n          <div class=\"group flex items-start gap-4 p-4 rounded-2xl bg-white/[0.02] border border-white/5 hover:border-[var(--primary)]/30 hover:bg-white/[0.05] transition-all cursor-pointer\" data-kid=\"123\">\n            <div class=\"mt-0.5 w-5 h-5 rounded-lg border border-white/10 flex items-center justify-center group-hover:border-[var(--primary)]/50 transition-colors shrink-0\" data-kid=\"124\">\n              <div class=\"w-2.5 h-2.5 rounded-sm bg-[var(--primary)] opacity-0 group-hover:opacity-100 transition-all scale-75 group-hover:scale-100\" data-kid=\"125\"></div>\n            </div>\n            <p class=\"text-[12px] text-slate-200 group-hover:text-white leading-tight transition-colors\" data-kid=\"126\">Optimize LinkedIn Technical Keywords</p>\n          </div>\n          <div class=\"group flex items-start gap-4 p-4 rounded-2xl bg-white/[0.02] border border-white/5 hover:border-[var(--primary)]/30 hover:bg-white/[0.05] transition-all cursor-pointer\" data-kid=\"127\">\n            <div class=\"mt-0.5 w-5 h-5 rounded-lg border border-white/10 flex items-center justify-center group-hover:border-[var(--primary)]/50 transition-colors shrink-0\" data-kid=\"128\">\n              <div class=\"w-2.5 h-2.5 rounded-sm bg-[var(--primary)] opacity-0 group-hover:opacity-100 transition-all scale-75 group-hover:scale-100\" data-kid=\"129\"></div>\n            </div>\n            <p class=\"text-[12px] text-slate-200 group-hover:text-white leading-tight transition-colors\" data-kid=\"130\">Prepare STAR stories for Staff level leadership</p>\n          </div>\n        </div>\n        <button class=\"mt-6 w-full py-3 rounded-xl border border-white/10 bg-white/[0.02] text-[10px] font-bold uppercase tracking-widest text-slate-400 hover:text-white hover:bg-white/5 hover:border-white/20 transition-all cursor-pointer\" data-kid=\"131\">\n          View All Tasks\n        </button>\n      </div>\n    </aside>\n\n  </div>\n</div>\n\n<script src=\"https://unpkg.com/lucide@latest\" data-kid=\"132\"></script>\n<script data-kid=\"133\">\n  window.addEventListener('load', () => {\n    if (typeof lucide !== 'undefined') {\n      lucide.createIcons();\n    }\n  });\n</script>\n",
