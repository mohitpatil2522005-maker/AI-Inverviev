iv>\n          <div class=\"flex flex-wrap gap-2\" data-kid=\"140\">\n            <span class=\"px-4 py-1.5 rounded-full bg-[var(--k-color-error)]/5 border border-[var(--k-color-error)]/20 text-sm font-medium hover:border-[var(--k-color-error)]/40 transition-all cursor-default text-[var(--k-color-error)]\" data-kid=\"141\">SaaS Design</span>\n            <span class=\"px-4 py-1.5 rounded-full bg-[var(--k-color-error)]/5 border border-[var(--k-color-error)]/20 text-sm font-medium hover:border-[var(--k-color-error)]/40 transition-all cursor-default text-[var(--k-color-error)]\" data-kid=\"142\">React.js</span>\n            <span class=\"px-4 py-1.5 rounded-full bg-[var(--k-color-error)]/5 border border-[var(--k-color-error)]/20 text-sm font-medium hover:border-[var(--k-color-error)]/40 transition-all cursor-default text-[var(--k-color-error)]\" data-kid=\"143\">Data Visualization</span>\n            <span class=\"px-4 py-1.5 rounded-full bg-[var(--k-color-error)]/5 border border-[var(--k-color-error)]/20 text-sm font-medium hover:border-[var(--k-color-error)]/40 transition-all cursor-default text-[var(--k-color-error)]\" data-kid=\"144\">Agile Workflow</span>\n            <span class=\"px-4 py-1.5 rounded-full bg-[var(--k-color-error)]/5 border border-[var(--k-color-error)]/20 text-sm font-medium hover:border-[var(--k-color-error)]/40 transition-all cursor-default text-[var(--k-color-error)]\" data-kid=\"145\">Stakeholder Management</span>\n          </div>\n        </div>\n        \n        <div class=\"h-px bg-[var(--k-color-border)]\" data-kid=\"146\"></div>\n\n        <div class=\"grid grid-cols-1 md:grid-cols-2 gap-8\" data-kid=\"147\">\n          <div class=\"space-y-4\" data-kid=\"148\">\n            <div class=\"flex items-center gap-2\" data-kid=\"149\">\n              <span class=\"text-xs font-bold text-[var(--k-color-text-muted)] uppercase tracking-widest\" data-kid=\"150\">Key Strength</span>\n            </div>\n            <div class=\"p-4 rounded-xl bg