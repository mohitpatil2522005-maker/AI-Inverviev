      "html": "\n<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Inter:wght@400;500;600;700&family=Fira+Code:wght@400;500&display=swap');\n\n  :root {\n    --bg-grid-opacity: 0.03;\n    --primary-glow: rgba(139, 92, 246, 0.4);\n  }\n\n  body {\n    margin: 0;\n    padding: 0;\n    background-color: var(--k-color-bg-page);\n    color: var(--k-color-text-primary);\n    font-family: var(--k-font-family-body);\n    overflow: hidden;\n  }\n\n  .dotted-bg {\n    background-image: \n      radial-gradient(circle at 50% 0%, rgba(139, 92, 246, 0.15) 0%, transparent 50%),\n      radial-gradient(circle at 1px 1px, rgba(255, 255, 255, 0.05) 1px, transparent 0);\n    background-size: 100% 100%, 32px 32px;\n  }\n\n  .glass-panel {\n    background: rgba(255, 255, 255, 0.02);\n    backdrop-filter: blur(20px);\n    border: 1px solid var(--k-color-border);\n    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);\n  }\n\n  .glass-panel:hover {\n    border-color: var(--k-color-border-hover);\n    box-shadow: 0 0 40px rgba(139, 92, 246, 0.1);\n    background: rgba(255, 255, 255, 0.03);\n  }\n\n  .glow-text {\n    text-shadow: 0 0 10px var(--primary-glow);\n  }\n\n  .glow-border {\n    box-shadow: 0 0 15px var(--primary-glow);\n  }\n\n  @keyframes scanline {\n    0% { transform: translateY(-100%); }\n    100% { transform: translateY(100%); }\n  }\n\n  @keyframes wave {\n    0%, 100% { transform: scaleY(0.3); }\n    50% { transform: scaleY(1); }\n  }\n\n  .custom-scrollbar::-webkit-scrollbar {\n    width: 6px;\n    height: 6px;\n  }\n  .custom-scrollbar::-webkit-scrollbar-track {\n    background: transparent;\n  }\n  .custom-scrollbar::-webkit-scrollbar-thumb {\n    background: rgba(255, 255, 255, 0.1);\n    border-radius: 10px;\n  }\n  .custom-scrollbar::-webkit-scrollbar-thumb:hover {\n    background: rgba(255, 255, 255, 0.2);\n  }\n\n  .code-token-keyword { color: #d55fde; } /* Brighter Purple */\n  .code-token-function { color: #4fc1ff; } /* Brighter Blue */\n  .code-token-string { color: #a5d6ff; } /* Lighter Cyan */\n  .code-token-comment { color: #8b949e; font-style: italic; } /* Lighter Gray */\n  .code-token-number { color: #ffab70; } /* Brighter Orange */\n\n  .editor-line:hover {\n    background: rgba(139, 92, 246, 0.05);\n  }\n</style>\n\n<div class=\"w-full h-[900px] flex flex-col dotted-bg relative overflow-hidden\" data-kid=\"1\">\n  \n  \n  <header class=\"h-20 shrink-0 border-b border-[var(--k-color-border)] px-8 flex items-center justify-between z-20\" data-kid=\"2\">\n    <div class=\"flex items-center gap-6\" data-kid=\"3\">\n      <div class=\"flex items-center gap-3\" data-kid=\"4\">\n        <div class=\"w-10 h-10 bg-[var(--k-color-primary)] rounded-xl flex items-center justify-center glow-border\" data-kid=\"5\">\n          <i class=\"fa-solid fa-brain text-white text-xl\" data-kid=\"6\"></i>\n        </div>\n        <div data-kid=\"7\">\n          <h1 class=\"font-[var(--k-font-family-heading)] text-xl font-bold tracking-tight\" data-kid=\"8\">\n            Interview <span class=\"text-[var(--k-color-primary)]\" data-kid=\"9\">Session</span>\n          </h1>\n          <div class=\"flex items-center gap-2\" data-kid=\"10\">\n             <div class=\"w-2 h-2 rounded-full bg-[var(--k-color-success)] animate-pulse\" data-kid=\"11\"></div>\n             <span class=\"text-[10px] uppercase tracking-widest text-[var(--k-color-text-muted)] font-bold\" data-kid=\"12\">AI Node: Active</span>\n          </div>\n        </div>\n      </div>\n    </div>\n\n    <div class=\"flex items-center gap-8\" data-kid=\"13\">\n      <div class=\"flex flex-col items-end\" data-kid=\"14\">\n        <span class=\"text-[10px] uppercase tracking-widest text-[var(--k-color-text-muted)] font-bold\" data-kid=\"15\">Time Remaining</span>\n        <span class=\"font-[var(--k-font-family-heading)] text-2xl font-bold glow-text\" data-kid=\"16\">42:15</span>\n      </div>\n      <div class=\"h-8 w-px bg-[var(--k-color-border)]\" data-kid=\"17\"></div>\n      <div class=\"flex items-center gap-3\" data-kid=\"18\">\n        <div class=\"text-right\" data-kid=\"19\">\n          <p class=\"text-sm font-medium\" data-kid=\"20\">Candidate #2048</p>\n          <p class=\"text-[10px] text-[var(--k-color-text-muted)]\" data-kid=\"21\">Senior Systems Architect</p>\n        </div>\n        <img src=\"https://i.pravatar.cc/40?u=candidate2048\" class=\"w-10 h-10 rounded-full border border-[var(--k-color-border)]\" alt=\"Avatar\" data-kid=\"22\">\n      </div>\n    </div>\n  </header>\n\n  \n  <main class=\"flex-1 flex gap-6 p-6 pb-24 overflow-hidden\" data-kid=\"23\">\n    \n    \n    <aside class=\"w-[380px] flex flex-col gap-6\" data-kid=\"24\">\n      <div class=\"flex-1 glass-panel rounded-[var(--k-radius-xl)] overflow-hidden flex flex-col shadow-2xl\" data-kid=\"25\">\n        \n        <div class=\"h-[320px] relative bg-black shrink-0\" data-kid=\"26\">\n          <div class=\"absolute top-4 left-4 z-10 flex items-center gap-2 px-3 py-1 bg-black/40 backdrop-blur-md rounded-full border border-red-500/30\" data-kid=\"27\">\n            <div class=\"w-2 h-2 bg-[var(--k-color-error)] rounded-full animate-pulse shadow-[0_0_8px_var(--k-color-error)]\" data-kid=\"28\"></div>\n            <span class=\"text-[10px] font-bold text-[var(--k-color-error)] tracking-widest uppercase\" data-kid=\"29\">Recording</span>\n          </div>\n          <video src=\"https://videos.pexels.com/video-files/34908994/14788400_360_640_30fps.mp4\" poster=\"https://images.pexels.com/videos/34908994/pexels-photo-34908994.jpeg?auto=compress&cs=tinysrgb&fit=crop&h=1200&w=630\" autoplay muted loop playsinline class=\"w-full h-full object-cover\" data-kid=\"30\"></video>\n          <div class=\"absolute inset-0 bg-gradient-to-t from-[#0a0a18] via-transparent to-transparent\" data-kid=\"31\"></div>\n          \n          <div class=\"absolute inset-0 pointer-events-none opacity-20\" data-kid