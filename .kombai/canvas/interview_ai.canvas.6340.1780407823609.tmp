      "html": "\n<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Inter:wght@400;500;600;700&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n  :root {\n    --glass-bg: rgba(255, 255, 255, 0.03);\n    --glass-border: rgba(255, 255, 255, 0.08);\n    --neon-purple: #8b5cf6;\n    --neon-cyan: #67e8f9;\n  }\n\n  body {\n    margin: 0;\n    padding: 0;\n    background-color: var(--k-color-bg-page);\n    color: var(--k-color-text-primary);\n    font-family: var(--k-font-family-body);\n  }\n\n  .font-heading {\n    font-family: var(--k-font-family-heading);\n  }\n\n  .glass-card {\n    background: var(--glass-bg);\n    backdrop-filter: blur(16px);\n    border: 1px solid var(--glass-border);\n    transition: all 0.3s ease;\n  }\n\n  .glass-card:hover {\n    border-color: var(--k-color-border-hover);\n    background: rgba(255, 255, 255, 0.05);\n  }\n\n  .gradient-text {\n    background: linear-gradient(135deg, #c084fc, #818cf8, #67e8f9);\n    -webkit-background-clip: text;\n    -webkit-text-fill-color: transparent;\n  }\n\n  .scan-line {\n    position: absolute;\n    width: 100%;\n    height: 2px;\n    background: linear-gradient(90deg, transparent, var(--neon-purple), transparent);\n    animation: scan 3s linear infinite;\n    z-index: 10;\n  }\n\n  @keyframes scan {\n    0% { top: 0; opacity: 0; }\n    10% { opacity: 1; }\n    90% { opacity: 1; }\n    100% { top: 100%; opacity: 0; }\n  }\n\n  .sidebar-collapsed {\n    width: 80px;\n  }\n\n  .sidebar-expanded {\n    width: 280px;\n  }\n\n  /* Custom scrollbar */\n  ::-webkit-scrollbar {\n    width: 6px;\n  }\n  ::-webkit-scrollbar-track {\n    background: transparent;\n  }\n  ::-webkit-scrollbar-thumb {\n    background: rgba(255, 255, 255, 0.1);\n    border-radius: 10px;\n  }\n  ::-webkit-scrollbar-thumb:hover {\n    background: rgba(255, 255, 255, 0.2);\n  }\n</style>\n\n<div class=\"flex min-h-screen bg-[var(--k-color-bg-page)] selection:bg-purple-500/30\" data-kid=\"1\">\n  \n  <input type=\"checkbox\" id=\"sidebar-toggle\" class=\"hidden peer\" checked data-kid=\"2\">\n  \n  \n  <aside class=\"fixed inset-y-0 left-0 z-50 flex flex-col glass-card border-y-0 border-l-0 transition-all duration-300 ease-in-out w-64 peer-checked:w-20 overflow-hidden group\" data-kid=\"3\">\n    \n    <div class=\"p-6 flex items-center gap-4 h-24 shrink-0\" data-kid=\"4\">\n      <div class=\"w-10 h-10 rounded-xl bg-gradient-to-br from-purple-500 to-indigo-600 flex items-center justify-center shadow-[0_0_20px_rgba(139,92,246,0.4)] shrink-0\" data-kid=\"5\">\n        <i class=\"ti ti-brain text-white text-xl\" data-kid=\"6\"></i>\n      </div>\n      <span class=\"text-xl font-bold font-heading tracking-tight whitespace-nowrap peer-checked:group-[]:opacity-0 transition-opacity duration-300\" data-kid=\"7\">AI.INTERVIEW</span>\n    </div>\n\n    \n    <nav class=\"flex-1 px-4 space-y-2 py-4\" data-kid=\"8\">\n      <a href=\"#\" class=\"flex items-center gap-4 px-3 py-3 rounded-xl bg-purple-500/10 text-[var(--k-color-primary)] border border-purple-500/20 transition-all\" data-kid=\"9\">\n        <i class=\"ti ti-layout-grid text-xl shrink-0\" data-kid=\"10\"></i>\n        <span class=\"font-medium whitespace-nowrap peer-checked:group-[]:hidden\" data-kid=\"11\">Dashboard</span>\n      </a>\n      <a href=\"#\" class=\"flex items-center gap-4 px-3 py-3 rounded-xl text-slate-400 hover:bg-white/5 hover:text-white transition-all group/nav\" data-kid=\"12\">\n        <i class=\"ti ti-history text-xl shrink-0\" data-kid=\"13\"></i>\n        <span class=\"font-medium whitespace-nowrap peer-checked:group-[]:hidden\" data-kid=\"14\">Past Sessions</span>\n      </a>\n      <a href=\"#\" class=\"flex items-center gap-4 px-3 py-3 rounded-xl text-slate-400 hover:bg-white/5 hover:text-white transition-all group/nav\" data-kid=\"15\">\n        <i class=\"ti ti-code text-xl shrink-0\" data-kid=\"16\"></i>\n        <span class=\"font-medium whitespace-nowrap peer-checked:group-[]:hidden\" data-kid=\"17\">Coding Playground</span>\n      </a>\n      <a href=\"#\" class=\"flex items-center gap-4 px-3 py-3 rounded-xl text-slate-400 hover:bg-white/5 hover:text-white transition-all group/nav\" data-kid=\"18\">\n        <i class=\"ti ti-database text-xl shrink-0\" data-kid=\"19\"></i>\n        <span class=\"font-medium whitespace-nowrap peer-checked:group-[]:hidden\" data-kid=\"20\">Skill Bank</span>\n      </a>\n      <a href=\"#\" class=\"flex items-center gap-4 px-3 py-3 rounded-xl text-slate-400 hover:bg-white/5 hover:text-white transition-all group/nav\" data-kid=\"21\">\n        <i class=\"ti ti-settings text-xl shrink-0\" data-kid=\"22\"></i>\n        <span class=\"font-medium whitespace-nowrap peer-checked:group-[]:hidden\" data-kid=\"23\">Settings</span>\n      </a>\n    </nav>\n\n    \n    <div class=\"p-4 border-t border-white/10\" data-kid=\"24\">\n      <label for=\"sidebar-toggle\" class=\"flex items-center gap-4 px-3 py-3 rounded-xl text-slate-400 hover:bg-white/5 hover:text-white cursor-pointer transition-all\" data-kid=\"25\">\n        <i class=\"ti ti-chevron-left text-xl shrink-0 peer-checked:group-[]:rotate-180 transition-transform\" data-kid=\"26\"></i>\n        <span class=\"font-medium whitespace-nowrap peer-checked:group-[]:hidden\" data-kid=\"27\">Collapse Sidebar</span>\n      </label>\n      \n      <div class=\"mt-4 flex items-center gap-3 px-1\" data-kid=\"28\">\n        <img src=\"https://i.pravatar.cc/100?u=user123\" class=\"w-10 h-10 rounded-full border-2 border-purple-500/30 shrink-0\" alt=\"Avatar\" decoding=\"async\" loading=\"lazy\" data-kid=\"29\">\n        <div class=\"flex-1 overflow-hidden peer-checked:group-[]:hidden\" data-kid=\"30\">\n          <p class=\"text-sm font-semibold truncate\" data-kid=\"31\">Alex Rivera</p>\n          <p class=\"text-xs text-slate-500 truncate\" data-kid=\"32\">Pro Member</p>\n        </div>\n      </div>\n    </div>\n  </aside>\n\n  \n  <main class=\"flex-1 transition-all duration-300 ml-64 peer-checked:ml-20 p-8 min-h-screen\" data-kid=\"33\">\n    \n    <header class=\"flex flex-col md:flex-row md:items-center justify-between gap-6 mb-12\" data-kid=\"34\">\n      <div data-kid=\"35\">\n        <h1 class=\"text-4xl font-bold font-heading text-white mb-2\" data-kid=\"36\">\n          Agent <span class=\"gradient-text\" data-kid=\"37\">Overview</span>\n        </h1>\n        <p class=\"text-slate-400 max-w-md\" data-kid=\"38\">Your AI-driven career trajectory and interview performance metrics.</p>\n      </div>\n      <div class=\"flex items-center gap-4\" data-kid=\"39\">\n        <button class=\"px-5 py-2.5 rounded-xl border border-white/10 hover:bg-white/5 text-slate-300 transition-all font-medium\" data-kid=\"40\">\n          Download Report\n        </button>\n        <button class=\"px-6 py-2.5 rounded-xl bg-purple-600 hover:bg-purple-700 text-white font-bold transition-all shadow-lg shadow-purple-500/30 flex items-center gap-2 group/btn\" data-kid=\"41\">\n          <span data-kid=\"42\">New Scan</span>\n          <i class=\"ti ti-sparkles group-hover/btn:rotate-12 transition-transform\" data-kid=\"43\"></i>\n        </button>\n      </div>\n    </header>\n\n    \n    <div class=\"grid grid-cols-12 gap-6\" data-kid=\"44\">\n      \n      \n      <div class=\"col-span-12 lg:col-span-4 glass-card rounded-3xl p-8 flex flex-col items-center justify-center relative overflow-hidden group\" data-kid=\"45\">\n        <div class=\"absolute -top-10 -right-10 w-32 h-32 bg-purple-500/10 blur-3xl\" data-kid=\"46\"></div>\n        <div class=\"relative w-48 h-48 mb-6\" data-kid=\"47\">\n          <svg class=\"w-full h-full transform -rotate-90\" viewBox=\"0 0 100 100\" data-kid=\"48\">\n            <circle cx=\"50\" cy=\"50\" r=\"42\" stroke=\"currentColor\" stroke-width=\"8\" fill=\"transparent\" class=\"text-white/5\" data-kid=\"49\"></circle>\n            <circle cx=\"50\" cy=\"50\" r=\"42\" stroke=\"var(--k-color-primary)\" stroke-width=\"8\" fill=\"transparent\" stroke-dasharray=\"263.8\" stroke-dashoffset=\"39.5\" stroke-linecap=\"round\" class=\"drop-shadow-[0_0_12px_var(--k-color-primary)] transition-all duration-1000\" data-kid=\"50\"></circle>\n          </svg>\n          <div class=\"absolute inset-0 flex flex-col items-center justify-center\" data-kid=\"51\">\n            <span class=\"text-5xl font-bold font-heading text-white\" data-kid=\"52\">85</span>\n            <span class=\"text-xs text-slate-500 uppercase tracking-widest font-bold\" data-kid=\"53\">Score</span>\n          </div>\n        </div>\n        <h3 class=\"text-xl font-bold font-heading text-white mb-1\" data-kid=\"54\">Interview Score</h3>\n        <p class=\"text-slate-400 text-sm mb-4\" data-kid=\"55\">Based on last 5 simulations</p>\n        <div class=\"flex gap-2\" data-kid=\"56\">\n          <span class=\"px-3 py-1 rounded-full bg-emerald-500/10 text-emerald-400 text-[10px] border border-emerald-500/20 font-bold uppercase tracking-wider\" data-kid=\"57\">Advanced</span>\n          <span class=\"px-3 py-1 rounded-full bg-purple-500/10 text-purple-400 text-[10px] border border-purple-500/20 font-bold uppercase tracking-wider\" data-kid=\"58\">+12% vs last week</span>\n        </div>\n      </div>\n\n      <div class=\"col-span-12 lg:col-span-4 glass-card rounded-3xl p-8 flex flex-col items-center justify-center\" data-kid=\"59\">\n        <div class=\"relative w-40 h-40 mb-6\" data-kid=\"60\">\n          <svg class=\"w-full h-full transform -rotate-90\" viewBox=\"0 0 100 100\" data-kid=\"61\">\n            <circle cx=\"50\" cy=\"50\" r=\"42\" stroke=\"currentColor\" stroke-width=\"6\" fill=\"transparent\" class=\"text-white/5\" data-kid=\"62\"></circle>\n            <circle cx=\"50\" cy=\"50\" r=\"42\" stroke=\"var(--k-color-accent)\" stroke-width=\"6\" fill=\"transparent\" stroke-dasharray=\"263.8\" stroke-dashoffset=\"197.85\" stroke-linecap=\"round\" class=\"drop-shadow-[0_0_8px_var(--k-color-accent)] transition-all duration-1000\" data-kid=\"63\"></circle>\n          </svg>\n          <div class=\"absolute inset-0 flex flex-col items-center justify-center\" data-kid=\"64\">\n            <span class=\"text-3xl font-bold font-heading text-white\" data-kid=\"65\">25</span>\n            <span class=\"text-[10px] text-slate-500 uppercase tracking-tighter\" data-kid=\"66\">Credits</span>\n          </div>\n        </div>\n        <h3 class=\"text-lg font-bold font-heading text-white mb-1\" data-kid=\"67\">Credits Remaining</h3>\n        <p class=\"text-slate-400 text-sm mb-4\" data-kid=\"68\">Plan: Professional Tier</p>\n        <button class=\"text-xs text-[var(--k-color-accent)] hover:underline font-bold uppercase tracking-widest\" data-kid=\"69\">Top up credits</button>\n      </div>\n\n      <div class=\"col-span-12 lg:col-span-4 glass-card rounded-3xl p-8 flex flex-col items-center justify-center\" data-kid=\"70\">\n        <div class=\"relative w-40 h-40 mb-6\" data-kid=\"71\">\n          <svg class=\"w-full h-full transform -rotate-90\" viewBox=\"0 0 100 100\" data-kid=\"72\">\n            <circle cx=\"50\" cy=\"50\" r=\"42\" stroke=\"currentColor\" stroke-width=\"6\" fill=\"transparent\" class=\"text-white/5\" data-kid=\"73\"></circle>\n            <circle cx=\"50\" cy=\"50\" r=\"42\" stroke=\"var(--k-color-secondary)\" stroke-width=\"6\" fill=\"transparent\" stroke-dasharray=\"263.8\" stroke-dashoffset=\"105.5\" stroke-linecap=\"round\" class=\"drop-shadow-[0_0_8px_var(--k-color-secondary)] transition-all duration-1000\" data-kid=\"74\"></circle>\n          </svg>\n          <div class=\"absolute inset-0 flex flex-col items-center justify-center\" data-kid=\"75\">\n            <span class=\"text-3xl font-bold font-heading text-white\" data-kid=\"76\">60%</span>\n          </div>\n        </div>\n        <h3 class=\"text-lg font-bold font-heading text-white mb-1\" data-kid=\"77\">Weekly Progress</h3>\n        <p class=\"text-slate-400 text-sm mb-4\" data-kid=\"78\">3/5 Goals completed</p>\n        <div class=\"w-full bg-white/5 h-1.5 rounded-full overflow-hidden\" data-kid=\"79\">\n          <div class=\"h-full bg-indigo-500 w-[60%] rounded-full shadow-[0_0_10px_rgba(99,102,241,0.5)]\" data-kid=\"80\"></div>\n        </div>\n      </div>\n\n      \n      <div class=\"col-span-12 lg:col-span-8 glass-card rounded-3xl p-8\" data-kid=\"81\">\n        <div class=\"flex flex-col md:flex-row md:items-center justify-between gap-4 mb-10\" data-kid=\"82\">\n          <div data-kid=\"83\">\n            <h2 class=\"text-2xl font-bold font-heading text-white mb-1\" data-kid=\"84\">Skill Proficiency Map</h2>\n            <p class=\"text-slate-400 text-sm\" data-kid=\"85\">Real-time analysis of your technical surface area.</p>\n          </div>\n          <div class=\"flex items-center gap-3 bg-white/5 px-4 py-2 rounded-xl border border-white/5\" data-kid=\"86\">\n            <div class=\"flex items-center gap-2\" data-kid=\"87\"><div class=\"w-2 h-2 rounded-full bg-slate-700\" data-kid=\"88\"></div><span class=\"text-[10px] text-slate-500 font-bold uppercase\" data-kid=\"89\">Basic</span></div>\n            <div class=\"flex items-center gap-2\" data-kid=\"90\"><div class=\"w-2 h-2 rounded-full bg-emerald-500\" data-kid=\"91\"></div><span class=\"text-[10px] text-slate-500 font-bold uppercase\" data-kid=\"92\">Fluent</span></div>\n            <div class=\"flex items-center gap-2\" data-kid=\"93\"><div class=\"w-2 h-2 rounded-full bg-purple-500\" data-kid=\"94\"></div><span class=\"text-[10px] text-slate-500 font-bold uppercase\" data-kid=\"95\">Master</span></div>\n          </div>\n        </div>\n\n        <div class=\"grid grid-cols-10 md:grid-cols-15 gap-2 md:gap-3\" data-kid=\"96\">\n          \n          <div class=\"aspect-square rounded-[4px] bg-purple-600 shadow-[0_0_10px_rgba(168,85,247,0.3)]\" data-kid=\"97\"></div>\n          <div class=\"aspect-square rounded-[4px] bg-purple-500\" data-kid=\"98\"></div>\n          <div class=\"aspect-square rounded-[4px] bg-emerald-500\" data-kid=\"99\"></div>\n          <div class=\"aspect-square rounded-[4px] bg-slate-800\" data-kid=\"100\"></div>\n          <div class=\"aspect-square rounded-[4px] bg-purple-700 shadow-[0_0_12px_rgba(168,85,247,0.4)]\" data-kid=\"101\"></div>\n          <div class=\"aspect-square rounded-[4px] bg-emerald-600\" data-kid=\"102\"></div>\n          <div class=\"aspect-square rounded-[4px] bg-slate-800\" data-kid=\"103\"></div>\n          <div class=\"aspect-square rounded-[4px] bg-purple-400\" data-kid=\"104\"></div>\n          <div class=\"aspect-square rounded-[4px] bg-emerald-400\" data-kid=\"105\"></div>\n          <div class=\"aspect-square rounded-[4px] bg-purple-500\" data-kid=\"106\"></div>\n          <div class=\"aspect-square rounded-[4px] bg-slate-800\" data-kid=\"107\"></div>\n          <div class=\"aspect-square rounded-[4px] bg-emerald-700\" data-kid=\"108\"></div>\n          <div class=\"aspect-square rounded-[4px] bg-purple-600\" data-kid=\"109\"></div>\n          <div class=\"aspect-square rounded-[4px] bg-purple-800 shadow-[0_0_15px_rgba(168,85,247,0.5)]\" data-kid=\"110\"></div>\n          <div class=\"aspect-square rounded-[4px] bg-emerald-500\" data-kid=\"111\"></div>\n          \n          <div class=\"aspect-square rounded-[4px] bg-emerald-400\" data-kid=\"112\"></div>\n          <div class=\"aspect-square rounded-[4px] bg-slate-800\" data-kid=\"113\"></div>\n          <div class=\"aspect-square rounded-[4px] bg-purple-500\" data-kid=\"114\"></div>\n          <div class=\"aspect-square rounded-[4px] bg-purple-600\" data-kid=\"115\"></div>\n          <div class=\"aspect-square rounded-[4px] bg-slate-800\" data-kid=\"116\"></div>\n          <div class=\"aspect-square rounded-[4px] bg-emerald-600\" data-kid=\"117\"></div>\n          <div class=\"aspect-square rounded-[4px] bg-purple-400\" data-kid=\"118\"></div>\n          <div class=\"aspect-square rounded-[4px] bg-slate-800\" data-kid=\"119\"></div>\n          <div class=\"aspect-square rounded-[4px] bg-purple-900 shadow-[0_0_15px_rgba(168,85,247,0.4)]\" data-kid=\"120\"></div>\n          <div class=\"aspect-square rounded-[4px] bg-slate-800\" data-kid=\"121\"></div>\n          <div class=\"aspect-square rounded-[4px] bg-emerald-500\" data-kid=\"122\"></div>\n          <div class=\"aspect-square rounded-[4px] bg-purple-500\" data-kid=\"123\"></div>\n          <div class=\"aspect-square rounded-[4px] bg-purple-700\" data-kid=\"124\"></div>\n          <div class=\"aspect-square rounded-[4px] bg-slate-800\" data-kid=\"125\"></div>\n          <div class=\"aspect-square rounded-[4px] bg-emerald-600\" data-kid=\"126\"></div>\n          \n          <div class=\"aspect-square rounded-[4px] bg-purple-500\" data-kid=\"127\"></div>\n          <div class=\"aspect-square rounded-[4px] bg-emerald-500 shadow-[0_0_10px_rgba(16,185,129,0.3)]\" data-kid=\"128\"></div>\n          <div class=\"aspect-square rounded-[4px] bg-slate-800\" data-kid=\"129\"></div>\n          <div class=\"aspect-square rounded-[4px] bg-purple-600\" data-kid=\"130\"></div>\n          <div class=\"aspect-square rounded-[4px] bg-purple-400\" data-kid=\"131\"></div>\n          <div class=\"aspect-square rounded-[4px] bg-slate-800\" data-kid=\"132\"></div>\n          <div class=\"aspect-square rounded-[4px] bg-emerald-700\" data-kid=\"133\"></div>\n          <div class=\"aspect-square rounded-[4px] bg-purple-700\" data-kid=\"134\"></div>\n          <div class=\"aspect-square rounded-[4px] bg-slate-800\" data-kid=\"135\"></div>\n          <div class=\"aspect-square rounded-[4px] bg-purple-500\" data-kid=\"136\"></div>\n          <div class=\"aspect-square rounded-[4px] bg-emerald-400\" data-kid=\"137\"></div>\n          <div class=\"aspect-square rounded-[4px] bg-slate-800\" data-kid=\"138\"></div>\n          <div class=\"aspect-square rounded-[4px] bg-purple-800\" data-kid=\"139\"></div>\n          <div class=\"aspect-square rounded-[4px] bg-purple-600\" data-kid=\"140\"></div>\n          <div class=\"aspect-square rounded-[4px] bg-emerald-500\" data-kid=\"141\"></div>\n          \n          <div class=\"aspect-square rounded-[4px] bg-slate-800\" data-kid=\"142\"></div>\n          <div class=\"aspect-square rounded-[4px] bg-emerald-600\" data-kid=\"143\"></div>\n          <div class=\"aspect-square rounded-[4px] bg-purple-400\" data-kid=\"144\"></div>\n          <div class=\"aspect-square rounded-[4px] bg-purple-500 shadow-[0_0_10px_rgba(168,85,247,0.2)]\" data-kid=\"145\"></div>\n          <div class=\"aspect-square rounded-[4px] bg-slate-800\" data-kid=\"146\"></div>\n          <div class=\"aspect-square rounded-[4px] bg-emerald-500\" data-kid=\"147\"></div>\n          <div class=\"aspect-square rounded-[4px] bg-purple-600\" data-kid=\"148\"></div>\n          <div class=\"aspect-square rounded-[4px] bg-purple-700\" data-kid=\"149\"></div>\n          <div class=\"aspect-square rounded-[4px] bg-slate-800\" data-kid=\"150\"></div>\n          <div class=\"aspect-square rounded-[4px] bg-emerald-600\" data-kid=\"151\"></div>\n          <div class=\"aspect-square rounded-[4px] bg-purple-500\" data-kid=\"152\"></div>\n          <div class=\"aspect-square rounded-[4px] bg-slate-800\" data-kid=\"153\"></div>\n          <div class=\"aspect-square rounded-[4px] bg-purple-400\" data-kid=\"154\"></div>\n          <div class=\"aspect-square rounded-[4px] bg-emerald-400\" data-kid=\"155\"></div>\n          <div class=\"aspect-square rounded-[4px] bg-purple-800\" data-kid=\"156\"></div>\n        </div>\n\n        <div class=\"mt-10 grid grid-cols-1 md:grid-cols-2 gap-6\" data-kid=\"157\">\n          <div class=\"p-5 rounded-2xl border border-emerald-500/20 bg-emerald-500/5 relative overflow-hidden\" data-kid=\"158\">\n            <div class=\"absolute top-0 right-0 p-4 opacity-10\" data-kid=\"159\">\n              <i class=\"ti ti-trending-up text-4xl text-emerald-400\" data-kid=\"160\"></i>\n            </div>\n            <h4 class=\"text-emerald-400 text-xs font-bold uppercase tracking-[0.2em] mb-2\" data-kid=\"161\">Key Strength</h4>\n            <p class=\"text-slate-300 text-sm leading-relaxed\" data-kid=\"162\">System Architecture & Scalability. Your scores indicate expert-level proficiency in distributed systems design.</p>\n          </div>\n          <div class=\"p-5 rounded-2xl border border-purple-500/20 bg-purple-500/5 relative overflow-hidden\" data-kid=\"163\">\n             <div class=\"absolute top-0 right-0 p-4 opacity-10\" data-kid=\"164\">\n              <i class=\"ti ti-target text-4xl text-purple-400\" data-kid=\"165\"></i>\n            </div>\n            <h4 class=\"text-purple-400 text-xs font-bold uppercase tracking-[0.2em] mb-2\" data-kid=\"166\">Priority Fix</h4>\n            <p class=\"text-slate-300 text-sm leading-relaxed\" data-kid=\"167\">Asymptotic Analysis. Focus on worst-case space complexity scenarios in your next session to improve rank.</p>\n          </div>\n        </div>\n      </div>\n\n      \n      <div class=\"col-span-12 lg:col-span-4 glass-card rounded-3xl p-8 flex flex-col relative overflow-hidden\" data-kid=\"168\">\n        <div class=\"scan-line\" data-kid=\"169\"></div>\n        <div class=\"flex items-center justify-between mb-8\" data-kid=\"170\">\n          <h3 class=\"font-bold font-heading text-white\" data-kid=\"171\">Live AI Analysis</h3>\n          <div class=\"flex items-center gap-2\" data-kid=\"172\">\n            <span class=\"relative flex h-2 w-2\" data-kid=\"173\">\n              <span class=\"animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75\" data-kid=\"174\"></span>\n              <span class=\"relative inline-flex rounded-full h-2 w-2 bg-emerald-500\" data-kid=\"175\"></span>\n            </span>\n            <span class=\"text-[10px] text-slate-500 font-bold uppercase\" data-kid=\"176\">Active</span>\n          </div>\n        </div>\n        \n        <div class=\"flex-1 space-y-6\" data-kid=\"177\">\n          <div class=\"space-y-3\" data-kid=\"178\">\n            <div class=\"h-3 w-3/4 bg-white/5 rounded-full\" data-kid=\"179\"></div>\n            <div class=\"h-3 w-full bg-white/5 rounded-full\" data-kid=\"180\"></div>\n            <div class=\"h-3 w-1/2 bg-white/5 rounded-full\" data-kid=\"181\"></div>\n          </div>\n          \n          <div class=\"p-4 rounded-xl bg-purple-500/10 border border-purple-500/20\" data-kid=\"182\">\n            <p class=\"text-xs text-purple-300 italic mb-2\" data-kid=\"183\">\"Synthesizing latest performance data...\"</p>\n            <div class=\"flex items-center gap-2\" data-kid=\"184\">\n              <div class=\"w-1 h-1 rounded-full bg-purple-400\" data-kid=\"185\"></div>\n              <div class=\"w-1 h-1 rounded-full bg-purple-400 animate-pulse\" data-kid=\"186\"></div>\n              <div class=\"w-1 h-1 rounded-full bg-purple-400\" data-kid=\"187\"></div>\n            </div>\n          </div>\n\n          <div class=\"space-y-4\" data-kid=\"188\">\n            <div class=\"flex items-start gap-3\" data-kid=\"189\">\n              <div class=\"w-8 h-8 rounded-lg bg-emerald-500/10 flex items-center justify-center shrink-0\" data-kid=\"190\">\n                <i class=\"ti ti-check text-emerald-400\" data-kid=\"191\"></i>\n              </div>\n              <div data-kid=\"192\">\n                <p class=\"text-xs font-bold text-white\" data-kid=\"193\">Confidence Level High</p>\n                <p class=\"text-[10px] text-slate-500\" data-kid=\"194\">Validated across 3 sessions</p>\n              </div>\n            </div>\n            <div class=\"flex items-start gap-3\" data-kid=\"195\">\n              <div class=\"w-8 h-8 rounded-lg bg-indigo-500/10 flex items-center justify-center shrink-0\" data-kid=\"196\">\n                <i class=\"ti ti-alert-circle text-indigo-400\" data-kid=\"197\"></i>\n              </div>\n              <div data-kid=\"198\">\n                <p class=\"text-xs font-bold text-white\" data-kid=\"199\">New Pattern Detected</p>\n                <p class=\"text-[10px] text-slate-500\" data-kid=\"200\">Focus shifting towards DevOps</p>\n              </div>\n            </div>\n          </div>\n        </div>\n\n        <button class=\"mt-8 w-full py-4 rounded-xl border border-dashed border-white/20 hover:border-purple-500/50 hover:bg-purple-500/5 transition-all text-xs font-bold text-slate-400 hover:text-purple-400 flex items-center justify-center gap-2\" data-kid=\"201\">\n          <i class=\"ti ti-upload-cloud\" data-kid=\"202\"></i>\n          Update Data Source\n        </button>\n      </div>\n\n      \n      <div class=\"col-span-12 glass-card rounded-3xl p-8 border-l-4 border-l-purple-500 flex flex-col md:flex-row items-center justify-between gap-6 relative overflow-hidden group\" data-kid=\"203\">\n        <div class=\"absolute inset-0 bg-gradient-to-r from-purple-500/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity\" data-kid=\"204\"></div>\n        <div class=\"flex items-center gap-6 relative z-10\" data-kid=\"205\">\n          <div class=\"w-14 h-14 rounded-2xl bg-white/5 border border-white/10 flex items-center justify-center\" data-kid=\"206\">\n            <i class=\"ti ti-zap text-3xl text-purple-400 drop-shadow-[0_0_8px_rgba(168,85,247,0.5)]\" data-kid=\"207\"></i>\n          </div>\n          <div data-kid=\"208\">\n            <h3 class=\"text-xl font-bold font-heading text-white\" data-kid=\"209\">Boost your score to 90+</h3>\n            <p class=\"text-slate-400 text-sm\" data-kid=\"210\">Our AI has identified a custom learning path to reach elite status.</p>\n          </div>\n        </div>\n        <button class=\"relative z-10 px-8 py-3 bg-white text-black font-bold rounded-xl hover:scale-105 active:scale-95 transition-all whitespace-nowrap\" data-kid=\"211\">\n          View Action Plan\n        </button>\n      </div>\n\n    </div>\n    \n    \n    <footer class=\"mt-20 pt-8 border-t border-white/5 flex flex-col md:flex-row items-center justify-between gap-4 text-slate-500 text-xs font-medium uppercase tracking-widest\" data-kid=\"212\">\n      <p data-kid=\"213\">© 2026 AI.INTERVIEW ENGINE • ALL SYSTEMS NOMINAL</p>\n      <div class=\"flex gap-8\" data-kid=\"214\">\n        <a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"215\">Privacy Protocol</a>\n        <a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"216\">Neural Terms</a>\n        <a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"217\">Support Portal</a>\n      </div>\n    </footer>\n  </main>\n</div>\n",
