      "html": "\n<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Space+Grotesk:wght@400;500;600;700&display=swap');\n\n  :root {\n    --bg-base: #080812;\n    --bg-surface: #0d0d1f;\n    --bg-card: #111128;\n    --primary: #8b5cf6;\n    --secondary: #3b82f6;\n    --accent: #06b6d4;\n    --text-base: #f8fafc;\n    --text-muted: #94a3b8;\n  }\n\n  body {\n    background-color: var(--bg-base);\n    color: var(--text-base);\n    font-family: 'Inter', sans-serif;\n    margin: 0;\n    padding: 0;\n  }\n\n  .font-heading {\n    font-family: 'Space Grotesk', sans-serif;\n  }\n\n  .glass-card {\n    background: rgba(255, 255, 255, 0.03);\n    backdrop-filter: blur(24px);\n    -webkit-backdrop-filter: blur(24px);\n    border: 1px solid rgba(255, 255, 255, 0.08);\n  }\n\n  .gradient-text {\n    background: linear-gradient(135deg, #c084fc, #818cf8, #67e8f9);\n    -webkit-background-clip: text;\n    background-clip: text;\n    -webkit-text-fill-color: transparent;\n  }\n\n  .neon-button {\n    background: linear-gradient(135deg, #8b5cf6, #6d28d9);\n    border: 1px solid rgba(139, 92, 246, 0.5);\n    box-shadow: 0 0 20px rgba(139, 92, 246, 0.3);\n    color: white;\n    font-weight: 600;\n    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);\n  }\n\n  .neon-button:hover {\n    box-shadow: 0 0 35px rgba(139, 92, 246, 0.6);\n    transform: translateY(-2px);\n    filter: brightness(1.1);\n  }\n\n  .animate-float {\n    animation: float 6s ease-in-out infinite;\n  }\n\n  @keyframes float {\n    0%, 100% { transform: translateY(0px); }\n    50% { transform: translateY(-20px); }\n  }\n\n  .animate-pulse-glow {\n    animation: pulseGlow 2s ease-in-out infinite;\n  }\n\n  @keyframes pulseGlow {\n    0%, 100% { box-shadow: 0 0 20px rgba(139, 92, 246, 0.3); }\n    50% { box-shadow: 0 0 50px rgba(139, 92, 246, 0.7); }\n  }\n\n  /* Custom scrollbar */\n  ::-webkit-scrollbar {\n    width: 6px;\n  }\n  ::-webkit-scrollbar-track {\n    background: var(--bg-surface);\n  }\n  ::-webkit-scrollbar-thumb {\n    background: rgba(139, 92, 246, 0.4);\n    border-radius: 3px;\n  }\n\n  /* Accordion styles */\n  .accordion-content {\n    max-height: 0;\n    overflow: hidden;\n    transition: max-height 0.3s ease-out;\n  }\n  .accordion-item.active .accordion-content {\n    max-height: 200px;\n  }\n  .accordion-item.active .accordion-icon {\n    transform: rotate(180deg);\n  }\n\n  /* Pricing Toggle */\n  .pricing-toggle-knob {\n    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);\n  }\n  .pricing-toggle.yearly .pricing-toggle-knob {\n    transform: translateX(24px);\n    background-color: #8b5cf6;\n    box-shadow: 0 0 15px rgba(139, 92, 246, 0.8);\n  }\n</style>\n\n<div class=\"relative selection:bg-violet-500/35 selection:text-white overflow-hidden\" data-kid=\"1\">\n  \n  \n  <nav class=\"absolute top-0 left-0 right-0 h-16 z-50 flex items-center justify-between px-6 md:px-12 bg-[#080812]/85 backdrop-blur-[20px] border-b border-white/5\" data-kid=\"2\">\n    <div class=\"flex items-center gap-2.5\" data-kid=\"3\">\n      <div class=\"w-8 h-8 rounded-lg flex items-center justify-center bg-gradient-to-br from-[#8b5cf6] to-[#3b82f6]\" data-kid=\"4\">\n        <i data-lucide=\"zap\" class=\"w-4 h-4 text-white\" data-kid=\"5\"></i>\n      </div>\n      <span class=\"font-bold text-white text-lg font-heading\" data-kid=\"6\">InterviewAI</span>\n    </div>\n    <div class=\"hidden md:flex items-center gap-8\" data-kid=\"7\">\n      <a href=\"#features\" class=\"text-sm text-[#94a3b8] hover:text-white transition-colors\" data-kid=\"8\">Features</a>\n      <a href=\"#demo\" class=\"text-sm text-[#94a3b8] hover:text-white transition-colors\" data-kid=\"9\">Demo</a>\n      <a href=\"#pricing\" class=\"text-sm text-[#94a3b8] hover:text-white transition-colors\" data-kid=\"10\">Pricing</a>\n      <a href=\"#faq\" class=\"text-sm text-[#94a3b8] hover:text-white transition-colors\" data-kid=\"11\">FAQ</a>\n    </div>\n    <div class=\"flex items-center gap-3\" data-kid=\"12\">\n      <button class=\"px-4 py-2 text-sm text-slate-300 hover:text-white transition-colors hidden sm:block\" data-kid=\"13\">Log in</button>\n      <button class=\"neon-button px-5 py-2 rounded-lg text-sm\" data-kid=\"14\">Get Started</button>\n    </div>\n  </nav>\n\n  \n  <section class=\"relative min-h-[900px] flex items-center justify-center pt-16 overflow-hidden\" data-kid=\"15\">\n    \n    <div id=\"particle-container\" class=\"absolute inset-0 pointer-events-none opacity-60\" data-kid=\"16\">\n       <canvas id=\"particleCanvas\" class=\"w-full h-full\" data-kid=\"17\"></canvas>\n    </div>\n    \n    <div class=\"absolute -top-40 -left-40 w-96 h-96 rounded-full bg-[radial-gradient(circle,rgba(139,92,246,0.25)_0%,transparent_70%)] animate-float\" data-kid=\"18\"></div>\n    <div class=\"absolute -right-20 top-1/3 w-80 h-80 rounded-full bg-[radial-gradient(circle,rgba(59,130,246,0.2)_0%,transparent_70%)] animate-float\" style=\"animation-delay: 2s;\" data-kid=\"19\"></div>\n    \n    <div class=\"max-w-5xl px-6 relative z-10 mx-auto text-center\" data-kid=\"20\">\n      <div class=\"inline-flex items-center px-4 py-1.5 rounded-full text-sm mb-6 bg-violet-500/15 text-[#c4b5fd] border border-violet-500/30\" data-kid=\"21\">\n        <i data-lucide=\"sparkles\" class=\"w-3 h-3 mr-1.5\" data-kid=\"22\"></i>\n        Powered by GPT-4 + Claude\n      </div>\n\n      <h1 class=\"text-5xl md:text-7xl font-black mb-6 leading-tight tracking-tight text-white font-heading\" data-kid=\"23\">\n        Ace Your Next<br data-kid=\"24\">\n        <span class=\"gradient-text\" data-kid=\"25\">Interview with AI</span>\n      </h1>\n\n      <p class=\"text-lg md:text-xl mb-6 max-w-2xl leading-relaxed mx-auto text-[#94a3b8]\" data-kid=\"26\">\n        Practice technical, behavioral, and HR interviews with an AI interviewer trained on real hiring conversations.\n      </p>\n\n      \n      <div class=\"mb-10 h-8\" data-kid=\"27\">\n        <span id=\"typing-text\" class=\"text-lg md:text-xl font-medium text-violet-400/90 font-heading tracking-wide\" data-kid=\"28\"></span>\n        <span class=\"inline-block w-0.5 h-6 bg-violet-400 animate-pulse align-middle ml-1\" data-kid=\"29\"></span>\n      </div>\n\n      <div class=\"flex flex-col sm:flex-row gap-4 items-center justify-center\" data-kid=\"30\">\n        <button class=\"neon-button px-8 h-12 rounded-xl text-base flex items-center gap-2\" data-kid=\"31\">\n          <i data-lucide=\"zap\" class=\"w-4.5 h-4.5\" data-kid=\"32\"></i> Start Free\n        </button>\n        <button class=\"px-8 h-12 rounded-xl bg-white/3 text-[#c4b5fd] font-medium border border-white/10 hover:bg-white/5 transition-all flex items-center gap-2\" data-kid=\"33\">\n          <i data-lucide=\"play\" class=\"w-4.5 h-4.5\" data-kid=\"34\"></i> Watch Demo\n        </button>\n      </div>\n\n      \n      <div class=\"mt-20 max-w-4xl group relative mx-auto\" data-kid=\"35\">\n        <div class=\"absolute -inset-4 blur-3xl rounded-[2.5rem] bg-gradient-to-r from-violet-500/20 via-cyan-500/20 to-blue-500/20 opacity-40 transition-opacity duration-1000 group-hover:opacity-70\" data-kid=\"36\"></div>\n        <div class=\"glass-card p-2 md:p-3 rounded-[2rem] relative overflow-hidden border-white/10 shadow-2xl\" data-kid=\"37\">\n          <div class=\"relative overflow-hidden rounded-[1.5rem] aspect-[16/9] bg-[#0d0d1f]\" data-kid=\"38\">\n            \n            <img src=\"https://images.pexels.com/photos/28428591/pexels-photo-28428591.jpeg?auto=compress&cs=tinysrgb&w=1200&q=80\" alt=\"Dashboard\" class=\"w-full h-full object-cover opacity-40 grayscale group-hover:grayscale-0 group-hover:opacity-60 transition-all duration-700\" data-kid=\"39\">\n            <div class=\"absolute inset-0 bg-gradient-to-t from-[#080812] via-transparent to-transparent\" data-kid=\"40\"></div>\n            \n            \n            <div class=\"absolute inset-0 p-6 flex flex-col justify-end text-left\" data-kid=\"41\">\n              <div class=\"max-w-md glass-card p-6 shadow-2xl border-violet-500/30 bg-white/[0.05]\" data-kid=\"42\">\n                <div class=\"flex items-center gap-3 mb-4\" data-kid=\"43\">\n                  <div class=\"w-8 h-8 rounded-full bg-gradient-to-br from-[#8b5cf6] to-[#3b82f6] flex items-center justify-center\" data-kid=\"44\">\n                    <i data-lucide=\"bot\" class=\"w-4 h-4 text-white\" data-kid=\"45\"></i>\n                  </div>\n                  <div data-kid=\"46\">\n                    <p class=\"text-sm font-semibold text-white\" data-kid=\"47\">AI Interviewer</p>\n                    <div class=\"flex items-center gap-1.5\" data-kid=\"48\">\n                      <span class=\"w-1.5 h-1.5 bg-green-400 animate-pulse rounded-full\" data-kid=\"49\"></span>\n                      <span class=\"text-xs text-[#94a3b8]\" data-kid=\"50\">Live session</span>\n                    </div>\n                  </div>\n                  \n                  <div class=\"ml-auto flex items-end gap-1 h-4\" data-kid=\"51\">\n                    <div class=\"w-1 h-3 bg-violet-400 animate-[bounce_0.6s_infinite]\" data-kid=\"52\"></div>\n                    <div class=\"w-1 h-4 bg-violet-400 animate-[bounce_0.8s_infinite]\" data-kid=\"53\"></div>\n                    <div class=\"w-1 h-2 bg-violet-400 animate-[bounce_0.5s_infinite]\" data-kid=\"54\"></div>\n                    <div class=\"w-1 h-4 bg-violet-400 animate-[bounce_0.7s_infinite]\" data-kid=\"55\"></div>\n                  </div>\n                </div>\n                <div class=\"space-y-3\" data-kid=\"56\">\n                  <div class=\"p-3 rounded-lg bg-violet-500/10 border border-violet-500/15\" data-kid=\"57\">\n                    <p class=\"text-sm text-white leading-relaxed\" data-kid=\"58\">\"Tell me about a time you had to optimize a system under tight deadlines. Walk me through your thought process.\"</p>\n                  </div>\n                  <div class=\"flex gap-2 pl-4\" data-kid=\"59\">\n                    <div class=\"w-6 h-6 rounded-full bg-slate-600 shrink-0 border border-white/10\" style=\"background-image: url(https://i.pravatar.cc/24?u=user); background-size: cover;\" data-kid=\"60\"></div>\n                    <p class=\"text-sm text-slate-300\" data-kid=\"61\">\"In my previous role at a startup, we had a database query taking 8 seconds...\"</p>\n                  </div>\n                </div>\n                <div class=\"mt-4 pt-4 border-t border-white/5 flex items-center justify-between\" data-kid=\"62\">\n                  <div class=\"flex items-center gap-2\" data-kid=\"63\">\n                    <div class=\"w-2 h-2 bg-green-400 animate-pulse rounded-full\" data-kid=\"64\"></div>\n                    <span class=\"text-xs text-[#94a3b8]\" data-kid=\"65\">Analyzing response...</span>\n                  </div>\n                  <div class=\"flex gap-3 text-[10px] uppercase tracking-wider font-bold\" data-kid=\"66\">\n                    <span class=\"text-violet-400\" data-kid=\"67\">Confidence: 87%</span>\n                    <span class=\"text-cyan-400\" data-kid=\"68\">Clarity: 92%</span>\n                  </div>\n                </div>\n              </div>\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"py-20 border-t border-white/5 overflow-hidden\" data-kid=\"69\">\n    <div class=\"text-center mb-10\" data-kid=\"70\">\n      <p class=\"text-xs font-medium tracking-[0.2em] uppercase text-[#475569]\" data-kid=\"71\">Trusted by candidates from</p>\n    </div>\n    <div class=\"flex flex-wrap items-center justify-center gap-12 px-6 opacity-30 grayscale hover:grayscale-0 transition-all duration-500\" data-kid=\"72\">\n      <span class=\"text-2xl font-black font-heading text-white\" data-kid=\"73\">Google</span>\n      <span class=\"text-2xl font-black font-heading text-white\" data-kid=\"74\">Amazon</span>\n      <span class=\"text-2xl font-black font-heading text-white\" data-kid=\"75\">Meta</span>\n      <span class=\"text-2xl font-black font-heading text-white\" data-kid=\"76\">Netflix</span>\n      <span class=\"text-2xl font-black font-heading text-white\" data-kid=\"77\">Microsoft</span>\n      <span class=\"text-2xl font-black font-heading text-white\" data-kid=\"78\">OpenAI</span>\n    </div>\n  </section>\n\n  \n  <section id=\"features\" class=\"py-24 px-6 max-w-7xl mx-auto\" data-kid=\"79\">\n    <div class=\"text-center mb-16\" data-kid=\"80\">\n      <p class=\"text-sm font-medium tracking-widest text-[#8b5cf6] uppercase mb-3\" data-kid=\"81\">Features</p>\n      <h2 class=\"text-4xl md:text-5xl font-black text-white mb-4 font-heading\" data-kid=\"82\">\n        Everything you need to <span class=\"gradient-text\" data-kid=\"83\">land the role</span>\n      </h2>\n      <p class=\"text-lg max-w-2xl mx-auto text-[#94a3b8]\" data-kid=\"84\">\n        From AI-powered mock interviews to ATS resume scoring, we've built the most comprehensive interview prep platform.\n      </p>\n    </div>\n\n    <div class=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4\" data-kid=\"85\">\n      \n      <div class=\"glass-card p-6 rounded-2xl border-white/5 hover:border-violet-500/40 hover:bg-white/[0.06] hover:shadow-[0_0_30px_rgba(139,92,246,0.2)] transition-all duration-300 cursor-pointer group\" data-kid=\"86\">\n        <div class=\"w-10 h-10 rounded-xl mb-4 bg-violet-500/20 flex items-center justify-center group-hover:scale-110 transition-transform\" data-kid=\"87\">\n          <i data-lucide=\"brain\" class=\"w-5 h-5 text-[#8b5cf6]\" data-kid=\"88\"></i>\n        </div>\n        <h3 class=\"font-semibold text-white mb-2\" data-kid=\"89\">AI Mock Interviews</h3>\n        <p class=\"text-sm text-[#64748b] leading-relaxed\" data-kid=\"90\">Practice with an adaptive AI trained on 10,000+ real interviews.</p>\n      </div>\n\n      <div class=\"glass-card p-6 rounded-2xl border-white/5 hover:border-blue-500/30 hover:shadow-[0_0_30px_rgba(59,130,246,0.15)] transition-all cursor-pointer group\" data-kid=\"91\">\n        <div class=\"w-10 h-10 rounded-xl mb-4 bg-blue-500/20 flex items-center justify-center group-hover:scale-110 transition-transform\" data-kid=\"92\">\n          <i data-lucide=\"file-text\" class=\"w-5 h-5 text-[#3b82f6]\" data-kid=\"93\"></i>\n        </div>\n        <h3 class=\"font-semibold text-white mb-2\" data-kid=\"94\">Resume Analyzer</h3>\n        <p class=\"text-sm text-[#64748b] leading-relaxed\" data-kid=\"95\">Get ATS scores, keyword gaps, and improvement suggestions instantly.</p>\n      </div>\n\n      <div class=\"glass-card p-6 rounded-2xl border-white/5 hover:border-cyan-500/30 hover:shadow-[0_0_30px_rgba(6,182,212,0.15)] transition-all cursor-pointer group\" data-kid=\"96\">\n        <div class=\"w-10 h-10 rounded-xl mb-4 bg-cyan-500/20 flex items-center justify-center group-hover:scale-110 transition-transform\" data-kid=\"97\">\n          <i data-lucide=\"mic\" class=\"w-5 h-5 text-[#06b6d4]\" data-kid=\"98\"></i>\n        </div>\n        <h3 class=\"font-semibold text-white mb-2\" data-kid=\"99\">Voice Interviews</h3>\n        <p class=\"text-sm text-[#64748b] leading-relaxed\" data-kid=\"100\">Real-time voice recognition with live transcription and analysis.</p>\n      </div>\n\n      <div class=\"glass-card p-6 rounded-2xl border-white/5 hover:border-green-500/30 hover:shadow-[0_0_30px_rgba(16,185,129,0.15)] transition-all cursor-pointer group\" data-kid=\"101\">\n        <div class=\"w-10 h-10 rounded-xl mb-4 bg-green-500/20 flex items-center justify-center group-hover:scale-110 transition-transform\" data-kid=\"102\">\n          <i data-lucide=\"code\" class=\"w-5 h-5 text-[#10b981]\" data-kid=\"103\"></i>\n        </div>\n        <h3 class=\"font-semibold text-white mb-2\" data-kid=\"104\">Coding Interviews</h3>\n        <p class=\"text-s