      "html": "\n<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Inter:wght@400;500;600;700&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n  :root {\n    --primary-gradient: linear-gradient(135deg, var(--k-color-primary), var(--k-color-secondary));\n    --text-gradient: linear-gradient(135deg, #c084fc, #818cf8, #67e8f9);\n  }\n\n  body {\n    background-color: var(--k-color-bg-page);\n    color: var(--k-color-text-primary);\n    font-family: var(--k-font-family-body);\n    margin: 0;\n    position: relative;\n  }\n\n  .bg-canvas {\n    position: absolute;\n    inset: 0;\n    z-index: -1;\n    background: radial-gradient(circle at 50% -20%, #1e1b4b 0%, var(--k-color-bg-page) 70%);\n  }\n\n  .bg-grid {\n    position: absolute;\n    inset: 0;\n    z-index: -1;\n    opacity: 0.03;\n    background-image: radial-gradient(#fff 1px, transparent 1px);\n    background-size: 40px 40px;\n  }\n\n  .noise-overlay {\n    position: absolute;\n    inset: 0;\n    z-index: -1;\n    opacity: 0.02;\n    background-image: url('https://grainy-gradients.vercel.app/noise.svg');\n    pointer-events: none;\n  }\n\n  .font-heading {\n    font-family: var(--k-font-family-heading);\n  }\n\n  .glass-card {\n    background: rgba(255, 255, 255, 0.03);\n    backdrop-filter: blur(20px);\n    border: 1px solid var(--k-color-border);\n    border-radius: var(--k-radius-xl);\n    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);\n  }\n\n  .glass-card:hover {\n    border-color: var(--k-color-border-hover);\n    background: rgba(255, 255, 255, 0.05);\n  }\n\n  .gradient-text {\n    background: var(--text-gradient);\n    -webkit-background-clip: text;\n    background-clip: text;\n    -webkit-text-fill-color: transparent;\n  }\n\n  .btn-neon {\n    background: var(--primary-gradient);\n    color: white;\n    box-shadow: 0 0 20px rgba(139, 92, 246, 0.3);\n    transition: all 0.3s ease;\n  }\n\n  .btn-neon:hover {\n    box-shadow: 0 0 40px rgba(139, 92, 246, 0.5);\n    transform: translateY(-2px);\n  }\n\n  .btn-ghost {\n    background: transparent;\n    border: 1px solid var(--k-color-border);\n    color: var(--k-color-text-primary);\n    transition: all 0.3s ease;\n  }\n\n  .btn-ghost:hover {\n    background: rgba(255, 255, 255, 0.05);\n    border-color: var(--k-color-text-secondary);\n  }\n\n  @keyframes scanLineAnim {\n    0% { top: 0%; opacity: 0; }\n    10% { opacity: 1; }\n    90% { opacity: 1; }\n    100% { top: 100%; opacity: 0; }\n  }\n\n  .scan-line {\n    position: absolute;\n    left: 0;\n    right: 0;\n    height: 2px;\n    background: var(--k-color-primary);\n    box-shadow: 0 0 20px var(--k-color-primary);\n    animation: scanLineAnim 4s linear infinite;\n    pointer-events: none;\n    z-index: 20;\n  }\n\n  @keyframes floatAnim {\n    0%, 100% { transform: translateY(0px) rotate(0deg); }\n    50% { transform: translateY(-15px) rotate(5deg); }\n  }\n\n  .animate-float {\n    animation: floatAnim 6s ease-in-out infinite;\n  }\n\n  .progress-glow {\n    box-shadow: 0 0 10px currentColor;\n  }\n\n  .terminal-box {\n    background: #0d0d1f;\n    border: 2px dashed var(--k-color-border);\n    box-shadow: inset 0 0 60px rgba(0, 0, 0, 0.8);\n  }\n</style>\n\n<div class=\"relative overflow-hidden min-h-[1200px]\" data-kid=\"1\">\n  <div class=\"bg-canvas\" data-kid=\"2\"></div>\n  <div class=\"bg-grid\" data-kid=\"3\"></div>\n  <div class=\"noise-overlay\" data-kid=\"4\"></div>\n\n  <main class=\"max-w-7xl mx-auto px-6 py-12 space-y-32 relative z-10\" data-kid=\"5\">\n  \n  <section class=\"flex flex-col items-center text-center pt-20\" data-kid=\"6\">\n    <div class=\"space-y-6 max-w-4xl\" data-kid=\"7\">\n      <div class=\"inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/5 border border-white/10 mb-8\" data-kid=\"8\">\n        <span class=\"w-2 h-2 rounded-full bg-cyan-400 animate-pulse\" data-kid=\"9\"></span>\n        <span class=\"text-xs font-bold uppercase tracking-widest text-cyan-400\" data-kid=\"10\">Next Gen Career Intelligence</span>\n      </div>\n      <div class=\"relative inline-block\" data-kid=\"11\">\n        <div class=\"absolute -inset-x-20 -inset-y-10 bg-[var(--k-color-primary)] opacity-15 blur-[100px] rounded-full\" data-kid=\"12\"></div>\n        <h1 class=\"relative text-6xl md:text-8xl font-bold font-heading text-white leading-[0.95] tracking-tight\" data-kid=\"13\">\n          Master Your Next <br data-kid=\"14\"> \n          <span class=\"gradient-text\" data-kid=\"15\">Interview with AI</span>\n        </h1>\n      </div>\n      <p class=\"text-xl text-[var(--k-color-text-secondary)] max-w-2xl mx-auto leading-relaxed\" data-kid=\"16\">\n        Personalized AI coaching that analyzes your performance in real-time to help you land your dream tech role.\n      </p>\n      <div class=\"flex items-center justify-center gap-6 pt-8\" data-kid=\"17\">\n        <button class=\"btn-neon px-10 py-4 rounded-xl font-bold text-lg cursor-pointer\" data-kid=\"18\">Get Started</button>\n        <button class=\"btn-ghost px-10 py-4 rounded-xl font-bold text-lg cursor-pointer\" data-kid=\"19\">View Demo</button>\n      </div>\n    </div>\n\n    \n    <div class=\"mt-24 w-full max-w-5xl mx-auto h-[600px] glass-card relative overflow-hidden group shadow-[0_0_100px_rgba(139,92,246,0.15)]\" data-kid=\"20\">\n      <video src=\"https://videos.pexels.com/video-files/34745269/14729592_360_640_30fps.mp4\" poster=\"https://images.pexels.com/videos/34745269/pexels-photo-34745269.jpeg?auto=compress&cs=tinysrgb&fit=crop&h=1200&w=630\" autoplay muted loop playsinline class=\"w-full h-full object-cover opacity-60 scale-110\" data-kid=\"21\"></video>\n      <div class=\"scan-line\" data-kid=\"22\"></div>\n      <div class=\"absolute inset-0 bg-gradient-to-t from-[var(--k-color-bg-page)] via-transparent to-transparent opacity-80\" data-kid=\"23\"></div>\n      \n      \n      <d