      "html": "\n<div class=\"min-h-[1200px] w-full bg-[#080812] text-[#f8fafc] font-[var(--k-font-family-body)] p-8 selection:bg-[var(--k-color-primary)] selection:text-white\" data-kid=\"0\">\n  \n  <nav class=\"flex items-center gap-2 mb-8 text-xs font-medium uppercase tracking-[0.2em] text-[var(--k-color-text-muted)]\" data-kid=\"1\">\n    <span class=\"hover:text-[var(--k-color-primary)] cursor-pointer transition-colors\" data-kid=\"2\">Candidate Portal</span>\n    <i class=\"ti ti-chevron-right text-[10px]\" data-kid=\"3\"></i>\n    <span class=\"text-[var(--k-color-text-secondary)]\" data-kid=\"4\">Interview Performance Analysis</span>\n  </nav>\n\n  \n  <header class=\"flex flex-col md:flex-row justify-between items-start md:items-end gap-6 mb-12\" data-kid=\"5\">\n    <div class=\"space-y-2\" data-kid=\"6\">\n      <h1 class=\"text-5xl font-[var(--k-font-family-heading)] font-bold tracking-tight leading-none\" data-kid=\"7\">\n        Performance <span class=\"bg-linear-to-r from-[#c084fc] via-[#818cf8] to-[#67e8f9] bg-clip-text text-transparent\" data-kid=\"8\">Analysis</span>\n      </h1>\n      <p class=\"text-[var(--k-color-text-secondary)] text-lg max-w-2xl font-medium\" data-kid=\"9\">\n        Comprehensive AI-generated feedback for your <span class=\"text-white\" data-kid=\"10\">Senior Frontend Engineer</span> interview session.\n      </p>\n    </div>\n    \n    <div class=\"flex items-center gap-4\" data-kid=\"11\">\n      <div class=\"hidden lg:flex flex-col items-end mr-4\" data-kid=\"12\">\n        <span class=\"text-[10px] uppercase tracking-widest text-[var(--k-color-text-muted)]\" data-kid=\"13\">Generated on</span>\n        <span class=\"text-sm font-mono text-[var(--k-color-text-secondary)]\" data-kid=\"14\">Oct 24, 2026</span>\n      </div>\n      <button class=\"group relative px-8 py-4 bg-[#8b5cf6] text-white rounded-[var(--k-radius-lg)] font-bold shadow-[0_0_30px_rgba(139,92,246,0.4)] hover:shadow-[0_0_50px_rgba(139,92,246,0.6)] transition-all flex items-center gap-3 overflow-hidden\" data-kid=\"15\">\n        <div class=\"absolute inset-0 bg-linear-to-r from-white/0 via-white/10 to-white/0 -translate-x-full group-hover:translate-x-full transition-transform duration-700\" data-kid=\"16\"></div>\n        <i class=\"ti ti-file-download text-xl\" data-kid=\"17\"></i>\n        <span data-kid=\"18\">EXPORT TO PDF</span>\n      </button>\n    </div>\n  </header>\n\n  \n  <div class=\"grid grid-cols-12 gap-6 mb-12\" data-kid=\"19\">\n    \n    <div class=\"col-span-12 lg:col-span-8 bg-white/3 border border-white/5 rounded-[var(--k-radius-2xl)] backdrop-blur-xl p-8 relative overflow-hidden group\" data-kid=\"20\">\n      \n      <div class=\"absolute -top-24 -left-24 w-96 h-96 bg-[var(--k-color-primary)]/10 blur-[100px] rounded-full group-hover:bg-[var(--k-color-primary)]/15 transition-colors\" data-kid=\"21\"></div>\n      \n      <div class=\"flex items-center justify-between mb-8 relative z-10\" data-kid=\"22\">\n        <div class=\"space-y-1\" data-kid=\"23\">\n          <h3 class=\"font-[var(--k-font-family-heading)] text-2xl font-bold flex items-center gap-3\" data-kid=\"24\">\n            <i class=\"ti ti-chart-radar text-[var(--k-color-primary)] text-3xl\" data-kid=\"25\"></i>\n            Technical vs. Soft Skills\n          </h3>\n          <p class=\"text-sm text-[var(--k-color-text-secondary)]\" data-kid=\"26\">Multidimensional competency mapping</p>\n        </div>\n        <div class=\"flex gap-2\" data-kid=\"27\">\n            <span class=\"px-3 py-1 bg-white/5 border border-white/10 rounded-full text-[10px] font-bold tracking-widest text-[var(--k-color-text-muted)] flex items-center gap-2 uppercase\" data-kid=\"28\">\n                <span class=\"w-2 h-2 rounded-full bg-[var(--k-color-primary)]\" data-kid=\"29\"></span> Technical\n            </span>\n            <span class=\"px-3 py-1 bg-white/5 border border-white/10 rounded-full text-[10px] font-bold tracking-widest text-[var(--k-color-text-muted)] flex items-center gap-2 uppercase\" data-kid=\"30\">\n                <span class=\"w-2 h-2 rounded-full bg-[var(--k-color-accent)]\" data-kid=\"31\"></span> Soft Skills\n            </span>\n        </div>\n      </div>\n\n      <div class=\"w-full aspect-square md:aspect-video flex items-center justify-center relative z-10\" data-kid=\"32\">\n        <canvas id=\"skillRadar\" class=\"max-w-[500px] w-full\" data-kid=\"33\"></canvas>\n      </div>\n    </div>\n\n    \n    <div class=\"col-span-12 lg:col-span-4 space-y-6\" data-kid=\"34\">\n      \n      <div class=\"bg-linear-to-br from-white/5 to-white/[0.02] border border-white/10 rounded-[var(--k-radius-2xl)] backdrop-blur-xl p-8 flex flex-col items-center justify-center relative overflow-hidden h-full min-h-[400px]\" data-kid=\"35\">\n        <div class=\"absolute inset-0 bg-[radial-gradient(circle_at_center,_var(--color-primary)_0%,_transparent_70%)] opacity-5\" data-kid=\"36\"></div>\n        \n        <div class=\"relative w-56 h-56 mb-6\" data-kid=\"37\">\n          <svg class=\"w-full h-full -rotate-90 drop-shadow-[0_0_15px_rgba(139,92,246,0.3)]\" viewBox=\"0 0 100 100\" data-kid=\"38\">\n            <circle cx=\"50\" cy=\"50\" r=\"44\" fill=\"none\" stroke=\"rgba(255,255,255,0.03)\" stroke-width=\"6\" data-kid=\"39\"></circle>\n            <circle cx=\"50\" cy=\"50\" r=\"44\" fill=\"none\" stroke=\"url(#scoreGrad)\" stroke-width=\"6\" stroke-dasharray=\"276\" stroke-dashoffset=\"44\" stroke-linecap=\"round\" class=\"transition-all duration-1000 ease-out\" data-kid=\"40\"></circle>\n            <defs data-kid=\"41\">\n              <linearGradient id=\"scoreGrad\" x1=\"0%\" y1=\"0%\" x2=\"100%\" y2=\"100%\" data-kid=\"42\">\n                <stop offset=\"0%\" stop-color=\"#8b5cf6\" data-kid=\"43\"></stop>\n                <stop offset=\"100%\" stop-color=\"#67e8f9\" data-kid=\"44\"></stop>\n              </linearGradient>\n            </defs>\n          </svg>\n          <div class=\"absolute inset-0 flex flex-col items-center justify-center\" data-kid=\"45\">\n            <span class=\"text-7xl font-bold font-[var(--k-font-family-heading)] tracking-tighter\" data-kid=\"46\">84</span>\n            <span class=\"text-xs text-[var(--k-color-text-secondary)] font-bold tracking-[0.3em] uppercase mt-[-5px]\" data-kid=\"47\">Score</span>\n          </div>\n        </div>\n        \n        <div class=\"text-center space-y-4\" data-kid=\"48\">\n          <div class=\"inline-flex items-center gap-2 px-4 py-1.5 bg-[var(--k-color-success)]/10 text-[var(--k-color-success)] rounded-full border border-[var(--k-color-success)]/20 text-xs font-bold uppercase tracking-widest\" data-kid=\"49\">\n            <i class=\"ti ti-circle-check-filled\" data-kid=\"50\"></i>\n            Highly Recommended\n          </div>\n          <p class=\"text-[var(--k-color-text-secondary)] text-sm px-6\" data-kid=\"51\">\n            You are in the <span class=\"text-white font-bold\" data-kid=\"52\">top 4%</span> of all candidates interviewed for this role this quarter.\n          </p>\n        </div>\n      </div>\n    </div>\n  </div>\n\n  \n  <div class=\"grid grid-cols-1 md:grid-cols-2 gap-8 mb-12\" data-kid=\"53\">\n    \n    <div class=\"space-y-6\" data-kid=\"54\">\n      <div class=\"flex items-center justify-between border-b border-white/5 pb-4\" data-kid=\"55\">\n        <h2 class=\"text-2xl font-[var(--k-font-family-heading)] font-bold flex items-center gap-3\" data-kid=\"56\">\n          <div class=\"w-10 h-10 rounded-xl bg-[var(--k-color-success)]/10 flex items-center justify-center text-[var(--k-color-success)]\" data-kid=\"57\">\n            <i class=\"ti ti-discount-check text-2xl\" data-kid=\"58\"></i>\n          </div>\n          AI-Identified <span class=\"text-[var(--k-color-success)]\" data-kid=\"59\">Strengths</span>\n        </h2>\n        <span class=\"text-[10px] font-bold text-[var(--k-color-text-muted)] uppercase tracking-widest\" data-kid=\"60\">4 Observations</span>\n      </div>\n\n      <div class=\"grid gap-4\" data-kid=\"61\">\n        <div class=\"p-6 bg-white/3 border border-white/5 rounded-[var(--k-radius-xl)] relative group hover:bg-white/5 transition-all\" data-kid=\"62\">\n          <div class=\"flex justify-between items-start mb-3\" data-kid=\"63\">\n            <h4 class=\"text-lg font-bold text-white\" data-kid=\"64\">System Design Intuition</h4>\n            <span class=\"px-2 py-0.5 rounded bg-[var(--k-color-success)]/10 text-[var(--k-color-success)] text-[10px] font-bold uppercase tracking-widest\" data-kid=\"65\">Expert Level</span>\n          </div>\n          <p class=\"text-[var(--k-color-text-secondary)] text-sm leading-relaxed mb-4\" data-kid=\"66\">\n            Excellent grasp of distributed systems. Your explanation of eventual consistency in high-load scenarios was both theoretically sound and practically applicable.\n          </p>\n          <div class=\"flex gap-2\" data-kid=\"67\">\n            <span class=\"px-2 py-1 rounded-md bg-white/5 text-[var(--k-color-text-muted)] text-[10px] font-medium border border-white/5\" data-kid=\"68\">Scalability</span>\n            <span class=\"px-2 py-1 rounded-md bg-white/5 text-[var(--k-color-text-muted)] text-[10px] font-medium border border-white/5\" data-kid=\"69\">DB Sharding</span>\n          </div>\n        </div>\n\n        <div class=\"p-6 bg-white/3 border border-white/5 rounded-[var(--k-radius-xl)] relative group hover:bg-white/5 transition-all\" data-kid=\"70\">\n          <div class=\"flex justify-between items-start mb-3\" data-kid=\"71\">\n            <h4 class=\"text-lg font-bold text-white\" data-kid=\"72\">Communication & Empathy</h4>\n            <span class=\"px-2 py-0.5 rounded bg-[var(--k-color-success)]/10 text-[var(--k-color-success)] text-[10px] font-bold uppercase tracking-widest\" data-kid=\"73\">Strong</span>\n          </div>\n          <p class=\"text-[var(--k-color-text-secondary)] text-sm leading-relaxed mb-4\" data-kid=\"74\">\n            Successfully translated complex technical concepts into business value metrics. Shown high adaptability when the interviewer pivoted requirements mid-discussion.\n          </p>\n          <div class=\"flex gap-2\" data-kid=\"75\">\n            <span class=\"px-2 py-1 rounded-md bg-white/5 text-[var(--k-color-text-muted)] text-[10px] font-medium border border-white/5\" data-kid=\"76\">Stakeholder Mgt</span>\n            <span class=\"px-2 py-1 rounded-md bg-white/5 text-[var(--k-color-text-muted)] text-[10px] font-medium border border-white/5\" data-kid=\"77\">Adaptability</span>\n          </div>\n        </div>\n      </div>\n    </div>\n\n    \n    <div class=\"space-y-6\" data-kid=\"78\">\n      <div class=\"flex items-center justify-between border-b border-white/5 pb-4\" data-kid=\"79\">\n        <h2 class=\"text-2xl font-[var(--k-font-family-heading)] font-bold flex items-center gap-3\" data-kid=\"80\">\n          <div class=\"w-10 h-10 rounded-xl bg-[var(--k-color-warning)]/10 flex items-center justify-center text-[var(--k-color-warning)]\" data-kid=\"81\">\n            <i class=\"ti ti-flame text-2xl\" data-kid=\"82\"></i>\n          </div>\n          Growth <span class=\"text-[var(--k-color-warning)]\" data-kid=\"83\">Areas</span>\n        </h2>\n        <span class=\"text-[10px] font-bold text-[var(--k-color-text-muted)] uppercase tracking-widest\" data-kid=\"84\">2 Recommendations</span>\n      </div>\n\n      <div class=\"grid gap-4\" data-kid=\"85\">\n        <div class=\"p-6 bg-white/3 border border-white/5 rounded-[var(--k-radius-xl)] relative group hover:bg-white/5 transition-all border-l-2 border-l-[var(--k-color-warning)]/30\" data-kid=\"86\">\n          <div class=\"flex justify-between items-start mb-3\" data-kid=\"87\">\n            <h4 class=\"text-lg font-bold text-white text-[var(--k-color-warning)]\" data-kid=\"88\">API Performance Nuances</h4>\n            <span class=\"px-2 py-0.5 rounded bg-[var(--k-color-warning)]/10 text-[var(--k-color-warning)] text-[10px] font-bold uppercase tracking-widest\" data-kid=\"89\">Needs Review</span>\n          </div>\n          <p class=\"text-[var(--k-color-text-secondary)] text-sm leading-relaxed mb-4\" data-kid=\"90\">\n            A bit hazy on the latest HTTP/3 prioritization and header compression techniques. Reviewing QUIC protocol implementation would bolster your network stack knowledge.\n          </p>\n          <div class=\"flex items-center gap-2 text-[var(--k-color-accent)] text-xs font-bold\" data-kid=\"91\">\n            <i class=\"ti ti-arrow-right\" data-kid=\"92\"></i>\n            Suggested Course: Advanced Networking for Web\n          </div>\n        </div>\n\n        <div class=\"p-6 bg-white/3 border border-white/5 rounded-[var(--k-radius-xl)] relative group hover:bg-white/5 transition-all border-l-2 border-l-[var(--k-color-error)]/30\" data-kid=\"93\">\n          <div class=\"flex justify-between items-start mb-3\" data-kid=\"94\">\n            <h4 class=\"text-lg font-bold text-white text-[var(--k-color-error)]\" data-kid=\"95\">Unit Testing Edge Cases</h4>\n            <span class=\"px-2 py-0.5 rounded bg-[var(--k-color-error)]/10 text-[var(--k-color-error)] text-[10px] font-bold uppercase tracking-widest\" data-kid=\"96\">Critical</span>\n          </div>\n          <p class=\"text-[var(--k-color-text-secondary)] text-sm leading-relaxed mb-4\" data-kid=\"97\">\n            Missed a few boundary conditions in the coding challenge (negative inputs, extremely large arrays). Aim for more defensive coding practices under pressure.\n          </p>\n          <div class=\"flex items-center gap-2 text-[var(--k-color-accent)] text-xs font-bold\" data-kid=\"98\">\n            <i class=\"ti ti-arrow-right\" data-kid=\"99\"></i>\n            Suggested Practice: LeetCode Defensive Coding Tag\n          </div>\n        </div>\n      </div>\n    </div>\n  </div>\n\n  \n  <section class=\"bg-linear-to-r from-[var(--k-color-primary)]/10 via-transparent to-transparent border border-white/5 rounded-[var(--k-radius-2xl)] p-8 mb-12 relative overflow-hidden group\" data-kid=\"100\">\n    <div class=\"absolute top-0 right-0 p-8 opacity-10\" data-kid=\"101\">\n      <i class=\"ti ti-brain text-9xl\" data-kid=\"102\"></i>\n    </div>\n    \n    <div class=\"flex flex-col lg:flex-row gap-12 relative z-10\" data-kid=\"103\">\n      <div class=\"lg:w-2/3 space-y-6\" data-kid=\"104\">\n        <div class=\"inline-flex items-center gap-2 px-3 py-1 bg-white/5 rounded-full border border-white/10 text-[10px] font-bold uppercase tracking-[0.2em] text-[var(--k-color-primary)]\" data-kid=\"105\">\n          <span class=\"relative flex h-2 w-2\" data-kid=\"106\">\n            <span class=\"animate-ping absolute inline-flex h-full w-full rounded-full bg-[var(--k-color-primary)] opacity-75\" data-kid=\"107\"></span>\n            <span class=\"relative inline-flex rounded-full h-2 w-2 bg-[var(--k-color-primary)]\" data-kid=\"108\"></span>\n          </span>\n          AI Sentiment Analysis\n        </div>\n        <h2 class=\"text-3xl font-[var(--k-font-family-heading)] font-bold\" data-kid=\"109\">Executive <span class=\"text-white\" data-kid=\"110\">Summary</span></h2>\n        <p class=\"text-[var(--k-color-text-secondary)] leading-relaxed text-lg\" data-kid=\"111\">\n          The candidate exhibits a rare blend of deep technical architectural knowledge and high-emotional intelligence. Throughout the 60-minute session, their confidence remained stable even when challenged. The AI predicts a <span class=\"text-[var(--k-color-accent)] font-bold italic\" data-kid=\"112\">92% culture-fit probability</span> for the current Engineering Lead role.\n        </p>\n        <div class=\"flex flex-wrap gap-4\" data-kid=\"113\">\n          <div class=\"flex items-center gap-2 text-sm text-white font-medium\" data-kid=\"114\">\n            <i class=\"ti ti-clock text-[var(--k-color-primary)]\" data-kid=\"115\"></i>\n            Avg Response Time: 42s\n          </div>\n          <div class=\"flex items-center gap-2 text-sm text-white font-medium\" data-kid=\"116\">\n            <i class=\"ti ti-microphone text-[var(--k-color-primary)]\" data-kid=\"117\"></i>\n            Fluency Score: 9/10\n          </div>\n          <div class=\"flex items-center gap-2 text-sm text-white font-medium\" data-kid=\"118\">\n            <i class=\"ti ti-activity text-[var(--k-color-primary)]\" data-kid=\"119\"></i>\n            Confidence Level: Very High\n          </div>\n        </div>\n      </div>\n      \n      <div class=\"lg:w-1/3 flex items-center\" data-kid=\"120\">\n        <div class=\"w-full p-6 bg-white/5 border border-white/10 rounded-[var(--k-radius-xl)] backdrop-blur-sm\" data-kid=\"121\">\n          <h4 class=\"text-sm font-bold uppercase tracking-widest text-white mb-4\" data-kid=\"122\">Recommended Next Step</h4>\n          <p class=\"text-xs text-[var(--k-color-text-secondary)] mb-6\" data-kid=\"123\">Based on your performance, we recommend skipping the technical screening 2 and moving directly to the CTO interview.</p>\n          <button class=\"w-full py-3 bg-white text-black font-bold rounded-[var(--k-radius-md)] hover:bg-white/90 transition-all flex items-center justify-center gap-2 uppercase tracking-tighter text-sm\" data-kid=\"124\">\n            Schedule CTO Round\n            <i class=\"ti ti-arrow-right\" data-kid=\"125\"></i>\n          </button>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <footer class=\"flex flex-col md:flex-row justify-between items-center py-8 border-t border-white/5 text-[var(--k-color-text-muted)] text-[10px] font-bold uppercase tracking-[0.3em] gap-4\" data-kid=\"126\">\n    <div class=\"flex items-center gap-4\" data-kid=\"127\">\n      <span data-kid=\"128\">AI Model v4.2.0-Alpha</span>\n      <span class=\"w-1 h-1 rounded-full bg-white/20\" data-kid=\"129\"></span>\n      <span data-kid=\"130\">GDPR Compliant Data</span>\n    </div>\n    <div data-kid=\"131\">\n      © 2026 INTERVIEW.AI SYSTEMS\n    </div>\n  </footer>\n</div>\n\n\n<script src=\"https://cdn.jsdelivr.net/npm/chart.js\" data-kid=\"132\"></script>\n<script data-kid=\"133\">\ndocument.addEventListener('DOMContentLoaded', function() {\n  const ctx = document.getElementById('skillRadar').getContext('2d');\n  \n  // Custom font loading check (optional but good practice)\n  const isDark = true;\n  const textColor = '#94a3b8';\n  const gridColor = 'rgba(255, 255, 255, 0.05)';\n  const primaryColor = '#8b5cf6';\n  const accentColor = '#67e8f9';\n\n  new Chart(ctx, {\n    type: 'radar',\n    data: {\n      labels: [\n        'Problem Solving', \n        'System Design', \n        'Code Quality', \n        'Algorithms', \n        'Communication', \n        'Leadership', \n        'Teamwork', \n        'Product Mindset'\n      ],\n      datasets: [\n        {\n          label: 'Technical',\n          data: [85, 95, 78, 82, 0, 0, 0, 0],\n          fill: true,\n          backgroundColor: 'rgba(139, 92, 246, 0.2)',\n          borderColor: '#8b5cf6',\n          pointBackgroundColor: '#8b5cf6',\n          pointBorderColor: '#fff',\n          pointHoverBackgroundColor: '#fff',\n          pointHoverBorderColor: '#8b5cf6',\n          borderWidth: 2,\n          tension: 0.1\n        },\n        {\n          label: 'Soft Skills',\n          data: [0, 0, 0, 0, 92, 85, 88, 75],\n          fill: true,\n          backgroundColor: 'rgba(103, 232, 249, 0.2)',\n          borderColor: '#67e8f9',\n          pointBackgroundColor: '#67e8f9',\n          pointBorderColor: '#fff',\n          pointHoverBackgroundColor: '#fff',\n          pointHoverBorderColor: '#67e8f9',\n          borderWidth: 2,\n          tension: 0.1\n        }\n      ]\n    },\n    options: {\n      elements: {\n        line: { borderWidth: 3 }\n      },\n      scales: {\n        r: {\n          angleLines: { color: gridColor },\n          grid: { color: gridColor },\n          pointLabels: {\n            color: textColor,\n            font: {\n              family: 'Space Grotesk',\n              size: 11,\n              weight: 'bold'\n            }\n          },\n          ticks: {\n            display: false,\n            stepSize: 20\n          },\n          suggestedMin: 0,\n          suggestedMax: 100\n        }\n      },\n      plugins: {\n        legend: { display: false }\n      },\n      responsive: true,\n      maintainAspectRatio: false\n    }\n  });\n});\n</script>\n\n<style data-kid=\"134\">\n  @import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Inter:wght@400;500;600;700&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n  :root {\n    --color-primary: #8b5cf6;\n  }\n\n  /* Custom Scrollbar */\n  ::-webkit-scrollbar {\n    width: 6px;\n  }\n  ::-webkit-scrollbar-track {\n    background: #080812;\n  }\n  ::-webkit-scrollbar-thumb {\n    background: #1e1b4b;\n    border-radius: 10px;\n  }\n  ::-webkit-scrollbar-thumb:hover {\n    background: #8b5cf6;\n  }\n\n  .font-heading {\n    font-family: 'Space Grotesk', sans-serif;\n  }\n</style>\n",
