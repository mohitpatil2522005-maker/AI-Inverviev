a2.828 2.828 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5L17 3z\" data-kid=\"87\"></path></svg>\n          </div>\n          <div class=\"grow space-y-2\" data-kid=\"88\">\n            <div class=\"flex justify-between text-sm\" data-kid=\"89\">\n              <span class=\"text-[var(--k-color-text-primary)] font-medium\" data-kid=\"90\">Formatting</span>\n              <span class=\"text-[var(--k-color-success)] font-bold\" data-kid=\"91\">95%</span>\n            </div>\n            <div class=\"h-2 bg-[var(--k-color-border)] rounded-full overflow-hidden\" data-kid=\"92\">\n              <div class=\"h-full bg-[var(--k-color-success)] rounded-full shadow-[0_0_10px_var(--k-color-success)]/30\" style=\"width: 95%\" data-kid=\"93\"></div>\n            </div>\n          </div>\n        </div>\n        \n        <div class=\"flex gap-4\" data-kid=\"94\">\n          <div class=\"w-10 h-10 rounded-lg bg-[var(--k-color-bg-surface-hover)] flex items-center justify-center shrink-0\" data-kid=\"95\">\n            <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"var(--k-color-text-muted)\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" data-kid=\"96\"><polyline points=\"20 6 9 17 4 12\" data-kid=\"97\"></polyline></svg>\n          </div>\n          <div class=\"grow space-y-2\" data-kid=\"98\">\n            <div class=\"flex justify-between text-sm\" data-kid=\"99\">\n              <span class=\"text-[var(--k-color-text-primary)] font-medium\" data-kid=\"100\">Achievements</span>\n              <span class=\"text-[var(--k-color-warning)] font-bold\" data-kid=\"101\">71%</span>\n            </div>\n            <div class=\"h-2 bg-[var(--k-color-border)] rounded-full overflow-hidden\" data-kid=\"102\">\n              <div class=\"h-full bg-[var(--k-color-warning)] rounded-full shadow-[0_0_10px_var(--k-color-warning)]/30\" style=\"width: 71%\" data-kid=\"103\"></div>\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n  </div>\n\n  \n  <div class=\"grid grid-cols-1 lg:grid-cols-3 gap-6\" data-kid=\"104\">\n    \n    <div class=\"lg:col-span-2 glass-card overflow-hidden flex flex-col\" data-kid=\"105\">\n      <div class=\"flex bg-[var(--k-color-bg-surface-hover)] border-b border-[var(--k-color-border)]\" data-kid=\"106\">\n        <button class=\"px-8 py-4 text-sm font-bold tab-active bg-[var(--k-color-bg-surface)]\" data-kid=\"107\">Keywords</button>\n        <button class=\"px-8 py-4 text-sm font-semibold text-[var(--k-color-text-secondary)] hover:text-[var(--k-color-text-primary)] transition-colors border-b-2 border-transparent group/tab relative\" data-kid=\"108\">\n          Strengths\n          <span class=\"absolute top-4 right-4 w-1.5 h-1.5 rounded-full bg-[var(--k-color-success)] opacity-0 group-hover/tab:opacity-100 transition-opacity\" data-kid=\"109\"></span>\n        </button>\n        <button class=\"px-8 py-4 text-sm font-semibold text-[var(--k-color-text-secondary)] hover:text-[var(--k-color-text-primary)] transition-colors border-b-2 border-transparent group/tab relative\" data-kid=\"110\">\n          Weaknesses\n          <span class=\"absolute top-4 right-4 w-1.5 h-1.5 rounded-full bg-[var(--k-color-error)] opacity-0 group-hover/tab:opacity-100 transition-opacity\" data-kid=\"111\"></span>\n        </button>\n        <button class=\"px-8 py-4 text-sm font-semibold text-[var(--k-color-text-secondary)] hover:text-[var(--k-color-text-primary)] transition-colors border-b-2 border-transparent group/tab relative\" data-kid=\"112\">\n          Suggestions\n          <span class=\"absolute top-4 right-4 w-1.5 h-1.5 rounded-full bg-[var(--k-color-primary)] opacity-0 group-hover/tab:opacity-100 transition-opacity\" data-kid=\"113\"></span>\n        </button>\n      </div>\n      <div class=\"p-8 space-y-8 flex-1\" data-kid=\"114\">\n        \n        <div data-kid=\"115\">\n          <div class=\"flex items-center gap-3 mb-4\" da