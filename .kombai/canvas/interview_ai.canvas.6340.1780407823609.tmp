      "html": "\n<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Space+Grotesk:wght@400;500;600;700&display=swap');\n\n  body {\n    background-color: var(--k-color-bg-page);\n    background-image: radial-gradient(circle at 50% -20%, var(--k-color-secondary) 0%, var(--k-color-bg-page) 70%);\n    color: var(--k-color-text-primary);\n    font-family: var(--k-font-family-body);\n    margin: 0;\n    padding: 0;\n  }\n\n  h1, h2, h3, h4 {\n    font-family: var(--k-font-family-heading);\n  }\n\n  .glass-card {\n    background: var(--k-color-bg-surface);\n    backdrop-filter: blur(20px);\n    -webkit-backdrop-filter: blur(20px);\n    border: var(--k-border-width-default) solid var(--k-color-border);\n    border-radius: var(--k-radius-xl);\n  }\n\n  .gradient-text {\n    background: linear-gradient(135deg, var(--k-color-primary), var(--k-color-secondary), var(--k-color-accent));\n    -webkit-background-clip: text;\n    background-clip: text;\n    -webkit-text-fill-color: transparent;\n  }\n\n  .neon-button {\n    background: linear-gradient(135deg, var(--k-color-primary), var(--k-color-primary-hover));\n    border: 1px solid var(--k-color-border-hover);\n    box-shadow: 0 0 20px rgba(139, 92, 246, 0.3);\n    color: var(--k-color-text-primary);\n    transition: all 0.2s ease;\n  }\n\n  .neon-button:hover {\n    box-shadow: 0 0 35px rgba(139, 92, 246, 0.5);\n    transform: translateY(-1px);\n  }\n\n  .score-ring-svg {\n    transform: rotate(-90deg);\n  }\n\n  .score-circle-bg {\n    fill: none;\n    stroke: var(--k-color-border);\n    stroke-width: 8;\n  }\n\n  .score-circle-progress {\n    fill: none;\n    stroke: var(--k-color-primary);\n    stroke-width: 8;\n    stroke-linecap: round;\n    stroke-dasharray: 414.69;\n    stroke-dashoffset: 87.08; /* (1 - 0.79) * 414.69 */\n    filter: drop-shadow(0 0 12px var(--k-color-primary));\n  }\n\n  .score-glow-aura {\n    fill: var(--k-color-primary);\n    opacity: 0.05;\n    filter: blur(15px);\n  }\n\n  @keyframes scanLine {\n    0% { top: -2%; opacity: 0; }\n    10% { opacity: 1; }\n    90% { opacity: 1; }\n    100% { top: 102%; opacity: 0; }\n  }\n\n  .scanning-line {\n    position: absolute;\n    left: 0;\n    right: 0;\n    height: 2px;\n    background: var(--k-color-primary);\n    box-shadow: 0 0 15px var(--k-color-primary);\n    animation: scanLine 3s linear infinite;\n    pointer-events: none;\n    z-index: 10;\n  }\n\n  @keyframes float {\n    0%, 100% { transform: translateY(0px); }\n    50% { transform: translateY(-10px); }\n  }\n\n  .animate-float {\n    animation: float 6s ease-in-out infinite;\n  }\n\n  .tab-active {\n    border-bottom: 2px solid var(--k-color-primary);\n    color: var(--k-color-text-primary);\n  }\n\n  .scrollbar-hide::-webkit-scrollbar {\n    display: none;\n  }\n  .scrollbar-hide {\n    -ms-overflow-style: none;\n    scrollbar-width: none;\n  }\n</style>\n\n<div class=\"p-4 md:p-8 lg:p-12 max-w-7xl mx-auto space-y-8 relative overflow-hidden\" data-kid=\"1\">\n  \n  <div class=\"absolute inset-0 opacity-[0.03] pointer-events-none\" style=\"background-image: radial-gradient(var(--k-color-text-primary) 1px, transparent 1px); background-size: 40px 40px;\" data-kid=\"2\"></div>\n  \n  <header class=\"flex flex-col md:flex-row md:items-end justify-between gap-4\" data-kid=\"3\">\n    <div data-kid=\"4\">\n      <h1 class=\"text-3xl md:text-4xl font-black text-[var(--k-color-text-primary)]\" data-kid=\"5\">Resume <span class=\"gradient-text\" data-kid=\"6\">Analyzer</span></h1>\n      <p class=\"text-[var(--k-color-text-secondary)] mt-2 max-w-lg\" data-kid=\"7\">\n        AI-powered ATS optimization and personalized career suggestions for the modern job market.\n      </p>\n    </div>\n    <div class=\"flex items-center gap-3\" data-kid=\"8\">\n      <button class=\"px-6 py-2.5 rounded-xl border border-[var(--k-color-border)] text-sm font-semibold text-[var(--k-color-text-secondary)] hover:bg-[var(--k-color-bg-surface-hover)] transition-colors flex items-center gap-2 cursor-pointer\" data-kid=\"9\">\n        <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" data-kid=\"10\"><path d=\"M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4\" data-kid=\"11\"></path><polyline points=\"7 10 12 15 17 10\" data-kid=\"12\"></polyline><line x1=\"12\" x2=\"12\" y1=\"15\" y2=\"3\" data-kid=\"13\"></line></svg>\n        Download Report\n      </button>\n      <button class=\"bg-[var(--k-color-bg-surface-hover)] hover:bg-[var(--k-color-bg-surface)] px-6 py-2.5 rounded-xl text-sm font-bold text-[var(--k-color-primary)] flex items-center gap-2 transition-all border border-[var(--k-color-border)] cursor-pointer\" data-kid=\"14\">\n        <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" data-kid=\"15\"><path d=\"M23 4v6h-6\" data-kid=\"16\"></path><path d=\"M20.49 15a9 9 0 1 1-2.12-9.36L23 10\" data-kid=\"17\"></path></svg>\n        New Scan\n      </button>\n    </div>\n  </header>\n\n  \n  <div class=\"grid grid-cols-1 lg:grid-cols-3 gap-6\" data-kid=\"18\">\n    \n    <div class=\"glass-card p-8 flex flex-col items-center justify-center text-center border-[var(--k-color-primary)]/30 shadow-[0_0_50px_rgba(139,92,246,0.1)]\" data-kid=\"19\">\n      <div class=\"relative w-40 h-40 flex items-center justify-center mb-6\" data-kid=\"20\">\n        <svg width=\"160\" height=\"160\" class=\"score-ring-svg\" data-kid=\"21\">\n          <circle cx=\"80\" cy=\"80\" r=\"66\" class=\"score-circle-bg\" data-kid=\"22\"></circle>\n          <circle cx=\"80\" cy=\"80\" r=\"66\" class=\"score-circle-progress\" data-kid=\"23\"></circle>\n          <circle cx=\"80\" cy=\"80\" r=\"60\" class=\"score-glow-aura\" data-kid=\"24\"></circle>\n        </svg>\n        <div class=\"absolute flex flex-col items-center\" data-kid=\"25\">\n          <span class=\"text-5xl font-black text-[var(--k-color-text-primary)]\" data-kid=\"26\">79</span>\n          <span class=\"text-xs text-[var(--k-color-text-secondary)] font-medium uppercase tracking-wider\" data-kid=\"27\">ATS Score</span>\n        </div>\n      </div>\n      <div class=\"flex gap-2\" data-kid=\"28\">\n        <span class=\"px-3 py-1 text-xs font-bold rounded-full bg-[var(--k-color-success)]/15 text-[var(--k-color-success)] border border-[var(--k-color-success)]/20\" data-kid=\"29\">Good</span>\n        <span class=\"px-3 py-1 text-xs font-bold rounded-full bg-[var(--k-color-warning)]/15 text-[var(--k-color-warning)] border border-[var(--k-color-warning)]/20\" data-kid=\"30\">+12 pts possible</span>\n      </div>\n      <p class=\"text-sm mt-4 text-[var(--k-color-text-muted)]\" data-kid=\"31\">Matched with: <span class=\"text-[var(--k-color-text-primary)] font-medium\" data-kid=\"32\">Senior Product Designer</span></p>\n    </div>\n\n    \n    <div class=\"lg:col-span-2 glass-card p-8\" data-kid=\"33\">\n      <div class=\"flex items-center justify-between mb-8\" data-kid=\"34\">\n        <h2 class=\"text-xl font-bold text-[var(--k-color-text-primary)] flex items-center gap-2\" data-kid=\"35\">\n          <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"text-[var(--k-color-primary)]\" data-kid=\"36\"><path d=\"M12 20v-6M6 20V10M18 20V4\" data-kid=\"37\"></path></svg>\n          Detailed Breakdown\n        </h2>\n        <span class=\"text-xs text-[var(--k-color-text-secondary)] font-medium bg-[var(--k-color-border)] px-2 py-1 rounded\" data-kid=\"38\">Compared to 1.2k profiles</span>\n      </div>\n      <div class=\"grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-8\" data-kid=\"39\">\n        \n        <div class=\"flex gap-5\" data-kid=\"40\">\n          <div class=\"w-11 h-11 rounded-xl bg-[var(--k-color-bg-surface-hover)] border border-[var(--k-color-border)] flex items-center justify-center shrink-0 shadow-sm\" data-kid=\"41\">\n            <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"var(--k-color-primary)\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" data-kid=\"42\"><rect x=\"2\" y=\"7\" width=\"20\" height=\"14\" rx=\"2\" ry=\"2\" data-kid=\"43\"></rect><path d=\"M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16\" data-kid=\"44\"></path></svg>\n          </div>\n          <div class=\"grow space-y-2.5\" data-kid=\"45\">\n            <div class=\"flex justify-between text-sm\" data-kid=\"46\">\n              <span class=\"text-[var(--k-color-text-primary)] font-semibold\" data-kid=\"47\">Work Experience</span>\n              <span class=\"text-[var(--k-color-success)] font-black tracking-tight\" data-kid=\"48\">88%</span>\n            </div>\n            <div class=\"h-2 bg-[var(--k-color-border)] rounded-full overflow-hidden\" data-kid=\"49\">\n              <div class=\"h-full bg-[var(--k-color-success)] rounded-full shadow-[0_0_10px_var(--k-color-success)]/40\" style=\"width: 88%\" data-kid=\"50\"></div>\n            </div>\n          </div>\n        </div>\n        \n        <div class=\"flex gap-5\" data-kid=\"51\">\n          <div class=\"w-11 h-11 rounded-xl bg-[var(--k-color-bg-surface-hover)] border border-[var(--k-color-border)] flex items-center justify-center shrink-0 shadow-sm\" data-kid=\"52\">\n            <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"var(--k-color-primary)\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" data-kid=\"53\"><circle cx=\"12\" cy=\"12\" r=\"10\" data-kid=\"54\"></circle><circle cx=\"12\" cy=\"12\" r