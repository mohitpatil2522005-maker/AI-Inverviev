      "html": "\n<div class=\"bg-[#080812] text-[#f8fafc] font-sans p-4 md:p-8 space-y-8 relative overflow-hidden\" data-kid=\"0\">\n  <div class=\"absolute inset-0 opacity-[0.03] pointer-events-none\" style=\"background-image: radial-gradient(#8b5cf6 1px, transparent 1px); background-size: 32px 32px;\" data-kid=\"1\"></div>\n  <style data-kid=\"2\">\n    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Space+Grotesk:wght@400;500;600;700&display=swap');\n\n    :root {\n      --bg-base: #080812;\n      --bg-surface: #0d0d1f;\n      --bg-card: #111128;\n      --primary: #8b5cf6;\n      --secondary: #3b82f6;\n      --accent: #06b6d4;\n      --success: #10b981;\n      --danger: #ef4444;\n      --font-heading: \"Space Grotesk\", sans-serif;\n      --font-sans: \"Inter\", sans-serif;\n    }\n\n    .glass-card {\n      background: rgba(255, 255, 255, 0.03);\n      backdrop-filter: blur(20px);\n      -webkit-backdrop-filter: blur(20px);\n      border: 1px solid rgba(255, 255, 255, 0.06);\n      border-radius: 1rem;\n    }\n\n    .glass-card-hover {\n      transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);\n    }\n    .glass-card-hover:hover {\n      background: rgba(255, 255, 255, 0.06);\n      border-color: rgba(139, 92, 246, 0.4);\n      box-shadow: 0 0 40px rgba(139, 92, 246, 0.2), inset 0 0 20px rgba(139, 92, 246, 0.05);\n      transform: translateY(-4px);\n    }\n\n    .neon-button {\n      background: linear-gradient(135deg, #8b5cf6, #6d28d9);\n      border: 1px solid rgba(139, 92, 246, 0.5);\n      box-shadow: 0 0 20px rgba(139, 92, 246, 0.3);\n      color: white;\n      font-weight: 600;\n      transition: all 0.2s ease;\n    }\n    .neon-button:hover {\n      box-shadow: 0 0 35px rgba(139, 92, 246, 0.5);\n      transform: translateY(-1px);\n    }\n\n    .font-heading { font-family: var(--font-heading); }\n    .font-sans { font-family: var(--font-sans); }\n\n    .chart-container {\n      width: 100%;\n      height: 100%;\n    }\n\n    /* Custom Scrollbar */\n    ::-webkit-scrollbar { width: 6px; }\n    ::-webkit-scrollbar-track { background: var(--bg-surface); }\n    ::-webkit-scrollbar-thumb { background: rgba(139, 92, 246, 0.4); border-radius: 3px; }\n\n    @keyframes fadeIn {\n      from { opacity: 0; transform: translateY(10px); }\n      to { opacity: 1; transform: translateY(0); }\n    }\n    .animate-in { animation: fadeIn 0.5s ease-out forwards; }\n\n    @keyframes glowPulse {\n      0%, 100% { filter: drop-shadow(0 0 12px rgba(139,92,246,0.6)); }\n      50% { filter: drop-shadow(0 0 20px rgba(139,92,246,0.9)); }\n    }\n    .animate-glow-pulse { animation: glowPulse 3s ease-in-out infinite; }\n  </style>\n\n  \n  <script src=\"https://cdn.jsdelivr.net/npm/apexcharts\" data-kid=\"3\"></script>\n  <script src=\"https://unpkg.com/lucide@latest\" data-kid=\"4\"></script>\n\n  <div class=\"max-w-7xl mx-auto space-y-8 pb-12\" data-kid=\"5\">\n    \n    <header class=\"flex flex-col md:flex-row md:items-center justify-between gap-6 animate-in\" data-kid=\"6\">\n      <div data-kid=\"7\">\n        <h1 class=\"text-4xl md:text-5xl font-black text-white font-heading tracking-tight leading-none\" data-kid=\"8\">Interview <span class=\"text-transparent bg-clip-text bg-gradient-to-r from-violet-400 to-indigo-400\" data-kid=\"9\">Feedback</span> Report</h1>\n        <p class=\"text-slate-400 mt-3 font-medium flex items-center gap-2 text-sm\" data-kid=\"10\">\n          <span class=\"flex items-center gap-1.5 bg-white/5 px-3 py-1 rounded-full border border-white/10\" data-kid=\"11\">\n            <i data-lucide=\"calendar\" class=\"w-3.5 h-3.5 text-violet-400\" data-kid=\"12\"></i>\n            Software Engineer Interview\n          </span>\n          <span class=\"text-slate-600\" data-kid=\"13\">•</span>\n          <span class=\"text-slate-500\" data-kid=\"14\">May 27, 2026</span>\n        </p>\n      </div>\n      <div class=\"flex flex-wrap items-center gap-3\" data-kid=\"15\">\n        <button class=\"px-4 py-2 rounded-lg glass-card text-sm font-semibold flex items-center gap-2 border border-white/10 hover:bg-white/5 transition-colors\" data-kid=\"16\">\n          <i data-lucide=\"download\" class=\"w-4 h-4\" data-kid=\"17\"></i> Download PDF\n        </button>\n        <button class=\"px-4 py-2 rounded-lg glass-card text-sm font-semibold flex items-center gap-2 border border-white/10 hover:bg-white/5 transition-colors\" data-kid=\"18\">\n          <i data-lucide=\"linkedin\" class=\"w-4 h-4 text-blue-400\" data-kid=\"19\"></i> Share on LinkedIn\n        </button>\n        <button class=\"neon-button px-5 py-2 rounded-lg text-sm font-bold flex items-center gap-2 shadow-lg\" data-kid=\"20\">\n          <i data-lucide=\"share-2\" class=\"w-4 h-4\" data-kid=\"21\"></i> Share Report\n        </button>\n      </div>\n    </header>\n\n    \n    <div class=\"grid grid-cols-1 lg:grid-cols-3 gap-6\" data-kid=\"22\">\n      \n      <div class=\"glass-card p-10 flex flex-col items-center justify-center text-center animate-in relative overflow-hidden\" style=\"animation-delay: 0.1s\" data-kid=\"23\">\n        <div class=\"absolute top-0 right-0 p-4 opacity-10\" data-kid=\"24\">\n          <i data-lucide=\"shield-check\" class=\"w-20 h-20 text-white\" data-kid=\"25\"></i>\n        </div>\n        <div class=\"relative w-52 h-52 flex items-center justify-center mb-10\" data-kid=\"26\">\n          \n          <div class=\"absolute inset-0 rounded-full bg-violet-500/10 blur-2xl\" data-kid=\"27\"></div>\n          <svg class=\"w-full h-full transform -rotate-90 relative z-10\" data-kid=\"28\">\n            <circle cx=\"104\" cy=\"104\" r=\"92\" stroke=\"rgba(255,255,255,0.03)\" stroke-width=\"14\" fill=\"transparent\" data-kid=\"29\"></circle>\n            <circle cx=\"104\" cy=\"104\" r=\"92\" stroke=\"var(--primary)\" stroke-width=\"14\" fill=\"transparent\" stroke-dasharray=\"578\" stroke-dashoffset=\"92.5\" stroke-linecap=\"round\" class=\"animate-glow-pul