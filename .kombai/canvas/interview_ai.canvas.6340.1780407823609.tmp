      "html": "\n<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Space+Grotesk:wght@400;500;600;700&display=swap');\n\n  :root {\n    --bg-base: #080812;\n    --bg-surface: #0d0d1f;\n    --bg-card: #111128;\n    --bg-card-hover: #16163a;\n    --border-subtle: rgba(255, 255, 255, 0.06);\n    --border-glow: rgba(139, 92, 246, 0.3);\n    --text-base: #f8fafc;\n    --text-muted: #94a3b8;\n    --text-faint: #475569;\n    --primary: #8b5cf6;\n    --primary-glow: rgba(139, 92, 246, 0.4);\n    --secondary: #3b82f6;\n    --accent: #06b6d4;\n    --success: #10b981;\n    --warning: #f59e0b;\n    --danger: #ef4444;\n    --font-sans: \"Inter\", system-ui, sans-serif;\n    --font-heading: \"Space Grotesk\", sans-serif;\n  }\n\n  body {\n    background-color: var(--bg-base);\n    color: var(--text-base);\n    font-family: var(--font-sans);\n    margin: 0;\n  }\n\n  .font-heading {\n    font-family: var(--font-heading);\n  }\n\n  .glass-card {\n    background: rgba(255, 255, 255, 0.03);\n    backdrop-filter: blur(20px);\n    -webkit-backdrop-filter: blur(20px);\n    border: 1px solid rgba(255, 255, 255, 0.06);\n    border-radius: 1rem;\n  }\n\n  .gradient-text {\n    background: linear-gradient(135deg, #c084fc, #818cf8, #67e8f9);\n    -webkit-background-clip: text;\n    background-clip: text;\n    -webkit-text-fill-color: transparent;\n  }\n\n  .neon-button {\n    background: linear-gradient(135deg, #8b5cf6, #6d28d9);\n    border: 1px solid rgba(139, 92, 246, 0.5);\n    box-shadow: 0 0 20px rgba(139, 92, 246, 0.3);\n    color: white;\n    font-weight: 600;\n    transition: all 0.2s ease;\n  }\n\n  .neon-button:hover:not(:disabled) {\n    box-shadow: 0 0 35px rgba(139, 92, 246, 0.5);\n    transform: translateY(-1px);\n  }\n\n  .neon-button:disabled {\n    opacity: 0.7;\n    cursor: not-allowed;\n  }\n\n  @keyframes float {\n    0%, 100% { transform: translateY(0px); }\n    50% { transform: translateY(-20px); }\n  }\n\n  @keyframes pulseGlow {\n    0%, 100% { box-shadow: 0 0 20px rgba(139, 92, 246, 0.3); }\n    50% { box-shadow: 0 0 50px rgba(139, 92, 246, 0.7); }\n  }\n\n  @keyframes orb-float {\n    0% { transform: translate(0, 0) scale(1); }\n    33% { transform: translate(30px, -50px) scale(1.1); }\n    66% { transform: translate(-20px, 20px) scale(0.9); }\n    100% { transform: translate(0, 0) scale(1); }\n  }\n\n  @keyframes waveform {\n    0%, 100% { height: 4px; }\n    50% { height: 20px; }\n  }\n\n  .animate-float { animation: float 6s ease-in-out infinite; }\n  .animate-orb { animation: orb-float 15s ease-in-out infinite; }\n  .animate-waveform { animation: waveform 0.8s ease-in-out infinite; }\n\n  .orb {\n    position: absolute;\n    border-radius: 50%;\n    filter: blur(80px);\n    z-index: 0;\n    opacity: 0.15;\n  }\n\n  /* Scrollbar Customization */\n  ::-webkit-scrollbar {\n    width: 6px;\n  }\n  ::-webkit-scrollbar-track {\n    background: var(--bg-surface);\n  }\n  ::-webkit-scrollbar-thumb {\n    background: rgba(139, 92, 246, 0.4);\n    border-radius: 3px;\n  }\n  ::-webkit-scrollbar-thumb:hover {\n    background: rgba(139, 92, 246, 0.7);\n  }\n\n  .input-field {\n    background: rgba(255, 255, 255, 0.04);\n    border: 1px solid rgba(255, 255, 255, 0.08);\n    color: #f8fafc;\n    transition: all 0.2s ease;\n  }\n\n  .input-field:focus {\n    outline: none;\n    border-color: #8b5cf6;\n    background: rgba(255, 255, 255, 0.06);\n    box-shadow: 0 0 0 2px rgba(139, 92, 246, 0.2);\n  }\n\n  .step-node.active {\n    background: linear-gradient(135deg, #8b5cf6, #3b82f6);\n    color: white;\n    box-shadow: 0 0 15px rgba(139, 92, 246, 0.5);\n  }\n\n  .step-node.completed {\n    background: linear-gradient(135deg, #8b5cf6, #3b82f6);\n    color: white;\n  }\n\n  .step-line.completed {\n    background: #8b5cf6;\n  }\n</style>\n\n<div class=\"flex min-h-[900px] w-full bg-[#080812] overflow-hidden\" data-kid=\"1\">\n  \n  \n  <div class=\"hidden lg:flex flex-1 relative items-center justify-center p-12 overflow-hidden\" style=\"background: linear-gradient(135deg, #0d0d1f 0%, #100a20 100%); border-right: 1px solid rgba(255,255,255,0.05);\" data-kid=\"2\">\n    \n    \n    <div class=\"orb w-96 h-96 bg-purple-600 top-[-10%] left-[-10%] animate-orb\" data-kid=\"3\"></div>\n    <div class=\"orb w-80 h-80 bg-blue-600 bottom-[-5%] right-[-5%] animate-orb\" style=\"animation-delay: -5s;\" data-kid=\"4\"></div>\n    <div class=\"orb w-64 h-64 bg-cyan-500 top-[20%] right-[10%] animate-orb\" style=\"animation-delay: -10s;\" data-kid=\"5\"></div>\n\n    <div class=\"max-w-md relative z-10 text-center\" data-kid=\"6\">\n      \n      <div class=\"w-24 h-24 rounded-3xl mb-10 mx-auto flex items-center justify-center animate-float\" style=\"background: linear-gradient(135deg, #8b5cf6, #3b82f6); box-shadow: 0 0 60px rgba(139,92,246,0.4);\" data-kid=\"7\">\n        <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"40\" height=\"40\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"text-white\" data-kid=\"8\"><path d=\"M13 2L3 14h9l-1 8 10-12h-9l1-8z\" data-kid=\"9\"></path></svg>\n      </div>\n\n      <h2 class=\"text-3xl font-black text-white mb-4 font-heading tracking-tight leading-tight\" data-kid=\"10\">\n        Your AI Interview Coach\n      </h2>\n      \n      <p class=\"text-sm leading-relaxed mb-8 text-[#94a3b8]\" data-kid=\"11\">\n        Practice with real AI interviewers, get instant feedback, and land your dream job faster.\n      </p>\n\n      \n      <div class=\"flex justify-center gap-10 mb-10\" data-kid=\"12\">\n        <div class=\"text-center\" data-kid=\"13\">\n          <p class=\"text-xl font-black text-white tracking-tight\" data-kid=\"14\">92%</p>\n          <p class=\"text-[11px] font-bold text-[#64748b] uppercase tracking-wider\" data-kid=\"15\">Success</p>\n        </div>\n        <div class=\"text-center\" data-kid=\"16\">\n          <p class=\"text-xl font-black text-white tracking-tight\" data-kid=\"17\">500K+</p>\n          <p class=\"text-[11px] font-bold text-[#64748b] uppercase tracking-wider\" data-kid=\"18\">Users</p>\n        </div>\n        <div class=\"text-center\" data-kid=\"19\">\n          <p class=\"text-xl font-black text-white tracking-tight\" data-kid=\"20\">4.9★</p>\n          <p class=\"text-[11px] font-bold text-[#64748b] uppercase tracking-wider\" data-kid=\"21\">Rating</p>\n        </div>\n      </div>\n\n      \n      <div class=\"p-4 rounded-2xl text-left relative overflow-hidden group border border-[#8b5cf6]/30 bg-gradient-to-br from-white/[0.05] to-transparent backdrop-blur-md\" data-kid=\"22\">\n        <div class=\"flex items-center gap-2 mb-3\" data-kid=\"23\">\n          <div class=\"w-2 h-2 bg-green-400 rounded-full animate-pulse shadow-[0_0_8px_rgba(74,222,128,0.5)]\" data-kid=\"24\"></div>\n          <span class=\"text-xs font-bold text-[#94a3b8] uppercase tracking-wider\" data-kid=\"25\">Live Interview Session</span>\n          <div class=\"flex items-end gap-1 ml-auto h-4\" data-kid=\"26\">\n            <div class=\"w-0.5 bg-[#8b5cf6] animate-waveform\" style=\"animation-delay: 0.1s\" data-kid=\"27\"></div>\n            <div class=\"w-0.5 bg-[#8b5cf6] animate-waveform\" style=\"animation-delay: 0.3s\" data-kid=\"28\"></div>\n            <div class=\"w-0.5 bg-[#8b5cf6] animate-waveform\" style=\"animation-delay: 0.5s\" data-kid=\"29\"></div>\n            <div class=\"w-0.5 bg-[#8b5cf6] animate-waveform\" style=\"animation-delay: 0.2s\" data-kid=\"30\"></div>\n            <div class=\"w-0.5 bg-[#8b5cf6] animate-waveform\" style=\"animation-delay: 0.4s\" data-kid=\"31\"></div>\n            <div class=\"w-0.5 bg-[#8b5cf6] animate-waveform\" style=\"animation-delay: 0.6s\" data-kid=\"32\"></div>\n          </div>\n        </div>\n        \n        <p class=\"text-[#cbd5e1] text-sm leading-relaxed mb-3\" data-kid=\"33\">\n          \"Explain the difference between TCP and UDP. When would you use each?\"\n        </p>\n\n        <div class=\"flex gap-2\" data-kid=\"34\">\n          <span class=\"px-2 py-0.5 text-xs rounded bg-[#8b5cf6]/15 text-[#c4b5fd]\" data-kid=\"35\">Technical</span>\n          <span class=\"px-2 py-0.5 text-xs rounded bg-[#10b981]/15 text-[#6ee7b7]\" data-kid=\"36\">Networking</span>\n        </div>\n      </div>\n    </div>\n  </div>\n\n  \n  <div class=\"flex-1 flex items-center justify-center p-6 md:p-12 bg-[#080812]\" data-kid=\"37\">\n    <div class=\"max-w-[420px] w-full\" id=\"auth-container\" data-kid=\"38\">\n      \n      \n      <div class=\"flex lg:hidden items-center gap-3 mb-12\" data-kid=\"39\">\n        <div class=\"w-10 h-10 rounded-xl flex items-center justify-center bg-gradient-to-br from-[#8b5cf6] to-[#3b82f6]\" data-kid=\"40\">\n          <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"text-white\" data-kid=\"41\"><path d=\"M13 2L3 14h9l-1 8 10-12h-9l1-8z\" data-kid=\"42\"></path></svg>\n        </div>\n        <span class=\"text-2xl font-black text-white font-heading\" data-kid=\"43\">InterviewAI</span>\n      </div>\n\n      \n      <div id=\"login-view\" data-kid=\"44\">\n        <div class=\"mb-10\" data-kid=\"45\">\n          <h1 class=\"text-4xl font-black text-white mb-2 font-heading tracking-tight\" data-kid=\"46\">Welcome back</h1>\n          <p class=\"text-sm text-[#94a3b8]\" data-kid=\"47\">Sign in to continue your interview prep journey.</p>\n        </div>\n\n        \n        <button class=\"w-full h-12 flex items-center justify-center gap-3 rounded-xl border border-white/10 bg-white/5 hover:bg-white/10 transition-all text-[#e2e8f0] text-sm font-medium mb-8\" data-kid=\"48\">\n          <svg width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" xmlns=\"http://www.w3.org/2000/svg\" data-kid=\"49\"><path d=\"M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z\" fill=\"#4285F4\" data-kid=\"50\"></path><path d=\"M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z\" fill=\"#34A853\" data-kid=\"51\"></path><path d=\"M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z\" fill=\"#FBBC05\" data-kid=\"52\"></path><path d=\"M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z\" fill=\"#EA4335\" data-kid=\"53\"></path></svg>\n          Continue with Google\n        </button>\n\n        <div class=\"flex items-center gap-4 my-10\" data-kid=\"54\">\n          <div class=\"flex-1 h-px bg-white/[0.04]\" data-kid=\"55\"></div>\n          <span class=\"text-[10px] font-bold text-[#475569] uppercase tracking-[0.25em] whitespace-nowrap\" data-kid=\"56\">or continue with email</span>\n          <div class=\"flex-1 h-px bg-white/[0.04]\" data-kid=\"57\"></div>\n        </div>\n\n        <form class=\"space-y-6\" data-kid=\"58\">\n          <div data-kid=\"59\">\n            <label class=\"block text-[10px] font-bold text-[#52525b] uppercase tracking-widest mb-2 ml-1\" data-kid=\"60\">Email Address</label>\n            <div class=\"relative\" data-kid=\"61\">\n              <span class=\"absolute left-4 top-1/2 -translate-y-1/2 text-[#475569]\" data-kid=\"62\">\n                <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" data-kid=\"63\"><rect width=\"20\" height=\"16\" x=\"2\" y=\"4\" rx=\"2\" data-kid=\"64\"></rect><path d=\"m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7\" data-kid=\"65\"></path></svg>\n              </span>\n              <input type=\"email\" placeholder=\"name@company.com\" class=\"w-full h-12 pl-12 pr-4 rounded-xl input-field\" data-kid=\"66\">\n            </div>\n          </div>\n\n          <div data-kid=\"67\">\n            <div class=\"flex items-center justify-between mb-2 px-1\" data-kid=\"68\">\n              <label class=\"block text-[10px] font-bold text-[#52525b] uppercase tracking-widest\" data-kid=\"69\">Password</label>\n              <a href=\"#\" class=\"text-[10px] font-bold text-[#8b5cf6] hover:text-[#a78bfa] transition-colors uppercase tracking-wider\" data-kid=\"70\">Forgot?</a>\n            </div>\n            <div class=\"relative\" data-kid=\"71\">\n              <span class=\"absolute left-4 top-1/2 -translate-y-1/2 text-[#475569]\" data-kid=\"72\">\n                <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" data-kid=\"73\"><rect width=\"18\" height=\"11\" x=\"3\" y=\"11\" rx=\"2\" ry=\"2\" data-kid=\"74\"></rect><path d=\"M7 11V7a5 5 0 0 1 10 0v4\" data-kid=\"75\"></path></svg>\n              </span>\n              <input type=\"password\" placeholder=\"••••••••\" class=\"w-full h-12 pl-12 pr-12 rounded-xl input-field\" id=\"login-pass\" data-kid=\"76\">\n              <button type=\"button\" class=\"absolute right-4 top-1/2 -translate-y-1/2 text-[#475569] hover:text-white\" onclick=\"togglePass('login-pass')\" data-kid=\"77\">\n                <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"eye-icon\" data-kid=\"78\"><path d=\"M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z\" data-kid=\"79\"></path><circle cx=\"12\" cy=\"12\" r=\"3\" data-kid=\"80\"></circle></svg>\n              </button>\n            </div>\n          </div>\n\n          <button type=\"button\" class=\"w-full h-12 rounded-xl neon-button flex items-center justify-center gap-2 group\" data-kid=\"81\">\n            Sign In\n            <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"group-hover:translate-x-1 transition-transform\" data-kid=\"82\"><path d=\"M5 12h14\" data-kid=\"83\"></path><path d=\"m12 5 7 7-7 7\" data-kid=\"84\"></path></svg>\n          </button>\n        </form>\n\n        <p class=\"mt-10 text-center text-[#64748b] text-sm font-medium\" data-kid=\"85\">\n          New to InterviewAI? \n          <button onclick=\"switchToSignup()\" class=\"text-[#8b5cf6] font-bold hover:text-[#a78bfa] transition-colors ml-1\" data-kid=\"86\">Create Account</button>\n        </p>\n      </div>\n\n      \n      <div id=\"signup-view\" class=\"hidden\" data-kid=\"87\">\n        <div class=\"mb-10\" data-kid=\"88\">\n          <h1 class=\"text-4xl font-black text-white mb-2 font-heading tracking-tight\" data-kid=\"89\">Create account</h1>\n          <p class=\"text-sm text-[#94a3b8]\" data-kid=\"90\">Start free — no credit card required.</p>\n        </div>\n\n        \n        <div class=\"mb-10\" data-kid=\"91\">\n          <div class=\"flex items-center justify-center gap-2 mb-2\" data-kid=\"92\">\n            \n            <div class=\"flex items-center\" data-kid=\"93\">\n              <div class=\"step-node w-8 h-8 rounded-full flex items-center justify-center text-sm font-bold active\" id=\"step-node-1\" data-kid=\"94\">1</div>\n              <div class=\"w-8 h-0.5 bg-white/10\" id=\"step-line-1\" data-kid=\"95\"></div>\n            </div>\n            \n            <div class=\"flex items-center\" data-kid=\"96\">\n              <div class=\"step-node w-8 h-8 rounded-full flex items-center justify-center text-sm font-bold bg-white/5 text-[#475569]\" id=\"step-node-2\" data-kid=\"97\">2</div>\n              <div class=\"w-8 h-0.5 bg-white/10\" id=\"step-line-2\" data-kid=\"98\"></div>\n            </div>\n            \n            <div class=\"step-node w-8 h-8 rounded-full flex items-center justify-center text-sm font-bold bg-white/5 text-[#475569]\" id=\"step-node-3\" data-kid=\"99\">3</div>\n          </div>\n          <div class=\"flex justify-around px-4\" data-kid=\"100\">\n            <span class=\"text-sm text-[#94a3b8]\" id=\"step-label-1\" data-kid=\"101\">Account</span>\n            <span class=\"text-sm text-[#475569]\" id=\"step-label-2\" data-kid=\"102\">Profile</span>\n            <span class=\"text-sm text-[#475569]\" id=\"step-label-3\" data-kid=\"103\">Preferences</span>\n          </div>\n        </div>\n\n        \n        <div id=\"signup-step-1\" data-kid=\"104\">\n          <div class=\"space-y-5\" data-kid=\"105\">\n            <button class=\"w-full h-12 flex items-center justify-center gap-3 rounded-xl border border-white/10 bg-white/5 hover:bg-white/10 transition-colors text-[#e2e8f0] font-medium\" data-kid=\"106\">\n              <svg width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" xmlns=\"http://www.w3.org/2000/svg\" data-kid=\"107\"><path d=\"M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z\" fill=\"#4285F4\" data-kid=\"108\"></path><path d=\"M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z\" fill=\"#34A853\" data-kid=\"109\"></path><path d=\"M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z\" fill=\"#FBBC05\" data-kid=\"110\"></path><path d=\"M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z\" fill=\"#EA4335\" data-kid=\"111\"></path></svg>\n              Google\n            </button>\n            <div class=\"flex items-center gap-4 py-2\" data-kid=\"112\">\n              <div class=\"flex-1 h-px bg-white/5\" data-kid=\"113\"></div>\n              <span class=\"text-[10px] font-bold text-[#475569] uppercase tracking-widest\" data-kid=\"114\">or email</span>\n              <div class=\"flex-1 h-px bg-white/5\" data-kid=\"115\"></div>\n            </div>\n            <div data-kid=\"116\">\n              <label class=\"block text-[10px] font-bold text-[#475569] uppercase tracking-widest mb-1.5 ml-1\" data-kid=\"117\">Full Name</label>\n              <input type=\"text\" placeholder=\"John Doe\" class=\"w-full h-12 px-4 rounded-xl input-field\" data-kid=\"118\">\n            </div>\n            <div data-kid=\"119\">\n              <label class=\"block text-[10px] font-bold text-[#475569] uppercase tracking-widest mb-1.5 ml-1\" data-kid=\"120\">Email Address</label>\n              <input type=\"email\" placeholder=\"john@example.com\" class=\"w-full h-12 px-4 rounded-xl input-field\" data-kid=\"121\">\n            </div>\n            <div data-kid=\"122\">\n              <label class=\"block text-[10px] font-bold text-[#475569] uppercase tracking-widest mb-1.5 ml-1\" data-kid=\"123\">Password</label>\n              <input type=\"password\" placeholder=\"Min. 8 characters\" class=\"w-full h-12 px-4 rounded-xl input-field\" data-kid=\"124\">\n            </div>\n            <button type=\"button\" onclick=\"nextStep(2)\" class=\"w-full h-12 rounded-xl neon-button flex items-center justify-center gap-2 mt-4\" data-kid=\"125\">\n              Continue\n              <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\" data-kid=\"126\"><path d=\"M5 12h14\" data-kid=\"127\"></path><path d=\"m12 5 7 7-7 7\" data-kid=\"128\"></path></svg>\n            </button>\n          </div>\n        </div>\n\n        <div id=\"signup-step-2\" class=\"hidden\" data-kid=\"129\">\n          <h2 class=\"text-4xl font-black text-white mb-2 font-heading tracking-tight\" data-kid=\"130\">Your role</h2>\n          <p class=\"text-sm text-[#94a3b8] mb-6\" data-kid=\"131\">Tell us what you're interviewing for.</p>\n          <div class=\"grid grid-cols-2 gap-3 mb-6\" data-kid=\"132\">\n            <button class=\"p-4 rounded-xl border border-white/5 bg-white/[0.03] hover:border-[#8b5cf6]/40 hover:bg-[#8b5cf6]/10 transition-all text-left group\" onclick=\"selectCardRole(this)\" data-kid=\"133\">\n              <div class=\"mb-2 text-[#64748b] group-hover:text-[#c4b5fd]\" data-kid=\"134\">\n                <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" data-kid=\"135\"><polyline points=\"16 18 22 12 16 6\" data-kid=\"136\"></polyline><polyline points=\"8 6 2 12 8 18\" data-kid=\"137\"></polyline></svg>\n              </div>\n              <span class=\"text-sm font-medium text-[#94a3b8] group-hover:text-[#c4b5fd]\" data-kid=\"138\">Software Engineer</span>\n            </button>\n            <button class=\"p-4 rounded-xl border border-white/5 bg-white/[0.03] hover:border-[#8b5cf6]/40 hover:bg-[#8b5cf6]/10 transition-all text-left group\" onclick=\"selectCardRole(this)\" data-kid=\"139\">\n              <div class=\"mb-2 text-[#64748b] group-hover:text-[#c4b5fd]\" data-kid=\"140\">\n                <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" data-kid=\"141\"><path d=\"M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2\" data-kid=\"142\"></path><circle cx=\"9\" cy=\"7\" r=\"4\" data-kid=\"143\"></circle><path d=\"M23 21v-2a4 4 0 0 0-3-3.87\" data-kid=\"144\"></path><path d=\"M16 3.13a4 4 0 0 1 0 7.75\" data-kid=\"145\"></path></svg>\n              </div>\n              <span class=\"text-sm font-medium text-[#94a3b8] group-hover:text-[#c4b5fd]\" data-kid=\"146\">Product Manager</span>\n            </button>\n            <button class=\"p-4 rounded-xl border border-white/5 bg-white/[0.03] hover:border-[#8b5cf6]/40 hover:bg-[#8b5cf6]/10 transition-all text-left group\" onclick=\"selectCardRole(this)\" data-kid=\"147\">\n              <div class=\"mb-2 text-[#64748b] group-hover:text-[#c4b5fd]\" data-kid=\"148\">\n                <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" data-kid=\"149\"><line x1=\"18\" y1=\"20\" x2=\"18\" y2=\"10\" data-kid=\"150\"></line><line x1=\"12\" y1=\"20\" x2=\"12\" y2=\"4\" data-kid=\"151\"></line><line x1=\"6\" y1=\"20\" x2=\"6\" y2=\"14\" data-kid=\"152\"></line></svg>\n              </div>\n              <span class=\"text-sm font-medium text-[#94a3b8] group-hover:text-[#c4b5fd]\" data-kid=\"153\">Data Scientist</span>\n            </button>\n            <button class=\"p-4 rounded-xl border border-white/5 bg-white/[0.03] hover:border-[#8b5cf6]/40 hover:bg-[#8b5cf6]/10 transition-all text-left group\" onclick=\"selectCardRole(this)\" data-kid=\"154\">\n              <div class=\"mb-2 text-[#64748b] group-hover:text-[#c4b5fd]\" data-kid=\"155\">\n                <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" data-kid=\"156\"><path d=\"M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2\" data-kid=\"157\"></path><circle cx=\"12\" cy=\"7\" r=\"4\" data-kid=\"158\"></circle></svg>\n              </div>\n              <span class=\"text-sm font-medium text-[#94a3b8] group-hover:text-[#c4b5fd]\" data-kid=\"159\">Other</span>\n            </button>\n          </div>\n          \n          <div class=\"space-y-3\" data-kid=\"160\">\n             <label class=\"block text-[10px] font-bold text-[#475569] uppercase tracking-widest ml-1\" data-kid=\"161\">Experience Level</label>\n             <select class=\"w-full h-12 px-4 rounded-xl input-field appearance-none cursor-pointer\" data-kid=\"162\">\n               <option data-kid=\"163\">Entry Level (0-2 yrs)</option>\n               <option data-kid=\"164\">Mid Level (2-5 yrs)</option>\n               <option data-kid=\"165\">Senior (5-10 yrs)</option>\n               <option data-kid=\"166\">Lead / Principal (10+ yrs)</option>\n             </select>\n          </div>\n\n          <div class=\"flex gap-3 mt-8\" data-kid=\"167\">\n            <button type=\"button\" onclick=\"nextStep(1)\" class=\"flex-1 h-12 rounded-xl border border-white/10 text-[#94a3b8] font-bold hover:bg-white/5 transition-colors\" data-kid=\"168\">Back</button>\n            <button type=\"button\" onclick=\"nextStep(3)\" class=\"flex-[2] h-12 rounded-xl neon-button font-bold\" data-kid=\"169\">Continue</button>\n          </div>\n        </div>\n\n        <div id=\"signup-step-3\" class=\"hidden\" data-kid=\"170\">\n           <h2 class=\"text-4xl font-black text-white mb-2 font-heading tracking-tight\" data-kid=\"171\">Preferences</h2>\n           <p class=\"text-sm text-[#94a3b8] mb-6\" data-kid=\"172\">What types of interviews do you want to practice?</p>\n           <div class=\"grid grid-cols-2 gap-3 mb-8\" data-kid=\"173\">\n             <button class=\"p-3 rounded-xl border border-white/10 bg-white/[0.03] text-sm font-medium text-[#94a3b8] flex items-center gap-2 hover:border-[#8b5cf6]/40 transition-all\" onclick=\"toggleSelect(this)\" data-kid=\"174\">\n               <div class=\"w-3.5 h-3.5 rounded-sm border border-slate-600 flex items-center justify-center bg-transparent transition-all\" data-kid=\"175\"></div>\n               Technical\n             </button>\n             <button class=\"p-3 rounded-xl border border-white/10 bg-white/[0.03] text-sm font-medium text-[#94a3b8] flex items-center gap-2 hover:border-[#8b5cf6]/40 transition-all\" onclick=\"toggleSelect(this)\" data-kid=\"176\">\n               <div class=\"w-3.5 h-3.5 rounded-sm border border-slate-600 flex items-center justify-center bg-transparent transition-all\" data-kid=\"177\"></div>\n               Behavioral\n             </button>\n             <button class=\"p-3 rounded-xl border border-white/10 bg-white/[0.03] text-sm font-medium text-[#94a3b8] flex items-center gap-2 hover:border-[#8b5cf6]/40 transition-all\" onclick=\"toggleSelect(this)\" data-kid=\"178\">\n               <div class=\"w-3.5 h-3.5 rounded-sm border border-slate-600 flex items-center justify-center bg-transparent transition-all\" data-kid=\"179\"></div>\n               HR Rounds\n             </button>\n             <button class=\"p-3 rounded-xl border border-white/10 bg-white/[0.03] text-sm font-medium text-[#94a3b8] flex items-center gap-2 hover:border-[#8b5cf6]/40 transition-all\" onclick=\"toggleSelect(this)\" data-kid=\"180\">\n               <div class=\"w-3.5 h-3.5 rounded-sm border border-slate-600 flex items-center justify-center bg-transparent transition-all\" data-kid=\"181\"></div>\n               Coding\n             </button>\n             <button class=\"p-3 rounded-xl border border-white/10 bg-white/[0.03] text-sm font-medium text-[#94a3b8] flex items-center gap-2 hover:border-[#8b5cf6]/40 transition-all\" onclick=\"toggleSelect(this)\" data-kid=\"182\">\n               <div class=\"w-3.5 h-3.5 rounded-sm border border-slate-600 flex items-center justify-center bg-transparent transition-all\" data-kid=\"183\"></div>\n               System Design\n             </button>\n           </div>\n\n           <div class=\"flex gap-3\" data-kid=\"184\">\n             <button type=\"button\" onclick=\"nextStep(2)\" class=\"flex-1 h-12 rounded-xl border border-white/10 text-[#94a3b8] font-bold hover:bg-white/5 transition-colors\" data-kid=\"185\">Back</button>\n             <button type=\"button\" onclick=\"handleFinish()\" id=\"finish-btn\" class=\"flex-[2] h-12 rounded-xl neon-button font-bold\" data-kid=\"186\">Complete Setup</button>\n           </div>\n        </div>\n\n        <p class=\"mt-8 text-center text-[#64748b] text-sm font-medium\" data-kid=\"187\">\n          Already have an account? \n          <button onclick=\"switchToLogin()\" class=\"text-[#8b5cf6] font-bold hover:underline ml-1\" data-kid=\"188\">Sign In</button>\n        </p>\n      </div>\n\n      \n      <div id=\"success-view\" class=\"hidden text-center py-10\" data-kid=\"189\">\n        <div class=\"w-20 h-20 bg-green-500/20 text-green-500 rounded-full flex items-center justify-center mx-auto mb-6\" data-kid=\"190\">\n          <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"40\" height=\"40\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"3\" stroke-linecap=\"round\" stroke-linejoin=\"round\" data-kid=\"191\"><polyline points=\"20 6 9 17 4 12\" data-kid=\"192\"></polyline></svg>\n        </div>\n        <h2 class=\"text-3xl font-black text-white mb-4 font-heading\" data-kid=\"193\">You're All Set!</h2>\n        <p class=\"text-[#94a3b8] mb-10 leading-relaxed\" data-kid=\"194\">Your personalized AI coaching dashboard is ready. Let's start preparing for your next big win.</p>\n        <button onclick=\"window.location.reload()\" class=\"w-full h-14 rounded-xl neon-button text-lg\" data-kid=\"195\">Enter Dashboard</button>\n      </div>\n\n    </div>\n  </div>\n</div>\n\n<script data-kid=\"196\">\n  function togglePass(id) {\n    const input = document.getElementById(id);\n    input.type = input.type === 'password' ? 'text' : 'password';\n  }\n\n  function switchToSignup() {\n    document.getElementById('login-view').classList.add('hidden');\n    document.getElementById('signup-view').classList.remove('hidden');\n    nextStep(1); // Ensure we start at step 1\n  }\n\n  function switchToLogin() {\n    document.getElementById('signup-view').classList.add('hidden');\n    document.getElementById('login-view').classList.remove('hidden');\n  }\n\n  function nextStep(step) {\n    // Hide all steps\n    for (let i = 1; i <= 3; i++) {\n      const stepDiv = document.getElementById('signup-step-' + i);\n      if (stepDiv) stepDiv.classList.add('hidden');\n      \n      const node = document.getElementById('step-node-' + i);\n      node.classList.remove('active', 'completed');\n      node.style.background = 'rgba(255,255,255,0.05)';\n      node.style.color = '#475569';\n      node.style.boxShadow = 'none';\n\n      const label = document.getElementById('step-label-' + i);\n      label.classList.remove('text-[#94a3b8]');\n      label.classList.add('text-[#475569]');\n      \n      if (i < 3) {\n        const line = document.getElementById('step-line-' + i);\n        line.style.background = 'rgba(255,255,255,0.1)';\n      }\n    }\n\n    // Show target step\n    document.getElementById('signup-step-' + step).classList.remove('hidden');\n    \n    // Update Indicators\n    for (let i = 1; i <= step; i++) {\n      const node = document.getElementById('step-node-' + i);\n      const label = document.getElementById('step-label-' + i);\n      \n      if (i < step) {\n        node.classList.add('completed');\n        node.style.background = 'linear-gradient(135deg, #8b5cf6, #3b82f6)';\n        node.style.color = 'white';\n        node.innerHTML = '<svg xmlns=\"http://www.w3.org/2000/svg\" width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"3\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><polyline points=\"20 6 9 17 4 12\"/></svg>';\n        if (i < 3) {\n          const line = document.getElementById('step-line-' + i);\n          line.style.background = '#8b5cf6';\n        }\n      } else {\n        node.classList.add('active');\n        node.style.background = 'linear-gradient(135deg, #8b5cf6, #3b82f6)';\n        node.style.color = 'white';\n        node.style.boxShadow = '0 0 15px rgba(139, 92, 246, 0.5)';\n        node.innerHTML = i;\n      }\n      \n      label.classList.remove('text-[#475569]');\n      label.classList.add('text-[#94a3b8]');\n    }\n  }\n\n  function toggleSelect(btn) {\n    const isSelected = btn.classList.contains('selected');\n    const checkbox = btn.querySelector('div');\n    if (isSelected) {\n      btn.classList.remove('selected');\n      btn.style.background = 'rgba(255,255,255,0.03)';\n      btn.style.borderColor = 'rgba(255,255,255,0.1)';\n      btn.style.color = '#94a3b8';\n      checkbox.style.background = 'transparent';\n      checkbox.style.borderColor = '#475569';\n      checkbox.innerHTML = '';\n    } else {\n      btn.classList.add('selected');\n      btn.style.background = 'rgba(139,92,246,0.15)';\n      btn.style.borderColor = 'rgba(139,92,246,0.4)';\n      btn.style.color = '#c4b5fd';\n      checkbox.style.background = '#8b5cf6';\n      checkbox.style.borderColor = '#8b5cf6';\n      checkbox.innerHTML = '<svg xmlns=\"http://www.w3.org/2000/svg\" width=\"10\" height=\"10\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"4\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"text-white\"><polyline points=\"20 6 9 17 4 12\"/></svg>';\n    }\n  }\n\n  function selectCardRole(btn) {\n    const allBtns = btn.parentElement.querySelectorAll('button');\n    allBtns.forEach(b => {\n      b.style.background = 'rgba(255,255,255,0.03)';\n      b.style.borderColor = 'rgba(255,255,255,0.05)';\n      const icon = b.querySelector('div');\n      icon.style.background = 'rgba(255,255,255,0.05)';\n      icon.style.color = '#64748b';\n      const text = b.querySelector('span');\n      text.style.color = '#94a3b8';\n    });\n\n    btn.style.background = 'rgba(139,92,246,0.15)';\n    btn.style.borderColor = 'rgba(139,92,246,0.4)';\n    const activeIcon = btn.querySelector('div');\n    activeIcon.style.background = 'rgba(139,92,246,0.2)';\n    activeIcon.style.color = '#c4b5fd';\n    const activeText = btn.querySelector('span');\n    activeText.style.color = '#c4b5fd';\n  }\n\n  function handleFinish() {\n    const btn = document.getElementById('finish-btn');\n    btn.disabled = true;\n    btn.innerHTML = '<div class=\"w-5 h-5 border-2 border-white/20 border-t-white animate-spin rounded-full\"></div> Setting up...';\n    \n    setTimeout(() => {\n      document.getElementById('signup-view').classList.add('hidden');\n      document.getElementById('success-view').classList.remove('hidden');\n    }, 1500);\n  }\n</script>\n",
