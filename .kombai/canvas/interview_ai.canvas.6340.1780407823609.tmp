             <i data-lucide=\"activity\" class=\"w-4 h-4\" data-kid=\"345\"></i> Full System Health\n            </button>\n          </div>\n        </div>\n\n        \n        <div class=\"glass-card rounded-3xl overflow-hidden\" data-kid=\"346\">\n          <div class=\"p-8 border-b border-white/5 flex flex-col md:flex-row justify-between items-center gap-4\" data-kid=\"347\">\n            <h4 class=\"font-bold\" data-kid=\"348\">Governance & User Management</h4>\n            <div class=\"flex gap-3 w-full md:w-auto\" data-kid=\"349\">\n              <div class=\"relative flex-1 md:w-64\" data-kid=\"350\">\n                <i data-lucide=\"search\" class=\"absolute left-3 top-1/2 -translate-y-1/2 text-slate-500 w-3.5 h-3.5\" data-kid=\"351\"></i>\n                <input type=\"text\" placeholder=\"Filter members...\" class=\"w-full bg-white/5 border border-white/10 rounded-xl pl-9 pr-4 py-2 text-xs focus:outline-none\" data-kid=\"352\">\n              </div>\n              <button class=\"bg-white/5 border border-white/10 rounded-xl px-4 py-2 text-xs font-bold hover:bg-white/10\" data-kid=\"353\"><i data-lucide=\"sliders-horizontal\" class=\"w-3.5 h-3.5\" data-kid=\"354\"></i></button>\n            </div>\n          </div>\n          <div class=\"overflow-x-auto\" data-kid=\"355\">\n            <table class=\"w-full text-left\" data-kid=\"356\">\n              <thead data-kid=\"357\">\n                <tr class=\"bg-white/[0.02] text-[10px] font-bold text-slate-500 uppercase tracking-widest\" data-kid=\"358\">\n                  <th class=\"px-8 py-5\" data-kid=\"359\">User Account</th>\n                  <th class=\"px-8 py-5\" data-kid=\"360\">Access Tier</th>\n                  <th class=\"px-8 py-5\" data-kid=\"361\">Last Activity</th>\n                  <th class=\"px-8 py-5\" data-kid=\"362\">Security Status</th>\n                  <th class=\"px-8 py-5 text-right\" data-kid=\"363\">Actions</th>\n                </tr>\n              </thead>\n              