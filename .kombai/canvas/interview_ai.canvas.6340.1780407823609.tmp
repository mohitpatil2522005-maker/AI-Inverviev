  <div class=\"flex items-center gap-4 p-4 rounded-xl bg-white/2 border border-white/5 hover:border-white/10 transition-all\" data-kid=\"173\">\n        <div class=\"w-10 h-10 rounded-xl bg-[#3b82f6]/15 flex items-center justify-center shrink-0\" data-kid=\"174\">\n          <i data-lucide=\"clock\" class=\"w-5 h-5 text-[#3b82f6]\" data-kid=\"175\"></i>\n        </div>\n        <div class=\"min-w-0\" data-kid=\"176\">\n          <p class=\"text-sm font-semibold text-white truncate\" data-kid=\"177\">Behavioral - Amazon LP</p>\n          <p class=\"text-xs mt-0.5 text-[var(--text-faint)]\" data-kid=\"178\">Thu, 5 PM</p>\n        </div>\n      </div>\n      <div class=\"flex items-center gap-4 p-4 rounded-xl bg-white/2 border border-white/5 hover:border-white/10 transition-all\" data-kid=\"179\">\n        <div class=\"w-10 h-10 rounded-xl bg-[#3b82f6]/15 flex items-center justify-center shrink-0\" data-kid=\"180\">\n          <i data-lucide=\"clock\" class=\"w-5 h-5 text-[#3b82f6]\" data-kid=\"181\"></i>\n        </div>\n        <div class=\"min-w-0\" data-kid=\"182\">\n          <p class=\"text-sm font-semibold text-white truncate\" data-kid=\"183\">Coding - Hard LeetCode</p>\n          <p class=\"text-xs mt-0.5 text-[var(--text-faint)]\" data-kid=\"184\">Fri, 2 PM</p>\n        </div>\n      </div>\n    </div>\n  </section>\n</main>\n\n<script src=\"https://unpkg.com/lucide@latest\" data-kid=\"185\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/chart.js\" data-kid=\"186\"></script>\n<script data-kid=\"187\">\n  // Initialize Lucide Icons\n  lucide.createIcons();\n\n  // Weekly Performance Area Chart\n  const ctxWeekly = document.getElementById('weeklyChart').getContext('2d');\n  const gradientWeekly = ctxWeekly.createLinearGradient(0, 0, 0, 200);\n  gradientWeekly.addColorStop(0, 'rgba(139, 92, 246, 0.3)');\n  gradientWeekly.addColorStop(1, 'rgba(139, 92, 246, 0)');\n\n  new Chart(ctxWeekly, {\n    type: 'line',\n    data: {\n      labels: ['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun'],\n      datasets: [{\n        label: 'Score',\n        data: [68, 74, 71, 82, 79, 85, 88],\n        borderColor: '#8b5cf6',\n        borderWidth: 3,\n        fill: true,\n        backgroundColor: gradientWeekly,\n        tension: 0.4,\n        pointBackgroundColor: '#8b5cf6',\n        pointRadius: 4,\n        pointHoverRadius: 6\n      }]\n    },\n    options: {\n      responsive: true,\n      maintainAspectRatio: false,\n      plugins: {\n        legend: { display: false },\n        tooltip: {\n          backgroundColor: '#111128',\n          titleColor: '#fff',\n          bodyColor: '#94a3b8',\n          borderColor: 'rgba(255,255,255,0.1)',\n          borderWidth: 1,\n          padding: 10,\n          displayColors: false\n        }\n      },\n      scales: {\n        y: {\n          min: 50,\n          max: 100,\n          grid: { color: 'rgba(255,255,255,0.04)', drawBorder: false },\n          ticks: { color: '#475569', font: { size: 10 } }\n        },\n        x: {\n          grid: { display: false },\n          ticks: { color: '#475569', font: { size: 10 } }\n        }\n      }\n    }\n  });\n\n  // Skill Radar Chart\n  const ctxRadar = document.getElementById('skillRadar').getContext('2d');\n  new Chart(ctxRadar, {\n    type: 'radar',\n    data: {\n      labels: ['Technical', 'Communication', 'Problem Solving', 'Leadership', 'HR Readiness', 'Coding'],\n      datasets: [{\n        data: [78, 85, 72, 65, 90, 80],\n        backgroundColor: 'rgba(139, 92, 246, 0.15)',\n        borderColor: '#8b5cf6',\n        borderWidth: 2,\n        pointBackgroundColor: '#8b5cf6',\n        pointRadius: 2\n      }]\n    },\n    options: {\n      responsive: true,\n      maintainAspectRatio: false,\n      plugins: { legend: { display: false } },\n      scales: {\n        r: {\n          angleLines: { color: 'rgba(255,255,255,0.06)' },\n          grid: { color: 'rgba(255,255,255,0.06)' },\n          pointLabels: { color: '#cbd5e1', font: { size: 11, weight: '500' }, padding: 15 },\n          ticks: { display: false },\n          suggestedMin: 0,\n          suggestedMax: 100\n        }\n      }\n    }\n  });\n\n  // Activity Heatmap Generator\n  const heatmapContainer = document.getElementById('activityHeatmap');\n  const daysCount = 7 * 12; // 12 weeks\n  const pseudoRandom = (i) => {\n    const x = Math.sin(i + 13) * 10000;\n    return x - Math.floor(x);\n  };\n  for (let i = 0; i < daysCount; i++) {\n    const dot = document.createElement('div');\n    dot.className = 'w-3 h-3 rounded-[2px] transition-all hover:scale-125 cursor-pointer';\n    const intensity = pseudoRandom(i);\n    if (intensity > 0.8) dot.style.backgroundColor = '#8b5cf6';\n    else if (intensity > 0.5) dot.style.backgroundColor = 'rgba(139,92,246,0.6)';\n    else if (intensity > 0.2) dot.style.backgroundColor = 'rgba(139,92,246,0.3)';\n    else dot.style.backgroundColor = 'rgba(255,255,255,0.04)';\n    heatmapContainer.appendChild(dot);\n  }\n</script>\n",
